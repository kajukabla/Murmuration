ineLayout({\n   189→    bindGroupLayouts: [bgl, statsBGL],\n   190→  });\n   191→  const clearStatsPipe = device.createComputePipeline({\n   192→    layout: statsPipeLayout,\n   193→    compute: { module, entryPoint: 'clear_stats' },\n   194→  });\n   195→  const computeStatsPipe = device.createComputePipeline({\n   196→    layout: statsPipeLayout,\n   197→    compute: { module, entryPoint: 'compute_stats' },\n   198→  });\n   199→\n   200→  let step = 0;\n   201→  let autoRangeEnabled = false;\n   202→  let statsReading = false;\n   203→  let smoothMin = 0, smoothMax = 1;\n   204→  let emaInitialized = false;\n   205→\n   206→  return {\n   207→    numBoids,\n   208→    boidA,\n   209→    boidB,\n   210→    setParams: writeParams,\n   211→    applySizeRandomness,\n   212→\n   213→    set autoRange(v) { autoRangeEnabled = v; if (!v) emaInitialized = false; },\n   214→    get autoMin() { return smoothMin; },\n   215→    get autoMax() { return smoothMax; },\n   216→\n   217→    /** Run one sim step. Set lastStep=true on the final step of the frame. */\n   218→    update(encoder, lastStep = true) {\n   219→      const bg = step % 2 === 0 ? bgA : bgB;\n   220→      const passes = [\n   221→        [clearPipe,   gridWG],\n   222→        [assignPipe,  boidWG],\n   223→        [prefixPipe,  1],\n   224→        [scatterPipe, boidWG],\n   225→        [flockPipe,   boidWG],\n   226→      ];\n   227→      for (const [pipeline, wg] of passes) {\n   228→        const p = encoder.beginComputePass();\n   229→        p.setPipeline(pipeline);\n   230→        p.setBindGroup(0, bg);\n   231→        p.dispatchWorkgroups(wg);\n   232→        p.end();\n   233→      }\n   234→\n   235→      // Only compute stats on the last step of the frame (avoids races with multi-step)\n   236→      if (autoRangeEnabled && lastStep && !statsReading) {\n   237→        const c = encoder.beginComputePass();\n   238→        c.setPipeline(clearStatsPipe);\n   239→        c.setBindGroup(0, bg);\n   240→     