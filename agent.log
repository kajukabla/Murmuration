{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M5X6WF6aMPH6yckBpcS1mC","type":"tool_result","content":"     1→// === 3D Murmuration Compute Shader — Topological Neighbor Model ===\n     2→// Based on empirical starling research: birds track their nearest 7 neighbors,\n     3→// not all within a fixed radius. This produces realistic wave propagation,\n     4→// sharp flock edges, and coordinated turns.\n     5→\n     6→struct SimParams {\n     7→  num_boids: u32,\n     8→  grid_size: u32,\n     9→  grid_cells: u32,\n    10→  world_size: f32,\n    11→  cell_size: f32,\n    12→  visual_range: f32,\n    13→  visual_range_sq: f32,\n    14→  separation_dist: f32,\n    15→  separation_dist_sq: f32,\n    16→  align_factor: f32,\n    17→  cohesion_factor: f32,\n    18→  separation_factor: f32,\n    19→  max_speed: f32,\n    20→  min_speed: f32,\n    21→  dt: f32,\n    22→  turn_factor: f32,\n    23→  smoothing: f32,\n    24→  sim_speed: f32,\n    25→  size_randomness: f32,\n    26→  drag_factor: f32,\n    27→  gradient_id: u32,\n    28→  color_source: u32,\n    29→  sphere_radius: f32,\n    30→  frame_count: u32,\n    31→}\n    32→\n    33→struct Boid {\n    34→  pos: vec3f,\n    35→  size_factor: f32,\n    36→  vel: vec3f,\n    37→  speed: f32,\n    38→  heading: vec3f,\n    39→  neighbor_count: f32,\n    40→  dir_change: f32,\n    41→  flock_alignment: f32,\n    42→  sep_pressure: f32,\n    43→  density: f32,\n    44→}\n    45→\n    46→@group(0) @binding(0) var<uniform> params: SimParams;\n    47→@group(0) @binding(1) var<storage, read_write> boids_src: array<Boid>;\n    48→@group(0) @binding(2) var<storage, read_write> boids_dst: array<Boid>;\n    49→@group(0) @binding(3) var<storage, read_write> cell_counts: array<atomic<u32>>;\n    50→@group(0) @binding(4) var<storage, read_write> cell_offsets: array<u32>;\n    51→@group(0) @binding(5) var<storage, read_write> boid_cells: array<u32>;\n    52→@group(0) @binding(6) var<storage, read_write> sorted_indices: array<u32>;\n    53→@group(0) @binding(7) var<storage, read_write> scatter_counters: array<atomic<u32>>;\n    54→\n    55→fn get_cell(pos: vec3f) -> vec3u {\n    56→  let half = params.world_size * 0.5;\n    57→  return vec3u(clamp(\n    58→    vec3i(floor((pos + vec3f(half)) / params.cell_size)),\n    59→    vec3i(0),\n    60→    vec3i(i32(params.grid_size) - 1)\n    61→  ));\n    62→}\n    63→\n    64→fn cell_index(c: vec3u) -> u32 {\n    65→  return c.x + c.y * params.grid_size + c.z * params.grid_size * params.grid_size;\n    66→}\n    67→\n    68→@compute @workgroup_size(64)\n    69→fn clear_grid(@builtin(global_invocation_id) id: vec3u) {\n    70→  let i = id.x;\n    71→  if (i >= params.grid_cells) { return; }\n    72→  atomicStore(&cell_counts[i], 0u);\n    73→  atomicStore(&scatter_counters[i], 0u);\n    74→}\n    75→\n    76→@compute @workgroup_size(64)\n    77→fn assign_cells(@builtin(global_invocation_id) id: vec3u) {\n    78→  let i = id.x;\n    79→  if (i >= params.num_boids) { return; }\n    80→  let cell = cell_index(get_cell(boids_src[i].pos));\n    81→  boid_cells[i] = cell;\n    82→  atomicAdd(&cell_counts[cell], 1u);\n    83→}\n    84→\n    85→const SCAN_WG: u32 = 256u;\n    86→var<workgroup> scan_sums: array<u32, 256>;\n    87→\n    88→@compute @workgroup_size(256)\n    89→fn prefix_sum(@builtin(local_invocation_id) lid: vec3u) {\n    90→  let tid = lid.x;\n    91→  let chunk = (params.grid_cells + SCAN_WG - 1u) / SCAN_WG;\n    92→  let start = tid * chunk;\n    93→  let end = min(start + chunk, params.grid_cells);\n    94→  var local_total = 0u;\n    95→  for (var i = start; i < end; i++) {\n    96→    let count = atomicLoad(&cell_counts[i]);\n    97→    cell_offsets[i] = local_total;\n    98→    local_total += count;\n    99→  }\n   100→  scan_sums[tid] = local_total;\n   101→  workgroupBarrier();\n   102→  for (var stride = 1u; stride < SCAN_WG; stride *= 2u) {\n   103→    let val = select(0u, scan_sums[tid - stride], tid >= stride);\n   104→    workgroupBarrier();\n   105→    scan_sums[tid] += val;\n   106→    workgroupBarrier();\n   107→  }\n   108→  let prefix = select(0u, scan_sums[tid - 1u], tid > 0u);\n   109→  for (var i = start; i < end; i++) {\n   110→    cell_offsets[i] += prefix;\n   111→  }\n   112→}\n   113→\n   114→@compute @workgroup_size(64)\n   115→fn scatter(@builtin(global_invocation_id) id: vec3u) {\n   116→  let i = id.x;\n   117→  if (i >= params.num_boids) { return; }\n   118→  let cell = boid_cells[i];\n   119→  let local_offset = atomicAdd(&scatter_counters[cell], 1u);\n   120→  sorted_indices[cell_offsets[cell] + local_offset] = i;\n   121→}\n   122→\n   123→// === Topological Neighbor Flocking ===\n   124→// Find the K nearest neighbors (K=7 for alignment/cohesion, closest 1 for avoidance)\n   125→// Uses the spatial hash to find candidates, then keeps only the K closest.\n   126→\n   127→const K_NEIGHBORS: u32 = 7u;\n   128→\n   129→@compute @workgroup_size(64)\n   130→fn flock(@builtin(global_invocation_id) id: vec3u) {\n   131→  let i = id.x;\n   132→  if (i >= params.num_boids) { return; }\n   133→\n   134→  let boid = boids_src[i];\n   135→  let my_grid = get_cell(boid.pos);\n   136→  let gs = i32(params.grid_size);\n   137→  let mg = vec3i(my_grid);\n   138→\n   139→  // Track K nearest neighbors by distance (insertion sort into small array)\n   140→  // Store squared distances and indices\n   141→  var nearest_d2: array<f32, 7>;   // distances squared\n   142→  var nearest_idx: array<u32, 7>;  // boid indices\n   143→  var n_found = 0u;\n   144→\n   145→  // Initialize with large distances\n   146→  for (var k = 0u; k < K_NEIGHBORS; k++) {\n   147→    nearest_d2[k] = 1e10;\n   148→    nearest_idx[k] = 0u;\n   149→  }\n   150→\n   151→  // Search 3x3x3 neighborhood (27 cells)\n   152→  let lo = max(mg - vec3i(1), vec3i(0));\n   153→  let hi = min(mg + vec3i(1), vec3i(gs - 1));\n   154→\n   155→  var total_candidates = 0u;\n   156→\n   157→  for (var nz = lo.z; nz <= hi.z; nz++) {\n   158→    let zoff = u32(nz) * params.grid_size * params.grid_size;\n   159→    for (var ny = lo.y; ny <= hi.y; ny++) {\n   160→      let yzoff = u32(ny) * params.grid_size + zoff;\n   161→      for (var nx = lo.x; nx <= hi.x; nx++) {\n   162→        let nc = u32(nx) + yzoff;\n   163→        let start = cell_offsets[nc];\n   164→        let end_val = select(cell_offsets[nc + 1u], params.num_boids, nc + 1u >= params.grid_cells);\n   165→        if (start >= end_val) { continue; }\n   166→\n   167→        for (var j = start; j < end_val; j++) {\n   168→          let other_idx = sorted_indices[j];\n   169→          if (other_idx == i) { continue; }\n   170→\n   171→          let other_pos = boids_src[other_idx].pos;\n   172→          let diff = boid.pos - other_pos;\n   173→          let d2 = dot(diff, diff);\n   174→\n   175→          // Pre-filter by visual range before K-nearest sort\n   176→          if (d2 > params.visual_range_sq) { continue; }\n   177→\n   178→          total_candidates++;\n   179→\n   180→          // Insert into sorted K-nearest if closer than current worst\n   181→          if (d2 < nearest_d2[K_NEIGHBORS - 1u]) {\n   182→            // Find insertion position\n   183→            var pos = K_NEIGHBORS - 1u;\n   184→            for (var k = 0u; k < K_NEIGHBORS - 1u; k++) {\n   185→              if (d2 < nearest_d2[k]) {\n   186→                pos = k;\n   187→                break;\n   188→              }\n   189→            }\n   190→            // Shift larger entries down\n   191→            for (var k = K_NEIGHBORS - 1u; k > pos; k--) {\n   192→              nearest_d2[k] = nearest_d2[k - 1u];\n   193→              nearest_idx[k] = nearest_idx[k - 1u];\n   194→            }\n   195→            nearest_d2[pos] = d2;\n   196→            nearest_idx[pos] = other_idx;\n   197→            n_found = min(n_found + 1u, K_NEIGHBORS);\n   198→          }\n   199→        }\n   200→      }\n   201→    }\n   202→  }\n   203→\n   204→  // === Apply flocking rules using topological neighbors ===\n   205→  var new_vel = boid.vel;\n   206→\n   207→  // Avoidance: only the 1 nearest neighbor\n   208→  var sep_force = vec3f(0.0);\n   209→  if (n_found > 0u && nearest_d2[0] < params.separation_dist_sq) {\n   210→    let other_pos = boids_src[nearest_idx[0]].pos;\n   211→    let diff = boid.pos - other_pos;\n   212→    let d2 = nearest_d2[0];\n   213→    sep_force = diff * (1.0 - d2 / params.separation_dist_sq);\n   214→    new_vel += sep_force * params.separation_factor * 2.0; // stronger since only 1 neighbor\n   215→  }\n   216→\n   217→  // Alignment + Cohesion: all K neighbors\n   218→  var ali = vec3f(0.0);\n   219→  var coh = vec3f(0.0);\n   220→  var avg_vel = vec3f(0.0);\n   221→  if (n_found > 0u) {\n   222→    for (var k = 0u; k < min(n_found, K_NEIGHBORS); k++) {\n   223→      let other = boids_src[nearest_idx[k]];\n   224→      ali += other.vel;\n   225→      coh += other.pos;\n   226→    }\n   227→    let nf = f32(min(n_found, K_NEIGHBORS));\n   228→    avg_vel = ali / nf;\n   229→    let avg_pos = coh / nf;\n   230→    new_vel += (avg_vel - boid.vel) * params.align_factor;\n   231→    new_vel += (avg_pos - boid.pos) * params.cohesion_factor;\n   232→  }\n   233→\n   234→  // === Emergent murmuration forces ===\n   235→  // NO roost attractor, NO predator orbit — purely local interactions\n   236→  // The complex sweeping motion emerges from topological neighbor rules\n   237→  // + rare perturbations that cascade through the flock\n   238→\n   239→  // Gentle gravity (creates oblate/flat flock shape)\n   240→  new_vel.y -= 0.03;\n   241→\n   242→  // Rare strong perturbation: only ~3% of birds per frame\n   243→  // This is the primary driver of non-repetitive motion —\n   244→  // a random bird changes direction, neighbors respond via alignment,\n   245→  // creating a wave that sweeps across the entire flock\n   246→  let perturb_hash = fract(sin(f32(i * 7919u + params.frame_count * 104729u)) * 43758.5);\n   247→  if (perturb_hash < 0.07) {\n   248→    let seed = f32(i * 1973u + params.frame_count * 9277u);\n   249→    let kick = vec3f(\n   250→      fract(sin(seed) * 43758.5) - 0.5,\n   251→      fract(sin(seed * 1.3) * 22578.1) - 0.5,\n   252→      fract(sin(seed * 0.7) * 31415.9) - 0.5\n   253→    ) * 3.5;  // strong kick that cascades via topological links\n   254→    new_vel += kick;\n   255→  }\n   256→\n   257→  // Spherical boundary steering\n   258→  let dist_from_center = length(boid.pos);\n   259→  let r = params.sphere_radius;\n   260→  let soft_zone = r * 0.15;\n   261→  if (dist_from_center > r - soft_zone && dist_from_center > 0.001) {\n   262→    let penetration = (dist_from_center - (r - soft_zone)) / soft_zone;\n   263→    let push = -normalize(boid.pos) * params.turn_factor * clamp(penetration, 0.0, 3.0);\n   264→    new_vel += push;\n   265→  }\n   266→\n   267→  // Turn rate limiter (smooth heading changes — creates wave-like motion)\n   268→  let old_speed = length(boid.vel);\n   269→  var old_dir = boid.vel;\n   270→  if (old_speed > 0.001) { old_dir = old_dir / old_speed; }\n   271→  else { old_dir = vec3f(1.0, 0.0, 0.0); }\n   272→  let desired_speed = length(new_vel);\n   273→  var desired_dir = new_vel;\n   274→  if (desired_speed > 0.001) { desired_dir = desired_dir / desired_speed; }\n   275→  else { desired_dir = old_dir; }\n   276→  let final_dir = normalize(mix(old_dir, desired_dir, params.smoothing));\n   277→\n   278→  // Speed with drag\n   279→  let drag_scale = 1.0 / mix(1.0, boid.size_factor, params.drag_factor);\n   280→  var final_speed = mix(old_speed, desired_speed, 0.15);\n   281→  final_speed = clamp(final_speed, params.min_speed * drag_scale, params.max_speed * drag_scale);\n   282→  new_vel = final_dir * final_speed;\n   283→\n   284→  // Direction change metric\n   285→  let dir_change_val = 1.0 - clamp(dot(old_dir, final_dir), -1.0, 1.0);\n   286→  let effective_dt = params.dt;\n   287→\n   288→  // Write outputs\n   289→  boids_dst[i].pos = boid.pos + new_vel * effective_dt;\n   290→  boids_dst[i].vel = new_vel;\n   291→  boids_dst[i].size_factor = boid.size_factor;\n   292→  boids_dst[i].heading = final_dir;\n   293→  boids_dst[i].speed = final_speed;\n   294→  boids_dst[i].neighbor_count = f32(n_found);\n   295→  boids_dst[i].dir_change = dir_change_val;\n   296→  let vel_d2 = dot(boid.vel, boid.vel);\n   297→  let avg_d2 = dot(avg_vel, avg_vel);\n   298→  boids_dst[i].flock_alignment = select(dot(boid.vel, avg_vel) * inverseSqrt(vel_d2 * avg_d2), 0.0, vel_d2 < 0.001 || avg_d2 < 0.001);\n   299→  boids_dst[i].sep_pressure = length(sep_force);\n   300→  boids_dst[i].density = f32(n_found) / f32(K_NEIGHBORS);\n   301→}\n   302→\n   303→// === Classic Radius-Based Flocking (high performance, simpler behavior) ===\n   304→@compute @workgroup_size(64)\n   305→fn flock_radius(@builtin(global_invocation_id) id: vec3u) {\n   306→  let i = id.x;\n   307→  if (i >= params.num_boids) { return; }\n   308→\n   309→  let boid = boids_src[i];\n   310→  let my_grid = get_cell(boid.pos);\n   311→  let gs = i32(params.grid_size);\n   312→  let mg = vec3i(my_grid);\n   313→  let lo = max(mg - vec3i(1), vec3i(0));\n   314→  let hi = min(mg + vec3i(1), vec3i(gs - 1));\n   315→\n   316→  var sep = vec3f(0.0);\n   317→  var ali = vec3f(0.0);\n   318→  var coh = vec3f(0.0);\n   319→  var n_align = 0u;\n   320→\n   321→  // Process own cell first — in dense clusters, avoids searching 26 neighbors\n   322→  let my_ci = cell_index(my_grid);\n   323→  let my_start = cell_offsets[my_ci];\n   324→  let my_end = select(cell_offsets[my_ci + 1u], params.num_boids, my_ci + 1u >= params.grid_cells);\n   325→  if (my_start < my_end) {\n   326→    let cell_end = min(my_end, my_start + 4u);\n   327→    for (var j = my_start; j < cell_end; j++) {\n   328→      let other_idx = sorted_indices[j];\n   329→      if (other_idx == i) { continue; }\n   330→      let other_pos = boids_src[other_idx].pos;\n   331→      let diff = boid.pos - other_pos;\n   332→      let d2 = dot(diff, diff);\n   333→      let in_range = f32(d2 < params.visual_range_sq && d2 > 0.0001);\n   334→      ali += boids_src[other_idx].vel * in_range;\n   335→      coh += other_pos * in_range;\n   336→      n_align += u32(in_range);\n   337→      let in_sep = f32(d2 < params.separation_dist_sq) * in_range;\n   338→      sep += diff * (1.0 - d2 / params.separation_dist_sq) * in_sep;\n   339→    }\n   340→  }\n   341→\n   342→  // Only search 26 neighbor cells if own cell didn't provide enough\n   343→  if (n_align < 2u) {\n   344→    for (var nz = lo.z; nz <= hi.z; nz++) {\n   345→      let zoff = u32(nz) * params.grid_size * params.grid_size;\n   346→      for (var ny = lo.y; ny <= hi.y; ny++) {\n   347→        let yzoff = u32(ny) * params.grid_size + zoff;\n   348→        for (var nx = lo.x; nx <= hi.x; nx++) {\n   349→          let nc = u32(nx) + yzoff;\n   350→          if (nc == my_ci) { continue; } // skip own cell (already processed)\n   351→          let start = cell_offsets[nc];\n   352→          let end_val = select(cell_offsets[nc + 1u], params.num_boids, nc + 1u >= params.grid_cells);\n   353→          if (start >= end_val) { continue; }\n   354→          let cell_end = min(end_val, start + 6u);\n   355→          for (var j = start; j < cell_end; j++) {\n   356→            let other_idx = sorted_indices[j];\n   357→            if (other_idx == i) { continue; }\n   358→            let other_pos = boids_src[other_idx].pos;\n   359→            let diff = boid.pos - other_pos;\n   360→            let d2 = dot(diff, diff);\n   361→            let in_range = f32(d2 < params.visual_range_sq && d2 > 0.0001);\n   362→            ali += boids_src[other_idx].vel * in_range;\n   363→            coh += other_pos * in_range;\n   364→            n_align += u32(in_range);\n   365→            let in_sep = f32(d2 < params.separation_dist_sq) * in_range;\n   366→            sep += diff * (1.0 - d2 / params.separation_dist_sq) * in_sep;\n   367→          }\n   368→          if (n_align >= 2u) { break; }\n   369→        }\n   370→        if (n_align >= 2u) { break; }\n   371→      }\n   372→      if (n_align >= 2u) { break; }\n   373→    }\n   374→  }\n   375→\n   376→  var new_vel = boid.vel;\n   377→  if (n_align > 0u) {\n   378→    let nf = f32(n_align);\n   379→    new_vel += (ali / nf - boid.vel) * params.align_factor;\n   380→    new_vel += (coh / nf - boid.pos) * params.cohesion_factor;\n   381→  }\n   382→  new_vel += sep * params.separation_factor;\n   383→\n   384→  // Spherical boundary (cheap d2 test first, sqrt only for edge boids)\n   385→  let center_d2 = dot(boid.pos, boid.pos);\n   386→  let r = params.sphere_radius;\n   387→  let threshold = r - r * 0.15;\n   388→  if (center_d2 > threshold * threshold) {\n   389→    let inv_dist = inverseSqrt(max(center_d2, 1e-6));\n   390→    let dist = center_d2 * inv_dist;\n   391→    let penetration = (dist - threshold) / (r * 0.15);\n   392→    new_vel -= boid.pos * (inv_dist * params.turn_factor * min(penetration, 3.0));\n   393→  }\n   394→\n   395→  // Speed clamp only — skip smoothing mix to reduce ALU\n   396→  let spd_sq = dot(new_vel, new_vel);\n   397→  let max_spd = params.max_speed;\n   398→  if (spd_sq > max_spd * max_spd) {\n   399→    new_vel *= max_spd * inverseSqrt(spd_sq);\n   400→  } else if (spd_sq < params.min_speed * params.min_speed) {\n   401→    new_vel *= params.min_speed * inverseSqrt(max(spd_sq, 1e-6));\n   402→  }\n   403→\n   404→  // Write minimal fields\n   405→  boids_dst[i].pos = boid.pos + new_vel * params.dt;\n   406→  boids_dst[i].vel = new_vel;\n   407→  boids_dst[i].size_factor = boid.size_factor;\n   408→  boids_dst[i].heading = new_vel * inverseSqrt(max(dot(new_vel, new_vel), 1e-6));\n   409→}\n   410→\n   411→// === Auto-range stats ===\n   412→@group(1) @binding(0) var<storage, read_write> stats: array<atomic<u32>, 2>;\n   413→\n   414→fn get_metric(boid: Boid, source: u32) -> f32 {\n   415→  switch (source) {\n   416→    case 0u: { return dot(normalize(boid.heading + vec3f(0.0001, 0.0, 0.0)), vec3f(0.3, 0.4, 0.3)) + 0.5; }\n   417→    case 1u: { return boid.speed; }\n   418→    case 2u: { return boid.dir_change; }\n   419→    case 3u: { return boid.neighbor_count; }\n   420→    case 4u: { return (boid.pos.y + 50.0) / 100.0; }\n   421→    case 5u: { return length(boid.pos) / 50.0; }\n   422→    case 6u: { return boid.flock_alignment * 0.5 + 0.5; }\n   423→    case 7u: { return boid.sep_pressure; }\n   424→    case 8u: { return boid.density; }\n   425→    case 9u: { return 0.5; }\n   426→    default: { return 0.5; }\n   427→  }\n   428→}\n   429→\n   430→@compute @workgroup_size(64)\n   431→fn clear_stats(@builtin(global_invocation_id) id: vec3u) {\n   432→  if (id.x == 0u) {\n   433→    atomicStore(&stats[0], bitcast<u32>(1e10));\n   434→    atomicStore(&stats[1], 0u);\n   435→  }\n   436→}\n   437→\n   438→@compute @workgroup_size(64)\n   439→fn compute_stats(@builtin(global_invocation_id) id: vec3u) {\n   440→  let i = id.x;\n   441→  if (i >= params.num_boids) { return; }\n   442→  let val = get_metric(boids_src[i], params.color_source);\n   443→  let val_bits = bitcast<u32>(val);\n   444→  atomicMin(&stats[0], val_bits);\n   445→  atomicMax(&stats[1], val_bits);\n   446→}\n   447→\n   448→// === Murmuration Quality Metrics ===\n   449→// Computes behavioral metrics for evaluating murmuration quality.\n   450→// Uses @group(1) @binding(1) for a metrics buffer (separate from auto-range stats).\n   451→// 16 atomic u32 slots, interpreted as f32 via bitcast accumulation.\n   452→\n   453→@group(1) @binding(1) var<storage, read_write> metrics: array<atomic<u32>, 16>;\n   454→\n   455→// Slots:\n   456→// 0: count of boids with >= 5 neighbors (cohesion)\n   457→// 1: sum of neighbor_count (for avg)\n   458→// 2: sum of velocity_correlation (dot products)\n   459→// 3: sum of pos.x\n   460→// 4: sum of pos.y\n   461→// 5: sum of pos.z\n   462→// 6: sum of pos.x^2\n   463→// 7: sum of pos.y^2\n   464→// 8: sum of pos.z^2\n   465→// 9: sum of neighbor_count^2 (for variance)\n   466→// 10: count of boids processed\n   467→\n   468→@compute @workgroup_size(64)\n   469→fn clear_metrics(@builtin(global_invocation_id) id: vec3u) {\n   470→  if (id.x == 0u) {\n   471→    for (var k = 0u; k < 16u; k++) {\n   472→      atomicStore(&metrics[k], 0u);\n   473→    }\n   474→  }\n   475→}\n   476→\n   477→// Atomic float add via CAS loop\n   478→fn atomic_add_f32(slot: u32, val: f32) {\n   479→  var old = atomicLoad(&metrics[slot]);\n   480→  loop {\n   481→    let new_val = bitcast<f32>(old) + val;\n   482→    let result = atomicCompareExchangeWeak(&metrics[slot], old, bitcast<u32>(new_val));\n   483→    if (result.exchanged) { break; }\n   484→    old = result.old_value;\n   485→  }\n   486→}\n   487→\n   488→@compute @workgroup_size(64)\n   489→fn compute_metrics(@builtin(global_invocation_id) id: vec3u) {\n   490→  let i = id.x;\n   491→  if (i >= params.num_boids) { return; }\n   492→\n   493→  let boid = boids_src[i];\n   494→\n   495→  // Cohesion: count boids with >= 5 neighbors\n   496→  if (boid.neighbor_count >= 5.0) {\n   497→    atomicAdd(&metrics[0], 1u);\n   498→  }\n   499→\n   500→  // Neighbor count sum\n   501→  atomic_add_f32(1u, boid.neighbor_count);\n   502→\n   503→  // Velocity correlation (flock_alignment is already dot(my_vel, avg_neighbor_vel))\n   504→  atomic_add_f32(2u, boid.flock_alignment);\n   505→\n   506→  // Position sums for covariance\n   507→  atomic_add_f32(3u, boid.pos.x);\n   508→  atomic_add_f32(4u, boid.pos.y);\n   509→  atomic_add_f32(5u, boid.pos.z);\n   510→  atomic_add_f32(6u, boid.pos.x * boid.pos.x);\n   511→  atomic_add_f32(7u, boid.pos.y * boid.pos.y);\n   512→  atomic_add_f32(8u, boid.pos.z * boid.pos.z);\n   513→\n   514→  // Neighbor count squared for variance\n   515→  atomic_add_f32(9u, boid.neighbor_count * boid.neighbor_count);\n   516→\n   517→  // Total count\n   518→  atomicAdd(&metrics[10], 1u);\n   519→}\n   520→"}]},"parent_tool_use_id":null,"session_id":"9036d8f4-067e-45b6-b2b3-1c0500e3d4cd","uuid":"40283610-3cd1-4a22-b852-dcc861044921","timestamp":"2026-03-24T02:19:52.892Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/aaronlemke/AI/Murmuration/shader.wgsl","content":"// === 3D Murmuration Compute Shader — Topological Neighbor Model ===\n// Based on empirical starling research: birds track their nearest 7 neighbors,\n// not all within a fixed radius. This produces realistic wave propagation,\n// sharp flock edges, and coordinated turns.\n\nstruct SimParams {\n  num_boids: u32,\n  grid_size: u32,\n  grid_cells: u32,\n  world_size: f32,\n  cell_size: f32,\n  visual_range: f32,\n  visual_range_sq: f32,\n  separation_dist: f32,\n  separation_dist_sq: f32,\n  align_factor: f32,\n  cohesion_factor: f32,\n  separation_factor: f32,\n  max_speed: f32,\n  min_speed: f32,\n  dt: f32,\n  turn_factor: f32,\n  smoothing: f32,\n  sim_speed: f32,\n  size_randomness: f32,\n  drag_factor: f32,\n  gradient_id: u32,\n  color_source: u32,\n  sphere_radius: f32,\n  frame_count: u32,\n}\n\nstruct Boid {\n  pos: vec3f,\n  size_factor: f32,\n  vel: vec3f,\n  speed: f32,\n  heading: vec3f,\n  neighbor_count: f32,\n  dir_change: f32,\n  flock_alignment: f32,\n  sep_pressure: f32,\n  density: f32,\n}\n\n@group(0) @binding(0) var<uniform> params: SimParams;\n@group(0) @binding(1) var<storage, read_write> boids_src: array<Boid>;\n@group(0) @binding(2) var<storage, read_write> boids_dst: array<Boid>;\n@group(0) @binding(3) var<storage, read_write> cell_counts: array<atomic<u32>>;\n@group(0) @binding(4) var<storage, read_write> cell_offsets: array<u32>;\n@group(0) @binding(5) var<storage, read_write> boid_cells: array<u32>;\n@group(0) @binding(6) var<storage, read_write> sorted_indices: array<u32>;\n@group(0) @binding(7) var<storage, read_write> scatter_counters: array<atomic<u32>>;\n\nfn get_cell(pos: vec3f) -> vec3u {\n  let half = params.world_size * 0.5;\n  return vec3u(clamp(\n    vec3i(floor((pos + vec3f(half)) / params.cell_size)),\n    vec3i(0),\n    vec3i(i32(params.grid_size) - 1)\n  ));\n}\n\nfn cell_index(c: vec3u) -> u32 {\n  return c.x + c.y * params.grid_size + c.z * params.grid_size * params.grid_size;\n}\n\n@compute @workgroup_size(64)\nfn clear_grid(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.grid_cells) { return; }\n  atomicStore(&cell_counts[i], 0u);\n  atomicStore(&scatter_counters[i], 0u);\n}\n\n@compute @workgroup_size(64)\nfn assign_cells(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.num_boids) { return; }\n  let cell = cell_index(get_cell(boids_src[i].pos));\n  boid_cells[i] = cell;\n  atomicAdd(&cell_counts[cell], 1u);\n}\n\nconst SCAN_WG: u32 = 256u;\nvar<workgroup> scan_sums: array<u32, 256>;\n\n@compute @workgroup_size(256)\nfn prefix_sum(@builtin(local_invocation_id) lid: vec3u) {\n  let tid = lid.x;\n  let chunk = (params.grid_cells + SCAN_WG - 1u) / SCAN_WG;\n  let start = tid * chunk;\n  let end = min(start + chunk, params.grid_cells);\n  var local_total = 0u;\n  for (var i = start; i < end; i++) {\n    let count = atomicLoad(&cell_counts[i]);\n    cell_offsets[i] = local_total;\n    local_total += count;\n  }\n  scan_sums[tid] = local_total;\n  workgroupBarrier();\n  for (var stride = 1u; stride < SCAN_WG; stride *= 2u) {\n    let val = select(0u, scan_sums[tid - stride], tid >= stride);\n    workgroupBarrier();\n    scan_sums[tid] += val;\n    workgroupBarrier();\n  }\n  let prefix = select(0u, scan_sums[tid - 1u], tid > 0u);\n  for (var i = start; i < end; i++) {\n    cell_offsets[i] += prefix;\n  }\n}\n\n@compute @workgroup_size(64)\nfn scatter(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.num_boids) { return; }\n  let cell = boid_cells[i];\n  let local_offset = atomicAdd(&scatter_counters[cell], 1u);\n  sorted_indices[cell_offsets[cell] + local_offset] = i;\n}\n\n// === Topological Neighbor Flocking ===\n// Find the K nearest neighbors (K=7 for alignment/cohesion, closest 1 for avoidance)\n// Uses the spatial hash to find candidates, then keeps only the K closest.\n\nconst K_NEIGHBORS: u32 = 7u;\n\n@compute @workgroup_size(64)\nfn flock(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.num_boids) { return; }\n\n  let boid = boids_src[i];\n  let my_grid = get_cell(boid.pos);\n  let gs = i32(params.grid_size);\n  let mg = vec3i(my_grid);\n\n  // Track K nearest neighbors by distance (insertion sort into small array)\n  // Store squared distances and indices\n  var nearest_d2: array<f32, 7>;   // distances squared\n  var nearest_idx: array<u32, 7>;  // boid indices\n  var n_found = 0u;\n\n  // Initialize with large distances\n  for (var k = 0u; k < K_NEIGHBORS; k++) {\n    nearest_d2[k] = 1e10;\n    nearest_idx[k] = 0u;\n  }\n\n  // Search 3x3x3 neighborhood (27 cells)\n  let lo = max(mg - vec3i(1), vec3i(0));\n  let hi = min(mg + vec3i(1), vec3i(gs - 1));\n\n  var total_candidates = 0u;\n\n  for (var nz = lo.z; nz <= hi.z; nz++) {\n    let zoff = u32(nz) * params.grid_size * params.grid_size;\n    for (var ny = lo.y; ny <= hi.y; ny++) {\n      let yzoff = u32(ny) * params.grid_size + zoff;\n      for (var nx = lo.x; nx <= hi.x; nx++) {\n        let nc = u32(nx) + yzoff;\n        let start = cell_offsets[nc];\n        let end_val = select(cell_offsets[nc + 1u], params.num_boids, nc + 1u >= params.grid_cells);\n        if (start >= end_val) { continue; }\n\n        for (var j = start; j < end_val; j++) {\n          let other_idx = sorted_indices[j];\n          if (other_idx == i) { continue; }\n\n          let other_pos = boids_src[other_idx].pos;\n          let diff = boid.pos - other_pos;\n          let d2 = dot(diff, diff);\n\n          // Pre-filter by visual range before K-nearest sort\n          if (d2 > params.visual_range_sq) { continue; }\n\n          total_candidates++;\n\n          // Insert into sorted K-nearest if closer than current worst\n          if (d2 < nearest_d2[K_NEIGHBORS - 1u]) {\n            // Find insertion position\n            var pos = K_NEIGHBORS - 1u;\n            for (var k = 0u; k < K_NEIGHBORS - 1u; k++) {\n              if (d2 < nearest_d2[k]) {\n                pos = k;\n                break;\n              }\n            }\n            // Shift larger entries down\n            for (var k = K_NEIGHBORS - 1u; k > pos; k--) {\n              nearest_d2[k] = nearest_d2[k - 1u];\n              nearest_idx[k] = nearest_idx[k - 1u];\n            }\n            nearest_d2[pos] = d2;\n            nearest_idx[pos] = other_idx;\n            n_found = min(n_found + 1u, K_NEIGHBORS);\n          }\n        }\n      }\n    }\n  }\n\n  // === Apply flocking rules using topological neighbors ===\n  var new_vel = boid.vel;\n\n  // Avoidance: only the 1 nearest neighbor\n  var sep_force = vec3f(0.0);\n  if (n_found > 0u && nearest_d2[0] < params.separation_dist_sq) {\n    let other_pos = boids_src[nearest_idx[0]].pos;\n    let diff = boid.pos - other_pos;\n    let d2 = nearest_d2[0];\n    sep_force = diff * (1.0 - d2 / params.separation_dist_sq);\n    new_vel += sep_force * params.separation_factor * 2.0; // stronger since only 1 neighbor\n  }\n\n  // Alignment + Cohesion: all K neighbors\n  var ali = vec3f(0.0);\n  var coh = vec3f(0.0);\n  var avg_vel = vec3f(0.0);\n  if (n_found > 0u) {\n    for (var k = 0u; k < min(n_found, K_NEIGHBORS); k++) {\n      let other = boids_src[nearest_idx[k]];\n      ali += other.vel;\n      coh += other.pos;\n    }\n    let nf = f32(min(n_found, K_NEIGHBORS));\n    avg_vel = ali / nf;\n    let avg_pos = coh / nf;\n    new_vel += (avg_vel - boid.vel) * params.align_factor;\n    new_vel += (avg_pos - boid.pos) * params.cohesion_factor;\n  }\n\n  // === Emergent murmuration forces ===\n  // NO roost attractor, NO predator orbit — purely local interactions\n  // The complex sweeping motion emerges from topological neighbor rules\n  // + rare perturbations that cascade through the flock\n\n  // Gentle gravity (creates oblate/flat flock shape)\n  new_vel.y -= 0.03;\n\n  // Rare strong perturbation: only ~3% of birds per frame\n  // This is the primary driver of non-repetitive motion —\n  // a random bird changes direction, neighbors respond via alignment,\n  // creating a wave that sweeps across the entire flock\n  let perturb_hash = fract(sin(f32(i * 7919u + params.frame_count * 104729u)) * 43758.5);\n  if (perturb_hash < 0.07) {\n    let seed = f32(i * 1973u + params.frame_count * 9277u);\n    let kick = vec3f(\n      fract(sin(seed) * 43758.5) - 0.5,\n      fract(sin(seed * 1.3) * 22578.1) - 0.5,\n      fract(sin(seed * 0.7) * 31415.9) - 0.5\n    ) * 3.5;  // strong kick that cascades via topological links\n    new_vel += kick;\n  }\n\n  // Spherical boundary steering\n  let dist_from_center = length(boid.pos);\n  let r = params.sphere_radius;\n  let soft_zone = r * 0.15;\n  if (dist_from_center > r - soft_zone && dist_from_center > 0.001) {\n    let penetration = (dist_from_center - (r - soft_zone)) / soft_zone;\n    let push = -normalize(boid.pos) * params.turn_factor * clamp(penetration, 0.0, 3.0);\n    new_vel += push;\n  }\n\n  // Turn rate limiter (smooth heading changes — creates wave-like motion)\n  let old_speed = length(boid.vel);\n  var old_dir = boid.vel;\n  if (old_speed > 0.001) { old_dir = old_dir / old_speed; }\n  else { old_dir = vec3f(1.0, 0.0, 0.0); }\n  let desired_speed = length(new_vel);\n  var desired_dir = new_vel;\n  if (desired_speed > 0.001) { desired_dir = desired_dir / desired_speed; }\n  else { desired_dir = old_dir; }\n  let final_dir = normalize(mix(old_dir, desired_dir, params.smoothing));\n\n  // Speed with drag\n  let drag_scale = 1.0 / mix(1.0, boid.size_factor, params.drag_factor);\n  var final_speed = mix(old_speed, desired_speed, 0.15);\n  final_speed = clamp(final_speed, params.min_speed * drag_scale, params.max_speed * drag_scale);\n  new_vel = final_dir * final_speed;\n\n  // Direction change metric\n  let dir_change_val = 1.0 - clamp(dot(old_dir, final_dir), -1.0, 1.0);\n  let effective_dt = params.dt;\n\n  // Write outputs\n  boids_dst[i].pos = boid.pos + new_vel * effective_dt;\n  boids_dst[i].vel = new_vel;\n  boids_dst[i].size_factor = boid.size_factor;\n  boids_dst[i].heading = final_dir;\n  boids_dst[i].speed = final_speed;\n  boids_dst[i].neighbor_count = f32(n_found);\n  boids_dst[i].dir_change = dir_change_val;\n  let vel_d2 = dot(boid.vel, boid.vel);\n  let avg_d2 = dot(avg_vel, avg_vel);\n  boids_dst[i].flock_alignment = select(dot(boid.vel, avg_vel) * inverseSqrt(vel_d2 * avg_d2), 0.0, vel_d2 < 0.001 || avg_d2 < 0.001);\n  boids_dst[i].sep_pressure = length(sep_force);\n  boids_dst[i].density = f32(n_found) / f32(K_NEIGHBORS);\n}\n\n// === Classic Radius-Based Flocking (high performance, simpler behavior) ===\n@compute @workgroup_size(64)\nfn flock_radius(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.num_boids) { return; }\n\n  let boid = boids_src[i];\n  let my_grid = get_cell(boid.pos);\n  let gs = i32(params.grid_size);\n  let mg = vec3i(my_grid);\n  let lo = max(mg - vec3i(1), vec3i(0));\n  let hi = min(mg + vec3i(1), vec3i(gs - 1));\n\n  var sep = vec3f(0.0);\n  var ali = vec3f(0.0);\n  var coh = vec3f(0.0);\n  var n_align = 0u;\n\n  // Process own cell first — in dense clusters, avoids searching 26 neighbors\n  let my_ci = cell_index(my_grid);\n  let my_start = cell_offsets[my_ci];\n  let my_end = select(cell_offsets[my_ci + 1u], params.num_boids, my_ci + 1u >= params.grid_cells);\n  if (my_start < my_end) {\n    let cell_end = min(my_end, my_start + 4u);\n    for (var j = my_start; j < cell_end; j++) {\n      let other_idx = sorted_indices[j];\n      if (other_idx == i) { continue; }\n      let other_pos = boids_src[other_idx].pos;\n      let diff = boid.pos - other_pos;\n      let d2 = dot(diff, diff);\n      let in_range = f32(d2 < params.visual_range_sq && d2 > 0.0001);\n      ali += boids_src[other_idx].vel * in_range;\n      coh += other_pos * in_range;\n      n_align += u32(in_range);\n      let in_sep = f32(d2 < params.separation_dist_sq) * in_range;\n      sep += diff * (1.0 - d2 / params.separation_dist_sq) * in_sep;\n    }\n  }\n\n  // Only search 26 neighbor cells if own cell didn't provide enough\n  if (n_align < 2u) {\n    for (var nz = lo.z; nz <= hi.z; nz++) {\n      let zoff = u32(nz) * params.grid_size * params.grid_size;\n      for (var ny = lo.y; ny <= hi.y; ny++) {\n        let yzoff = u32(ny) * params.grid_size + zoff;\n        for (var nx = lo.x; nx <= hi.x; nx++) {\n          let nc = u32(nx) + yzoff;\n          if (nc == my_ci) { continue; } // skip own cell (already processed)\n          let start = cell_offsets[nc];\n          let end_val = select(cell_offsets[nc + 1u], params.num_boids, nc + 1u >= params.grid_cells);\n          if (start >= end_val) { continue; }\n          let cell_end = min(end_val, start + 6u);\n          for (var j = start; j < cell_end; j++) {\n            let other_idx = sorted_indices[j];\n            if (other_idx == i) { continue; }\n            let other_pos = boids_src[other_idx].pos;\n            let diff = boid.pos - other_pos;\n            let d2 = dot(diff, diff);\n            let in_range = f32(d2 < params.visual_range_sq && d2 > 0.0001);\n            ali += boids_src[other_idx].vel * in_range;\n            coh += other_pos * in_range;\n            n_align += u32(in_range);\n            let in_sep = f32(d2 < params.separation_dist_sq) * in_range;\n            sep += diff * (1.0 - d2 / params.separation_dist_sq) * in_sep;\n          }\n          if (n_align >= 2u) { break; }\n        }\n        if (n_align >= 2u) { break; }\n      }\n      if (n_align >= 2u) { break; }\n    }\n  }\n\n  var new_vel = boid.vel;\n  if (n_align > 0u) {\n    let nf = f32(n_align);\n    new_vel += (ali / nf - boid.vel) * params.align_factor;\n    new_vel += (coh / nf - boid.pos) * params.cohesion_factor;\n  }\n  new_vel += sep * params.separation_factor;\n\n  // Spherical boundary (cheap d2 test first, sqrt only for edge boids)\n  let center_d2 = dot(boid.pos, boid.pos);\n  let r = params.sphere_radius;\n  let threshold = r - r * 0.15;\n  if (center_d2 > threshold * threshold) {\n    let inv_dist = inverseSqrt(max(center_d2, 1e-6));\n    let dist = center_d2 * inv_dist;\n    let penetration = (dist - threshold) / (r * 0.15);\n    new_vel -= boid.pos * (inv_dist * params.turn_factor * min(penetration, 3.0));\n  }\n\n  // Speed clamp only — skip smoothing mix to reduce ALU\n  let spd_sq = dot(new_vel, new_vel);\n  let max_spd = params.max_speed;\n  if (spd_sq > max_spd * max_spd) {\n    new_vel *= max_spd * inverseSqrt(spd_sq);\n  } else if (spd_sq < params.min_speed * params.min_speed) {\n    new_vel *= params.min_speed * inverseSqrt(max(spd_sq, 1e-6));\n  }\n\n  // Write minimal fields\n  boids_dst[i].pos = boid.pos + new_vel * params.dt;\n  boids_dst[i].vel = new_vel;\n  boids_dst[i].size_factor = boid.size_factor;\n  boids_dst[i].heading = new_vel * inverseSqrt(max(dot(new_vel, new_vel), 1e-6));\n}\n\n// === Auto-range stats ===\n@group(1) @binding(0) var<storage, read_write> stats: array<atomic<u32>, 2>;\n\nfn get_metric(boid: Boid, source: u32) -> f32 {\n  switch (source) {\n    case 0u: { return dot(normalize(boid.heading + vec3f(0.0001, 0.0, 0.0)), vec3f(0.3, 0.4, 0.3)) + 0.5; }\n    case 1u: { return boid.speed; }\n    case 2u: { return boid.dir_change; }\n    case 3u: { return boid.neighbor_count; }\n    case 4u: { return (boid.pos.y + 50.0) / 100.0; }\n    case 5u: { return length(boid.pos) / 50.0; }\n    case 6u: { return boid.flock_alignment * 0.5 + 0.5; }\n    case 7u: { return boid.sep_pressure; }\n    case 8u: { return boid.density; }\n    case 9u: { return 0.5; }\n    default: { return 0.5; }\n  }\n}\n\n@compute @workgroup_size(64)\nfn clear_stats(@builtin(global_invocation_id) id: vec3u) {\n  if (id.x == 0u) {\n    atomicStore(&stats[0], bitcast<u32>(1e10));\n    atomicStore(&stats[1], 0u);\n  }\n}\n\n@compute @workgroup_size(64)\nfn compute_stats(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.num_boids) { return; }\n  let val = get_metric(boids_src[i], params.color_source);\n  let val_bits = bitcast<u32>(val);\n  atomicMin(&stats[0], val_bits);\n  atomicMax(&stats[1], val_bits);\n}\n\n// === Murmuration Quality Metrics ===\n// Computes behavioral metrics for evaluating murmuration quality.\n// Uses @group(1) @binding(1) for a metrics buffer (separate from auto-range stats).\n// 16 atomic u32 slots, interpreted as f32 via bitcast accumulation.\n\n@group(1) @binding(1) var<storage, read_write> metrics: array<atomic<u32>, 16>;\n\n// Slots:\n// 0: count of boids with >= 5 neighbors (cohesion)\n// 1: sum of neighbor_count (for avg)\n// 2: sum of velocity_correlation (dot products)\n// 3: sum of pos.x\n// 4: sum of pos.y\n// 5: sum of pos.z\n// 6: sum of pos.x^2\n// 7: sum of pos.y^2\n// 8: sum of pos.z^2\n// 9: sum of neighbor_count^2 (for variance)\n// 10: count of boids processed\n\n@compute @workgroup_size(64)\nfn clear_metrics(@builtin(global_invocation_id) id: vec3u) {\n  if (id.x == 0u) {\n    for (var k = 0u; k < 16u; k++) {\n      atomicStore(&metrics[k], 0u);\n    }\n  }\n}\n\n// Atomic float add via CAS loop\nfn atomic_add_f32(slot: u32, val: f32) {\n  var old = atomicLoad(&metrics[slot]);\n  loop {\n    let new_val = bitcast<f32>(old) + val;\n    let result = atomicCompareExchangeWeak(&metrics[slot], old, bitcast<u32>(new_val));\n    if (result.exchanged) { break; }\n    old = result.old_value;\n  }\n}\n\n@compute @workgroup_size(64)\nfn compute_metrics(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.num_boids) { return; }\n\n  let boid = boids_src[i];\n\n  // Cohesion: count boids with >= 5 neighbors\n  if (boid.neighbor_count >= 5.0) {\n    atomicAdd(&metrics[0], 1u);\n  }\n\n  // Neighbor count sum\n  atomic_add_f32(1u, boid.neighbor_count);\n\n  // Velocity correlation (flock_alignment is already dot(my_vel, avg_neighbor_vel))\n  atomic_add_f32(2u, boid.flock_alignment);\n\n  // Position sums for covariance\n  atomic_add_f32(3u, boid.pos.x);\n  atomic_add_f32(4u, boid.pos.y);\n  atomic_add_f32(5u, boid.pos.z);\n  atomic_add_f32(6u, boid.pos.x * boid.pos.x);\n  atomic_add_f32(7u, boid.pos.y * boid.pos.y);\n  atomic_add_f32(8u, boid.pos.z * boid.pos.z);\n\n  // Neighbor count squared for variance\n  atomic_add_f32(9u, boid.neighbor_count * boid.neighbor_count);\n\n  // Total count\n  atomicAdd(&metrics[10], 1u);\n}\n","numLines":520,"startLine":1,"totalLines":520}}}
