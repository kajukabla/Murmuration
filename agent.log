{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Roa6kHRWxjCYoLagyxnvjw","type":"tool_result","content":"The file /Users/aaronlemke/AI/Murmuration/index.html has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"ab277b0e-46f8-4888-a52e-c14b4b8bde67","uuid":"ef0d4ea7-87f9-4ffc-a13b-42a9d65214fe","timestamp":"2026-03-23T19:07:21.788Z","tool_use_result":{"filePath":"/Users/aaronlemke/AI/Murmuration/index.html","oldString":"    maxSpeed: 10.0, minSpeed: 3.0, turnFactor: 0.3, smoothing: 0.10,","newString":"    maxSpeed: 10.0, minSpeed: 3.0, turnFactor: 0.3, smoothing: 0.08,","originalFile":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<title>3D Murmuration</title>\n<style>\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  body { background: #000; overflow: hidden; font-family: system-ui, sans-serif; }\n  canvas { display: block; width: 100vw; height: 100vh; }\n  #hud {\n    position: fixed; top: 12px; left: 16px;\n    color: #aac; font: 14px/1.4 monospace;\n    pointer-events: none; text-shadow: 0 1px 3px #000;\n  }\n  #error {\n    position: fixed; inset: 0; display: flex; align-items: center; justify-content: center;\n    color: #f88; font: 18px/1.6 system-ui; text-align: center; padding: 2em;\n  }\n\n  /* --- Settings panel --- */\n  #panel {\n    position: fixed; top: 12px; right: 16px; width: 280px;\n    z-index: 10; user-select: none;\n  }\n  #panel-toggle {\n    display: block; width: 100%; padding: 8px 14px;\n    background: rgba(20,20,40,0.85); color: #aac; border: 1px solid rgba(100,100,160,0.3);\n    border-radius: 6px; font: 13px/1 system-ui; cursor: pointer; text-align: left;\n    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);\n  }\n  #panel-toggle:hover { background: rgba(30,30,60,0.9); }\n  #panel-toggle::after { content: ' \\u25BC'; float: right; font-size: 10px; }\n  #panel.open #panel-toggle::after { content: ' \\u25B2'; }\n  #panel-body {\n    max-height: 0; overflow: hidden; transition: max-height 0.3s ease;\n    background: rgba(10,10,25,0.88); border: 1px solid rgba(100,100,160,0.25);\n    border-top: none; border-radius: 0 0 6px 6px;\n    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);\n  }\n  #panel.open #panel-body { max-height: 700px; }\n  #panel-inner { padding: 10px 14px 14px; }\n\n  .param-row {\n    display: flex; align-items: center; gap: 6px; margin-bottom: 6px;\n  }\n  .param-row label {\n    flex: 0 0 90px; color: #889; font-size: 11px; text-align: right;\n  }\n  .param-row input[type=range] {\n    flex: 1; height: 4px; accent-color: #668cff;\n  }\n  .param-row .val {\n    flex: 0 0 42px; color: #bbd; font: 11px monospace; text-align: right;\n  }\n\n  .preset-row {\n    display: flex; gap: 6px; margin-bottom: 10px; align-items: center;\n  }\n  .preset-row select {\n    flex: 1; padding: 4px 6px; font-size: 12px;\n    background: rgba(30,30,60,0.9); color: #bbd; border: 1px solid rgba(100,100,160,0.3);\n    border-radius: 4px;\n  }\n  .preset-row button {\n    padding: 4px 8px; font-size: 11px; cursor: pointer;\n    background: rgba(40,40,80,0.8); color: #aac; border: 1px solid rgba(100,100,160,0.3);\n    border-radius: 4px;\n  }\n  .preset-row button:hover { background: rgba(60,60,100,0.9); }\n  .section-label {\n    color: #667; font-size: 10px; text-transform: uppercase; letter-spacing: 1px;\n    margin: 8px 0 4px; padding-bottom: 2px; border-bottom: 1px solid rgba(100,100,160,0.15);\n  }\n</style>\n</head>\n<body>\n<canvas id=\"c\"></canvas>\n<div id=\"hud\"></div>\n\n<div id=\"panel\">\n  <button id=\"panel-toggle\">Settings</button>\n  <div id=\"panel-body\"><div id=\"panel-inner\">\n    <div class=\"section-label\">Presets</div>\n    <div class=\"preset-row\">\n      <select id=\"preset-select\"></select>\n      <button id=\"preset-save\" title=\"Save current as new preset\">Save</button>\n      <button id=\"preset-del\" title=\"Delete selected user preset\">Del</button>\n    </div>\n    <div class=\"section-label\">Visuals</div>\n    <div class=\"param-row\">\n      <label>Gradient</label>\n      <select id=\"gradient-select\" style=\"flex:1; padding:3px 6px; font-size:12px; background:rgba(30,30,60,0.9); color:#bbd; border:1px solid rgba(100,100,160,0.3); border-radius:4px;\">\n        <option value=\"0\">Viridis</option>\n        <option value=\"1\">Inferno</option>\n        <option value=\"2\">Magma</option>\n        <option value=\"3\">Plasma</option>\n        <option value=\"4\">Turbo</option>\n        <option value=\"5\">Cividis</option>\n        <option value=\"6\">Coolwarm</option>\n        <option value=\"7\">Spectral</option>\n        <option value=\"8\">Hot</option>\n        <option value=\"9\">Ocean</option>\n      </select>\n    </div>\n    <div class=\"param-row\">\n      <label>Color Source</label>\n      <select id=\"color-source-select\" style=\"flex:1; padding:3px 6px; font-size:12px; background:rgba(30,30,60,0.9); color:#bbd; border:1px solid rgba(100,100,160,0.3); border-radius:4px;\">\n        <option value=\"0\">Velocity Direction</option>\n        <option value=\"1\">Speed</option>\n        <option value=\"2\">Direction Change</option>\n        <option value=\"3\">Neighbor Count</option>\n        <option value=\"4\">Altitude</option>\n        <option value=\"5\">Distance from Center</option>\n        <option value=\"6\">Flock Alignment</option>\n        <option value=\"7\">Separation Pressure</option>\n        <option value=\"8\">Local Density</option>\n        <option value=\"9\">Boid ID</option>\n      </select>\n    </div>\n    <div class=\"param-row\">\n      <label>Gain</label>\n      <input type=\"range\" id=\"gain-slider\" min=\"0.0\" max=\"1.0\" step=\"0.01\" value=\"0.5\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"gain-val\">0.50</span>\n    </div>\n    <div class=\"param-row\">\n      <label>Auto-Range</label>\n      <label style=\"flex:1; color:#aab; font-size:12px; cursor:pointer;\">\n        <input type=\"checkbox\" id=\"auto-range-cb\" style=\"accent-color:#668cff; margin-right:4px;\">\n        Normalize to data range\n      </label>\n    </div>\n    <div class=\"param-row\">\n      <label>Brightness</label>\n      <input type=\"range\" id=\"brightness-slider\" min=\"0.1\" max=\"5.0\" step=\"0.05\" value=\"1.0\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"brightness-val\">1.00</span>\n    </div>\n    <div class=\"param-row\">\n      <label>Sphere Radius</label>\n      <input type=\"range\" id=\"sphere-radius-slider\" min=\"20\" max=\"300\" step=\"5\" value=\"100\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"sphere-radius-val\">100</span>\n    </div>\n    <div class=\"param-row\">\n      <label>Neighbor Mode</label>\n      <select id=\"neighbor-mode-select\" style=\"flex:1; padding:3px 6px; font-size:12px; background:rgba(30,30,60,0.9); color:#bbd; border:1px solid rgba(100,100,160,0.3); border-radius:4px;\">\n        <option value=\"0\">Topological (K=7 nearest)</option>\n        <option value=\"1\">Radius (classic, fast)</option>\n      </select>\n    </div>\n    <div class=\"section-label\">Rendering</div>\n    <div class=\"param-row\">\n      <label>Render Mode</label>\n      <select id=\"render-mode-select\" style=\"flex:1; padding:3px 6px; font-size:12px; background:rgba(30,30,60,0.9); color:#bbd; border:1px solid rgba(100,100,160,0.3); border-radius:4px;\">\n        <option value=\"0\">Tetrahedron</option>\n        <option value=\"1\">Billboard (Additive)</option>\n        <option value=\"2\">Billboard (Opaque)</option>\n        <option value=\"3\">Reflective Tetrahedron</option>\n        <option value=\"4\">Reflective Billboard</option>\n      </select>\n    </div>\n    <div class=\"param-row\">\n      <label>Falloff</label>\n      <input type=\"range\" id=\"falloff-slider\" min=\"0.1\" max=\"3.0\" step=\"0.05\" value=\"1.0\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"falloff-val\">1.00</span>\n    </div>\n    <div class=\"param-row\">\n      <label>Particle Scale</label>\n      <input type=\"range\" id=\"particle-scale-slider\" min=\"0.05\" max=\"5.0\" step=\"0.05\" value=\"1.0\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"particle-scale-val\">1.00</span>\n    </div>\n    <div class=\"param-row\">\n      <label>Particle Count</label>\n      <input type=\"range\" id=\"particle-count-slider\" min=\"3\" max=\"6.3\" step=\"0.01\" value=\"3.7\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"particle-count-val\">5,000</span>\n    </div>\n    <div class=\"param-row\">\n      <label>Bloom</label>\n      <label style=\"flex:1; color:#aab; font-size:12px; cursor:pointer;\">\n        <input type=\"checkbox\" id=\"bloom-cb\" style=\"accent-color:#668cff; margin-right:4px;\">\n        Enable bloom\n      </label>\n    </div>\n    <div class=\"param-row\">\n      <label>Bloom Thresh</label>\n      <input type=\"range\" id=\"bloom-threshold-slider\" min=\"0.1\" max=\"2.0\" step=\"0.05\" value=\"0.8\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"bloom-threshold-val\">0.80</span>\n    </div>\n    <div class=\"param-row\">\n      <label>Bloom Intensity</label>\n      <input type=\"range\" id=\"bloom-intensity-slider\" min=\"0.0\" max=\"3.0\" step=\"0.05\" value=\"0.5\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"bloom-intensity-val\">0.50</span>\n    </div>\n    <div class=\"section-label\">Physics</div>\n    <div id=\"sliders\"></div>\n  </div></div>\n</div>\n\n<script type=\"module\">\n// Capture errors and post to server for debugging\nwindow.addEventListener('error', e => {\n  fetch('/api/bench_result', { method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ error: e.message, file: e.filename, line: e.lineno }),\n  }).catch(() => {});\n});\nwindow.addEventListener('unhandledrejection', e => {\n  fetch('/api/bench_result', { method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ error: String(e.reason) }),\n  }).catch(() => {});\n});\n\nimport { createSimulation } from './simulation.js';\nimport { createRenderer }   from './renderer.js';\n\n// Benchmark mode: ?boids=N runs a measured benchmark\nconst urlParams = new URLSearchParams(location.search);\nconst benchmarkBoids = urlParams.get('boids') ? parseInt(urlParams.get('boids')) : null;\n\nlet NUM_BOIDS = benchmarkBoids || 40000;\nconst WORLD_SIZE = 100;\n\n// ============================================================\n// Built-in presets\n// ============================================================\nconst BUILTIN_PRESETS = {\n  'Murmuration': {\n    simSpeed: 1.0, sizeRandomness: 0.0, dragFactor: 0.0, sphereRadius: 120,\n    visualRange: 15.0, separationDist: 2.0, alignFactor: 0.12,\n    cohesionFactor: 0.003, separationFactor: 0.08,\n    maxSpeed: 10.0, minSpeed: 3.0, turnFactor: 0.3, smoothing: 0.10,\n  },\n  'Tight Murmuration': {\n    simSpeed: 1.0, sizeRandomness: 0.0, dragFactor: 0.0, sphereRadius: 80,\n    visualRange: 10.0, separationDist: 1.5, alignFactor: 0.15,\n    cohesionFactor: 0.005, separationFactor: 0.12,\n    maxSpeed: 12.0, minSpeed: 5.0, turnFactor: 0.4, smoothing: 0.08,\n  },\n  'Lazy Murmuration': {\n    simSpeed: 1.0, sizeRandomness: 0.0, dragFactor: 0.0, sphereRadius: 150,\n    visualRange: 20.0, separationDist: 3.0, alignFactor: 0.08,\n    cohesionFactor: 0.001, separationFactor: 0.05,\n    maxSpeed: 5.0, minSpeed: 1.5, turnFactor: 0.2, smoothing: 0.15,\n  },\n  'Swarm': {\n    simSpeed: 1.0, sizeRandomness: 0.3, dragFactor: 0.5, sphereRadius: 100,\n    visualRange: 8.0, separationDist: 0.8, alignFactor: 0.01,\n    cohesionFactor: 0.02, separationFactor: 0.3,\n    maxSpeed: 5.0, minSpeed: 0.5, turnFactor: 0.4, smoothing: 0.15,\n  },\n  'Predator Evasion': {\n    simSpeed: 1.0, sizeRandomness: 0.0, dragFactor: 0.0, sphereRadius: 120,\n    visualRange: 12.0, separationDist: 3.0, alignFactor: 0.10,\n    cohesionFactor: 0.003, separationFactor: 0.15,\n    maxSpeed: 14.0, minSpeed: 5.0, turnFactor: 0.5, smoothing: 0.06,\n  },\n};\n\n// Slider definitions: [key, label, min, max, step]\nconst SLIDER_DEFS = [\n  ['simSpeed',        'Sim Speed',     0.1,  10.0,  0.1],\n  ['sizeRandomness',  'Size Random',   0.0,   1.0,  0.05],\n  ['dragFactor',      'Size Drag',     0.0,   1.0,  0.05],\n  ['visualRange',     'Visual Range',  1.0,  10.0,  0.1],\n  ['separationDist',  'Sep. Dist',     0.3,   5.0,  0.1],\n  ['alignFactor',     'Alignment',     0.001, 0.2,  0.001],\n  ['cohesionFactor',  'Cohesion',      0.0005,0.05, 0.0005],\n  ['separationFactor','Separation',    0.05,  2.0,  0.01],\n  ['maxSpeed',        'Max Speed',     1.0,  50.0,  0.5],\n  ['minSpeed',        'Min Speed',     0.1,   5.0,  0.1],\n  ['turnFactor',      'Turn Factor',   0.05,  1.0,  0.05],\n  ['smoothing',       'Turn Rate',     0.01,  0.3,  0.005],\n];\n\n// ============================================================\n// WebGPU init\n// ============================================================\nif (!navigator.gpu) { showError('WebGPU not supported. Use Chrome 113+ or Edge 113+.'); throw ''; }\nconst adapter = await navigator.gpu.requestAdapter();\nif (!adapter) { showError('No WebGPU adapter found.'); throw ''; }\nconst device = await adapter.requestDevice();\n\nconst canvas = document.getElementById('c');\nconst ctx    = canvas.getContext('webgpu');\n\nfunction resize() {\n  const dpr = devicePixelRatio;\n  canvas.width  = Math.floor(innerWidth * dpr);\n  canvas.height = Math.floor(innerHeight * dpr);\n}\nresize();\n\nlet simulation, renderer;\ntry {\n  simulation = await createSimulation(device, { numBoids: NUM_BOIDS, worldSize: WORLD_SIZE });\n  renderer = await createRenderer(device, ctx, simulation);\n} catch(e) {\n  showError('Init failed: ' + e.message);\n  throw e;\n}\naddEventListener('resize', () => { resize(); renderer.resize(); });\n\n// ============================================================\n// Current params state\n// ============================================================\nlet currentParams = { ...BUILTIN_PRESETS['Murmuration'] };\nsimulation.setParams(currentParams);\nsimulation.applySizeRandomness(currentParams.sizeRandomness ?? 0);\n\n// ============================================================\n// UI: Sliders\n// ============================================================\nconst sliderEls = {};\nconst slidersDiv = document.getElementById('sliders');\n\nfor (const [key, label, min, max, step] of SLIDER_DEFS) {\n  const row = document.createElement('div');\n  row.className = 'param-row';\n\n  const lbl = document.createElement('label');\n  lbl.textContent = label;\n\n  const input = document.createElement('input');\n  input.type = 'range';\n  input.min = min; input.max = max; input.step = step;\n  input.value = currentParams[key];\n\n  const val = document.createElement('span');\n  val.className = 'val';\n  val.textContent = fmtVal(currentParams[key], step);\n\n  input.addEventListener('input', () => {\n    const v = parseFloat(input.value);\n    currentParams[key] = v;\n    val.textContent = fmtVal(v, step);\n    simulation.setParams(currentParams);\n    if (key === 'sizeRandomness') simulation.applySizeRandomness(v);\n  });\n\n  row.append(lbl, input, val);\n  slidersDiv.appendChild(row);\n  sliderEls[key] = { input, val, step };\n}\n\nfunction fmtVal(v, step) {\n  const dec = step < 0.01 ? 4 : step < 0.1 ? 3 : step < 1 ? 2 : 1;\n  return v.toFixed(dec);\n}\n\nfunction syncSliders() {\n  for (const [key] of SLIDER_DEFS) {\n    const el = sliderEls[key];\n    el.input.value = currentParams[key];\n    el.val.textContent = fmtVal(currentParams[key], el.step);\n  }\n}\n\n// ============================================================\n// UI: Presets\n// ============================================================\nconst LS_KEY = 'murmuration-user-presets';\nconst presetSelect = document.getElementById('preset-select');\n\nfunction loadUserPresets() {\n  try { return JSON.parse(localStorage.getItem(LS_KEY)) || {}; } catch { return {}; }\n}\nfunction saveUserPresets(obj) {\n  localStorage.setItem(LS_KEY, JSON.stringify(obj));\n}\n\nfunction populatePresetDropdown() {\n  presetSelect.innerHTML = '';\n  // Built-in\n  for (const name of Object.keys(BUILTIN_PRESETS)) {\n    const opt = document.createElement('option');\n    opt.value = name; opt.textContent = name;\n    presetSelect.appendChild(opt);\n  }\n  // User\n  const userPresets = loadUserPresets();\n  const userNames = Object.keys(userPresets);\n  if (userNames.length) {\n    const sep = document.createElement('option');\n    sep.disabled = true; sep.textContent = '--- User Presets ---';\n    presetSelect.appendChild(sep);\n    for (const name of userNames) {\n      const opt = document.createElement('option');\n      opt.value = `user:${name}`; opt.textContent = name;\n      presetSelect.appendChild(opt);\n    }\n  }\n}\n\nfunction applyPreset(name) {\n  let params;\n  if (name.startsWith('user:')) {\n    params = loadUserPresets()[name.slice(5)];\n  } else {\n    params = BUILTIN_PRESETS[name];\n  }\n  if (!params) return;\n  currentParams = { ...params };\n  simulation.setParams(currentParams);\n  simulation.applySizeRandomness(currentParams.sizeRandomness ?? 0);\n  syncSliders();\n}\n\npresetSelect.addEventListener('change', () => applyPreset(presetSelect.value));\n\ndocument.getElementById('preset-save').addEventListener('click', () => {\n  const name = prompt('Preset name:');\n  if (!name || !name.trim()) return;\n  const userPresets = loadUserPresets();\n  userPresets[name.trim()] = { ...currentParams };\n  saveUserPresets(userPresets);\n  populatePresetDropdown();\n  presetSelect.value = `user:${name.trim()}`;\n});\n\ndocument.getElementById('preset-del').addEventListener('click', () => {\n  const sel = presetSelect.value;\n  if (!sel.startsWith('user:')) return; // can't delete built-in\n  const name = sel.slice(5);\n  const userPresets = loadUserPresets();\n  delete userPresets[name];\n  saveUserPresets(userPresets);\n  populatePresetDropdown();\n  presetSelect.value = 'Murmuration';\n  applyPreset('Murmuration');\n});\n\npopulatePresetDropdown();\npresetSelect.value = 'Murmuration';\n\n// Gain slider\nconst gainSlider = document.getElementById('gain-slider');\nconst gainVal = document.getElementById('gain-val');\ncurrentParams.gain = 0.5;\ngainSlider.addEventListener('input', () => {\n  currentParams.gain = parseFloat(gainSlider.value);\n  gainVal.textContent = currentParams.gain.toFixed(2);\n});\n\n// Auto-range checkbox\nconst autoRangeCb = document.getElementById('auto-range-cb');\nautoRangeCb.addEventListener('change', () => {\n  simulation.autoRange = autoRangeCb.checked;\n});\n\n// Brightness slider\nconst brightnessSlider = document.getElementById('brightness-slider');\nconst brightnessVal = document.getElementById('brightness-val');\nlet brightness = 1.0;\nbrightnessSlider.addEventListener('input', () => {\n  brightness = parseFloat(brightnessSlider.value);\n  brightnessVal.textContent = brightness.toFixed(2);\n});\n\n// Sphere radius slider\nconst sphereRadiusSlider = document.getElementById('sphere-radius-slider');\nconst sphereRadiusVal = document.getElementById('sphere-radius-val');\ncurrentParams.sphereRadius = 100;\nsphereRadiusSlider.addEventListener('input', () => {\n  currentParams.sphereRadius = parseFloat(sphereRadiusSlider.value);\n  sphereRadiusVal.textContent = currentParams.sphereRadius.toFixed(0);\n  simulation.setParams(currentParams);\n});\n\n// Particle scale slider\nconst particleScaleSlider = document.getElementById('particle-scale-slider');\nconst particleScaleVal = document.getElementById('particle-scale-val');\nlet particleScale = 1.0;\nparticleScaleSlider.addEventListener('input', () => {\n  particleScale = parseFloat(particleScaleSlider.value);\n  particleScaleVal.textContent = particleScale.toFixed(2);\n});\n\n// Neighbor mode\nconst neighborModeSelect = document.getElementById('neighbor-mode-select');\nlet neighborMode = 0;\nneighborModeSelect.addEventListener('change', () => {\n  neighborMode = parseInt(neighborModeSelect.value);\n});\n\n// Rendering controls\nconst renderModeSelect = document.getElementById('render-mode-select');\nconst falloffSlider = document.getElementById('falloff-slider');\nconst falloffVal = document.getElementById('falloff-val');\nconst particleCountSlider = document.getElementById('particle-count-slider');\nconst particleCountVal = document.getElementById('particle-count-val');\nconst bloomCb = document.getElementById('bloom-cb');\nconst bloomThreshSlider = document.getElementById('bloom-threshold-slider');\nconst bloomThreshVal = document.getElementById('bloom-threshold-val');\nconst bloomIntensitySlider = document.getElementById('bloom-intensity-slider');\nconst bloomIntensityVal = document.getElementById('bloom-intensity-val');\n\nlet renderMode = 0;\nlet falloff = 1.0;\nlet bloomEnabled = false;\nlet bloomThreshold = 0.8;\nlet bloomIntensity = 0.5;\n\nrenderModeSelect.addEventListener('change', () => { renderMode = parseInt(renderModeSelect.value); });\nfalloffSlider.addEventListener('input', () => {\n  falloff = parseFloat(falloffSlider.value);\n  falloffVal.textContent = falloff.toFixed(2);\n});\n\n// Particle count (logarithmic slider: 10^3 to 10^6.3)\nlet particleCountTimeout = null;\nparticleCountSlider.value = Math.log10(NUM_BOIDS);\nparticleCountVal.textContent = NUM_BOIDS.toLocaleString();\nparticleCountSlider.addEventListener('input', () => {\n  const count = Math.round(Math.pow(10, parseFloat(particleCountSlider.value)));\n  particleCountVal.textContent = count.toLocaleString();\n  clearTimeout(particleCountTimeout);\n  particleCountTimeout = setTimeout(async () => {\n    NUM_BOIDS = count;\n    simulation = await createSimulation(device, { numBoids: count, worldSize: WORLD_SIZE });\n    simulation.setParams(currentParams);\n    simulation.applySizeRandomness(currentParams.sizeRandomness ?? 0);\n    simulation.autoRange = autoRangeCb.checked;\n    renderer.rebindSimulation(simulation);\n  }, 500);\n});\n\nbloomCb.addEventListener('change', () => { bloomEnabled = bloomCb.checked; });\nbloomThreshSlider.addEventListener('input', () => {\n  bloomThreshold = parseFloat(bloomThreshSlider.value);\n  bloomThreshVal.textContent = bloomThreshold.toFixed(2);\n});\nbloomIntensitySlider.addEventListener('input', () => {\n  bloomIntensity = parseFloat(bloomIntensitySlider.value);\n  bloomIntensityVal.textContent = bloomIntensity.toFixed(2);\n});\n\n// Gradient + Color Source dropdowns\nconst gradientSelect = document.getElementById('gradient-select');\nconst colorSourceSelect = document.getElementById('color-source-select');\ncurrentParams.gradientId = 0;\ncurrentParams.colorSource = 0;\n\ngradientSelect.addEventListener('change', () => {\n  currentParams.gradientId = parseInt(gradientSelect.value);\n  simulation.setParams(currentParams);\n});\ncolorSourceSelect.addEventListener('change', () => {\n  currentParams.colorSource = parseInt(colorSourceSelect.value);\n  simulation.setParams(currentParams);\n});\n\n// Panel toggle\nconst panel = document.getElementById('panel');\ndocument.getElementById('panel-toggle').addEventListener('click', () => {\n  panel.classList.toggle('open');\n});\n\n// ============================================================\n// Orbit camera\n// ============================================================\nlet azimuth   = 0.5;\nlet elevation = 0.35;\nlet distance  = 140;\n\ncanvas.addEventListener('pointerdown', (e) => {\n  canvas.setPointerCapture(e.pointerId);\n  let lastX = e.clientX, lastY = e.clientY;\n  const move = (ev) => {\n    azimuth   -= (ev.clientX - lastX) * 0.005;\n    elevation  = Math.max(-1.5, Math.min(1.5, elevation + (ev.clientY - lastY) * 0.005));\n    lastX = ev.clientX; lastY = ev.clientY;\n  };\n  const up = () => { canvas.removeEventListener('pointermove', move); canvas.removeEventListener('pointerup', up); };\n  canvas.addEventListener('pointermove', move);\n  canvas.addEventListener('pointerup', up);\n});\ncanvas.addEventListener('wheel', (e) => {\n  distance = Math.max(20, Math.min(400, distance * (1 + e.deltaY * 0.001)));\n  e.preventDefault();\n}, { passive: false });\n\n// ============================================================\n// Matrix helpers\n// ============================================================\nfunction perspective(fov, aspect, near, far) {\n  const f = 1 / Math.tan(fov / 2);\n  const nf = 1 / (near - far);\n  return new Float32Array([\n    f / aspect, 0, 0, 0,\n    0, f, 0, 0,\n    0, 0, (far + near) * nf, -1,\n    0, 0, 2 * far * near * nf, 0,\n  ]);\n}\n\nfunction lookAt(eye, target, up) {\n  const zx = eye[0]-target[0], zy = eye[1]-target[1], zz = eye[2]-target[2];\n  let len = 1 / Math.hypot(zx, zy, zz);\n  const z0=zx*len, z1=zy*len, z2=zz*len;\n  const x0 = up[1]*z2 - up[2]*z1, x1 = up[2]*z0 - up[0]*z2, x2 = up[0]*z1 - up[1]*z0;\n  len = Math.hypot(x0,x1,x2); const rl = len ? 1/len : 0;\n  const r0=x0*rl, r1=x1*rl, r2=x2*rl;\n  const u0=z1*r2-z2*r1, u1=z2*r0-z0*r2, u2=z0*r1-z1*r0;\n  return new Float32Array([\n    r0, u0, z0, 0,\n    r1, u1, z1, 0,\n    r2, u2, z2, 0,\n    -(r0*eye[0]+r1*eye[1]+r2*eye[2]),\n    -(u0*eye[0]+u1*eye[1]+u2*eye[2]),\n    -(z0*eye[0]+z1*eye[1]+z2*eye[2]),\n    1,\n  ]);\n}\n\nfunction mat4Mul(a, b) {\n  const o = new Float32Array(16);\n  for (let i = 0; i < 4; i++)\n    for (let j = 0; j < 4; j++)\n      o[j*4+i] = a[i]*b[j*4] + a[4+i]*b[j*4+1] + a[8+i]*b[j*4+2] + a[12+i]*b[j*4+3];\n  return o;\n}\n\n// ============================================================\n// FPS + Main loop + Benchmark reporting\n// ============================================================\nconst frameTimes = [];\nlet lastTime = performance.now();\nconst hud = document.getElementById('hud');\nlet benchFrame = 0, benchDone = false;\n\nfunction frame() {\n  const now = performance.now();\n  const dt = now - lastTime;\n  lastTime = now;\n  benchFrame++;\n  if (benchFrame > 30) frameTimes.push(dt);\n  if (frameTimes.length > 200) frameTimes.shift();\n\n  const display = frameTimes.length ? frameTimes : [16.6];\n  const avgMs = display.reduce((a,b) => a+b, 0) / display.length;\n  hud.textContent = `${NUM_BOIDS.toLocaleString()} boids | ${(1000/avgMs).toFixed(0)} fps | ${avgMs.toFixed(1)} ms`;\n\n  if (benchmarkBoids && frameTimes.length >= 120 && !benchDone) {\n    benchDone = true;\n    const sorted = [...frameTimes].sort((a,b) => a - b);\n    const avg = sorted.reduce((a,b) => a+b, 0) / sorted.length;\n    const p99 = sorted[Math.floor(sorted.length * 0.99)];\n    fetch('/api/bench_result', { method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ num_boids: NUM_BOIDS, frames: sorted.length,\n        avg_ms: +avg.toFixed(2), p99_ms: +p99.toFixed(2),\n        min_ms: +sorted[0].toFixed(2), max_ms: +sorted[sorted.length-1].toFixed(2) }),\n    }).catch(() => {});\n    hud.textContent += ' | BENCHMARK COMPLETE';\n  }\n\n\n\n  const eye = [\n    distance * Math.cos(elevation) * Math.sin(azimuth),\n    distance * Math.sin(elevation),\n    distance * Math.cos(elevation) * Math.cos(azimuth),\n  ];\n  const aspect = canvas.width / canvas.height;\n  const proj = perspective(Math.PI / 3, aspect, 1.0, 600);\n  const view = lookAt(eye, [0,0,0], [0,1,0]);\n  const vp = mat4Mul(proj, view);\n\n  const encoder = device.createCommandEncoder();\n  const simSteps = Math.max(1, Math.round(currentParams.simSpeed ?? 1));\n  for (let s = 0; s < simSteps; s++) {\n    simulation.update(encoder, s === simSteps - 1, neighborMode);\n  }\n  const ar = autoRangeCb.checked;\n  renderer.render(encoder, vp, {\n    gradientId: currentParams.gradientId ?? 0,\n    colorSource: currentParams.colorSource ?? 0,\n    gain: currentParams.gain ?? 0.5,\n    autoRange: ar, autoMin: simulation.autoMin, autoMax: simulation.autoMax,\n    falloff, brightness, particleScale, sphereRadius: currentParams.sphereRadius ?? 100,\n    renderMode, cameraPos: eye, bloomEnabled, bloomThreshold, bloomIntensity,\n    numBoids: NUM_BOIDS, sim: simulation,\n  });\n  device.queue.submit([encoder.finish()]);\n  if (ar) simulation.readStats();\n\n  requestAnimationFrame(frame);\n}\nrequestAnimationFrame(frame);\n\nfunction showError(msg) {\n  document.getElementById('hud').remove();\n  const d = document.createElement('div'); d.id = 'error'; d.textContent = msg;\n  document.body.appendChild(d);\n}\n</script>\n</body>\n</html>\n","structuredPatch":[{"oldStart":227,"oldLines":7,"newStart":227,"newLines":7,"lines":["     simSpeed: 1.0, sizeRandomness: 0.0, dragFactor: 0.0, sphereRadius: 120,","     visualRange: 15.0, separationDist: 2.0, alignFactor: 0.12,","     cohesionFactor: 0.003, separationFactor: 0.08,","-    maxSpeed: 10.0, minSpeed: 3.0, turnFactor: 0.3, smoothing: 0.10,","+    maxSpeed: 10.0, minSpeed: 3.0, turnFactor: 0.3, smoothing: 0.08,","   },","   'Tight Murmuration': {","     simSpeed: 1.0, sizeRandomness: 0.0, dragFactor: 0.0, sphereRadius: 80,"]}],"userModified":false,"replaceAll":false}}
