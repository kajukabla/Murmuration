ton>\n    87→      <button id=\"preset-del\" title=\"Delete selected user preset\">Del</button>\n    88→    </div>\n    89→    <div class=\"section-label\">Visuals</div>\n    90→    <div class=\"param-row\">\n    91→      <label>Gradient</label>\n    92→      <select id=\"gradient-select\" style=\"flex:1; padding:3px 6px; font-size:12px; background:rgba(30,30,60,0.9); color:#bbd; border:1px solid rgba(100,100,160,0.3); border-radius:4px;\">\n    93→        <option value=\"0\">Viridis</option>\n    94→        <option value=\"1\">Inferno</option>\n    95→        <option value=\"2\">Magma</option>\n    96→        <option value=\"3\">Plasma</option>\n    97→        <option value=\"4\">Turbo</option>\n    98→        <option value=\"5\">Cividis</option>\n    99→        <option value=\"6\">Coolwarm</option>\n   100→        <option value=\"7\">Spectral</option>\n   101→        <option value=\"8\">Hot</option>\n   102→        <option value=\"9\">Ocean</option>\n   103→      </select>\n   104→    </div>\n   105→    <div class=\"param-row\">\n   106→      <label>Color Source</label>\n   107→      <select id=\"color-source-select\" style=\"flex:1; padding:3px 6px; font-size:12px; background:rgba(30,30,60,0.9); color:#bbd; border:1px solid rgba(100,100,160,0.3); border-radius:4px;\">\n   108→        <option value=\"0\">Velocity Direction</option>\n   109→        <option value=\"1\">Speed</option>\n   110→        <option value=\"2\">Direction Change</option>\n   111→        <option value=\"3\">Neighbor Count</option>\n   112→        <option value=\"4\">Altitude</option>\n   113→        <option value=\"5\">Distance from Center</option>\n   114→        <option value=\"6\">Flock Alignment</option>\n   115→        <option value=\"7\">Separation Pressure</option>\n   116→        <option value=\"8\">Local Density</option>\n   117→        <option value=\"9\">Boid ID</option>\n   118→      </select>\n   119→    </div>\n   120→    <div class=\"param-row\">\n   121→      <label>Gain</label>\n   122→      <input type=\"range\" id=\"gain-slider\" min=\"0.0\" max=\"1.0\" step=\"0.01\" value=\"0.5\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n   123→      <span class=\"val\" id=\"gain-val\">0.50</span>\n   124→    </div>\n   125→    <div class=\"param-row\">\n   126→      <label>Auto-Range</label>\n   127→      <label style=\"flex:1; color:#aab; font-size:12px; cursor:pointer;\">\n   128→        <input type=\"checkbox\" id=\"auto-range-cb\" style=\"accent-color:#668cff; margin-right:4px;\">\n   129→        Normalize to data range\n   130→      </label>\n   131→    </div>\n   132→    <div class=\"param-row\">\n   133→      <label>Brightness</label>\n   134→      <input type=\"range\" id=\"brightness-slider\" min=\"0.1\" max=\"5.0\" step=\"0.05\" value=\"1.0\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n   135→      <span class=\"val\" id=\"brightness-val\">1.00</span>\n   136→    </div>\n   137→    <div class=\"param-row\">\n   138→      <label>Sphere Radius</label>\n   139→      <input type=\"range\" id=\"sphere-radius-slider\" min=\"20\" max=\"300\" step=\"5\" value=\"100\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n   140→      <span class=\"val\" id=\"sphere-radius-val\">100</span>\n   141→    </div>\n   142→    <div class=\"section-label\">Rendering</div>\n   143→    <div class=\"param-row\">\n   144→      <label>Render Mode</label>\n   145→      <select id=\"render-mode-select\" style=\"flex:1; padding:3px 6px; font-size:12px; background:rgba(30,30,60,0.9); color:#bbd; border:1px solid rgba(100,100,160,0.3); border-radius:4px;\">\n   146→        <option value=\"0\">Tetrahedron</option>\n   147→        <option value=\"1\">Billboard (Additive)</option>\n   148→        <option value=\"2\">Billboard (Opaque)</option>\n   149→        <option value=\"3\">Reflective Tetrahedron</option>\n   150→        <option value=\"4\">Reflective Billboard</option>\n   151→      </select>\n   152→    </div>\n   153→    <div class=\"param-row\">\n   154→      <label>Falloff</label>\n   155→      <input type=\"range\" id=\"falloff-slider\" min=\"0.1\" max=\"3.0\" step=\"0.05\" value=\"1.0\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n   156→      <span class=\"val\" id=\"falloff-val\">1.00</span>\n   157→    </div>\n   158→    <div class=\"param-row\">\n   159→      <label>Particle Scale</label>\n   160→      <input type=\"range\" id=\"particle-scale-slider\" min=\"0.05\" max=\"5.0\" step=\"0.05\" value=\"1.0\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n   161→      <span class=\"val\" id=\"particle-scale-val\">1.00</span>\n   162→    </div>\n   163→    <div class=\"param-row\">\n   164→      <label>Particle Count</label>\n   165→      <input type=\"range\" id=\"particle-count-slider\" min=\"3\" max=\"6.3\" step=\"0.01\" value=\"3.7\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n   166→      <span class=\"val\" id=\"particle-count-val\">5,000</span>\n   167→    </div>\n   168→    <div class=\"param-row\">\n   169→      <label>Bloom</label>\n   170→      <label style=\"flex:1; color:#aab; font-size:12px; cursor:pointer;\">\n   171→        <input type=\"checkbox\" id=\"bloom-cb\" style=\"accent-color:#668cff; margin-right:4px;\">\n   172→        Enable bloom\n   173→      </label>\n   174→    </div>\n   175→    <div class=\"param-row\">\n   176→      <label>Bloom Thresh</label>\n   177→      <input type=\"range\" id=\"bloom-threshold-slider\" min=\"0.1\" max=\"2.0\" step=\"0.05\" value=\"0.8\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n   178→      <span class=\"val\" id=\"bloom-threshold-val\">0.80</span>\n   179→    </div>\n   180→    <div class=\"param-row\">\n   181→      <label>Bloom Intensity</label>\n   182→      <input type=\"range\" id=\"bloom-intensity-slider\" min=\"0.0\" max=\"3.0\" step=\"0.05\" value=\"0.5\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n   183→      <span class=\"val\" id=\"bloom-intensity-val\">0.50</span>\n   184→    </div>\n   185→    <div class=\"section-label\">Physics</div>\n   186→    <div id=\"sliders\"></div>\n   187→  </div></div>\n   188→</div>\n   189→\n   190→<script type=\"module\">\n   191→// Capture errors and post to server for debugging\n   192→window.addEventListener('error', e => {\n   193→  fetch('/api/bench_result', { method: 'POST',\n   194→    headers: { 'Content-Type': 'application/json' },\n   195→    body: JSON.stringify({ error: e.message, file: e.filename, line: e.lineno }),\n   196→  }).catch(() => {});\n   197→});\n   198→window.addEventListener('unhandledrejection', e => {\n   199→  fetch('/api/bench_result', { method: 'POST',\n   200→    headers: { 'Content-Type': 'application/json' },\n   201→    body: JSON.stringify({ error: String(e.reason) }),\n   202→  }).catch(() => {});\n   203→});\n   204→\n   205→import { createSimulation } from './simulation.js';\n   206→import { createRenderer }   from './renderer.js';\n   207→\n   208→// Benchmark mode: ?boids=N runs a measured benchmark\n   209→const urlParams = new URLSearchParams(location.search);\n   210→const benchmarkBoids = urlParams.get('boids') ? parseInt(urlParams.get('boids')) : null;\n   211→\n   212→let NUM_BOIDS = benchmarkBoids || 20000;\n   213→const WORLD_SIZE = 100;\n   214→\n   215→// ============================================================\n   216→// Built-in presets\n   217→// ============================================================\n   218→const BUILTIN_PRESETS = {\n   219→  'Murmuration': {\n   220→    simSpeed: 1.0, sizeRandomness: 0.0, dragFactor: 0.0, sphereRadius: 120,\n   221→    visualRange: 15.0, separationDist: 2.0, alignFactor: 0.12,\n   222→    cohesionFactor: 0.005, separationFactor: 0.08,\n   223→    maxSpeed: 10.0, minSpeed: 3.0, turnFactor: 0.3, smoothing: 0.10,\n   224→  },\n   225→  'Tight Murmuration': {\n   226→    simSpeed: 1.0, sizeRandomness: 0.0, dragFactor: 0.0, sphereRadius: 80,\n   227→    visualRange: 10.0, separationDist: 1.5, alignFactor: 0.15,\n   228→    cohesionFactor: 0.005, separationFactor: 0.12,\n   229→    maxSpeed: 12.0, minSpeed: 5.0, turnFactor: 0.4, smoothing: 0.08,\n   230→  },\n   231→  'Lazy Murmuration': {\n   232→    simSpeed: 1.0, sizeRandomness: 0.0, dragFactor: 0.0, sphereRadius: 150,\n   233→    visualRange: 20.0, separationDist: 3.0, alignFactor: 0.08,\n   234→    cohesionFactor: 0.001, separationFactor: 0.05,\n   235→    maxSpeed: 5.0, minSpeed: 1.5, turnFactor: 0.2, smoothing: 0.15,\n   236→  },\n   237→  'Swarm': {\n   238→    simSpeed: 1.0, sizeRandomness: 0.3, dragFactor: 0.5, sphereRadius: 100,\n   239→    visualRange: 8.0, separationDist: 0.8, alignFactor: 0.01,\n   240→    cohesionFactor: 0.02, separationFactor: 0.3,\n   241→    maxSpeed: 5.0, minSpeed: 0.5, turnFactor: 0.4, smoothing: 0.15,\n   242→  },\n   243→  'Predator Evasion': {\n   244→    simSpeed: 1.0, sizeRandomness: 0.0, dragFactor: 0.0, sphereRadius: 120,\n   245→    visualRange: 12.0, separationDist: 3.0, alignFactor: 0.10,\n   246→    cohesionFactor: 0.003, separationFactor: 0.15,\n   247→    maxSpeed: 14.0, minSpeed: 5.0, turnFactor: 0.5, smoothing: 0.06,\n   248→  },\n   249→};\n   250→\n   251→// Slider definitions: [key, label, min, max, step]\n   252→const SLIDER_DEFS = [\n   253→  ['simSpeed',        'Sim Speed',     0.1,  10.0,  0.1],\n   254→  ['sizeRandomness',  'Size Random',   0.0,   1.0,  0.05],\n   255→  ['dragFactor',      'Size Drag',     0.0,   1.0,  0.05],\n   256→  ['visualRange',     'Visual Range',  1.0,  10.0,  0.1],\n   257→  ['separationDist',  'Sep. Dist',     0.3,   5.0,  0.1],\n   258→  ['alignFactor',     'Alignment',     0.001, 0.2,  0.001],\n   259→  ['cohesionFactor',  'Cohesion',      0.0005,0.05, 0.0005],\n   260→  ['separationFactor','Separation',    0.05,  2.0,  0.01],\n   261→  ['maxSpeed',        'Max Speed',     1.0,  50.0,  0.5],\n   262→  ['minSpeed',        'Min Speed',     0.1,   5.0,  0.1],\n   263→  ['turnFactor',      'Turn Factor',   0.05,  1.0,  0.05],\n   264→  ['smoothing',       'Turn Rate',     0.01,  0.3,  0.005],\n   265→];\n   266→\n   267→// ============================================================\n   268→// WebGPU init\n   269→// ============================================================\n   270→if (!navigator.gpu) { showError('WebGPU not supported. Use Chrome 113+ or Edge 113+.'); throw ''; }\n   271→const adapter = await navigator.gpu.requestAdapter();\n   272→if (!adapter) { showError('No WebGPU adapter found.'); throw ''; }\n   273→const device = await adapter.requestDevice();\n   274→\n   275→const canvas = document.getElementById('c');\n   276→const ctx    = canvas.getContext('webgpu');\n   277→\n   278→function resize() {\n   279→  const dpr = devicePixelRatio;\n   280→  canvas.width  = Math.floor(innerWidth * dpr);\n   281→  canvas.height = Math.floor(innerHeight * dpr);\n   282→}\n   283→resize();\n   284→\n   285→let simulation, renderer;\n   286→try {\n   287→  simulation = await createSimulation(device, { numBoids: NUM_BOIDS, worldSize: WORLD_SIZE });\n   288→  renderer = await createRenderer(device, ctx, simulation);\n   289→} catch(e) {\n   290→  showError('Init failed: ' + e.message);\n   291→  throw e;\n   292→}\n   293→addEventListener('resize', () => { resize(); renderer.resize(); });\n   294→\n   295→// ============================================================\n   296→// Current params state\n   297→// ============================================================\n   298→let currentParams = { ...BUILTIN_PRESETS['Murmuration'] };\n   299→simulation.setParams(currentParams);\n   300→simulation.applySizeRandomness(currentParams.sizeRandomness ?? 0);\n   301→\n   302→// ============================================================\n   303→// UI: Sliders\n   304→// ============================================================\n   305→const sliderEls = {};\n   306→const slidersDiv = document.getElementById('sliders');\n   307→\n   308→for (const [key, label, min, max, step] of SLIDER_DEFS) {\n   309→  const row = document.createElement('div');\n   310→  row.className = 'param-row';\n   311→\n   312→  const lbl = document.createElement('label');\n   313→  lbl.textContent = label;\n   314→\n   315→  const input = document.createElement('input');\n   316→  input.type = 'range';\n   317→  input.min = min; input.max = max; input.step = step;\n   318→  input.value = currentParams[key];\n   319→\n   320→  const val = document.createElement('span');\n   321→  val.className = 'val';\n   322→  val.textContent = fmtVal(currentParams[key], step);\n   323→\n   324→  input.addEventListener('input', () => {\n   325→    const v = parseFloat(input.value);\n   326→    currentParams[key] = v;\n   327→    val.textContent = fmtVal(v, step);\n   328→    simulation.setParams(currentParams);\n   329→    if (key === 'sizeRandomness') simulation.applySizeRandomness(v);\n   330→  });\n   331→\n   332→  row.append(lbl, input, val);\n   333→  slidersDiv.appendChild(row);\n   334→  sliderEls[key] = { input, val, step };\n   335→}\n   336→\n   337→function fmtVal(v, step) {\n   338→  const dec = step < 0.01 ? 4 : step < 0.1 ? 3 : step < 1 ? 2 : 1;\n   339→  return v.toFixed(dec);\n   340→}\n   341→\n   342→function syncSliders() {\n   343→  for (const [key] of SLIDER_DEFS) {\n   344→    const el = sliderEls[key];\n   345→    el.input.value = currentParams[key];\n   346→    el.val.textContent = fmtVal(currentParams[key], el.step);\n   347→  }\n   348→}\n   349→\n   350→// ============================================================\n   351→// UI: Presets\n   352→// ============================================================\n   353→const LS_KEY = 'murmuration-user-presets';\n   354→const presetSelect = document.getElementById('preset-select');\n   355→\n   356→function loadUserPresets() {\n   357→  try { return JSON.parse(localStorage.getItem(LS_KEY)) || {}; } catch { return {}; }\n   358→}\n   359→function saveUserPresets(obj) {\n   360→  localStorage.setItem(LS_KEY, JSON.stringify(obj));\n   361→}\n   362→\n   363→function populatePresetDropdown() {\n   364→  presetSelect.innerHTML = '';\n   365→  // Built-in\n   366→  for (const name of Object.keys(BUILTIN_PRESETS)) {\n   367→    const opt = document.createElement('option');\n   368→    opt.value = name; opt.textContent = name;\n   369→    presetSelect.appendChild(opt);\n   370→  }\n   371→  // User\n   372→  const userPresets = loadUserPresets();\n   373→  const userNames = Object.keys(userPresets);\n   374→  if (userNames.length) {\n   375→    const sep = document.createElement('option');\n   376→    sep.disabled = true; sep.textContent = '--- User Presets ---';\n   377→    presetSelect.appendChild(sep);\n   378→    for (const name of userNames) {\n   379→      const opt = document.createElement('option');\n   380→      opt.value = `user:${name}`; opt.textContent = name;\n   381→      presetSelect.appendChild(opt);\n   382→    }\n   383→  }\n   384→}\n   385→\n   386→function applyPreset(name) {\n   387→  let params;\n   388→  if (name.startsWith('user:')) {\n   389→    params = loadUserPresets()[name.slice(5)];\n   390→  } else {\n   391→    params = BUILTIN_PRESETS[name];\n   392→  }\n   393→  if (!params) return;\n   394→  currentParams = { ...params };\n   395→  simulation.setParams(currentParams);\n   396→  simulation.applySizeRandomness(currentParams.sizeRandomness ?? 0);\n   397→  syncSliders();\n   398→}\n   399→\n   400→presetSelect.addEventListener('change', () => applyPreset(presetSelect.value));\n   401→\n   402→document.getElementById('preset-save').addEventListener('click', () => {\n   403→  const name = prompt('Preset name:');\n   404→  if (!name || !name.trim()) return;\n   405→  const userPresets = loadUserPresets();\n   406→  userPresets[name.trim()] = { ...currentParams };\n   407→  saveUserPresets(userPresets);\n   408→  populatePresetDropdown();\n   409→  presetSelect.value = `user:${name.trim()}`;\n   410→});\n   411→\n   412→document.getElementById('preset-del').addEventListener('click', () => {\n   413→  const sel = presetSelect.value;\n   414→  if (!sel.startsWith('user:')) return; // can't delete built-in\n   415→  const name = sel.slice(5);\n   416→  const userPresets = loadUserPresets();\n   417→  delete userPresets[name];\n   418→  saveUserPresets(userPresets);\n   419→  populatePresetDropdown();\n   420→  presetSelect.value = 'Murmuration';\n   421→  applyPreset('Murmuration');\n   422→});\n   423→\n   424→populatePresetDropdown();\n   425→presetSelect.value = 'Murmuration';\n   426→\n   427→// Gain slider\n   428→const gainSlider = document.getElementById('gain-slider');\n   429→const gainVal = document.getElementById('gain-val');\n   430→currentParams.gain = 0.5;\n   431→gainSlider.addEventListener('input', () => {\n   432→  currentParams.gain = parseFloat(gainSlider.value);\n   433→  gainVal.textContent = currentParams.gain.toFixed(2);\n   434→});\n   435→\n   436→// Auto-range checkbox\n   437→const autoRangeCb = document.getElementById('auto-range-cb');\n   438→autoRangeCb.addEventListener('change', () => {\n   439→  simulation.autoRange = autoRangeCb.checked;\n   440→});\n   441→\n   442→// Brightness slider\n   443→const brightnessSlider = document.getElementById('brightness-slider');\n   444→const brightnessVal = document.getElementById('brightness-val');\n   445→let brightness = 1.0;\n   446→brightnessSlider.addEventListener('input', () => {\n   447→  brightness = parseFloat(brightnessSlider.value);\n   448→  brightnessVal.textContent = brightness.toFixed(2);\n   449→});\n   450→\n   451→// Sphere radius slider\n   452→const sphereRadiusSlider = document.getElementById('sphere-radius-slider');\n   453→const sphereRadiusVal = document.getElementById('sphere-radius-val');\n   454→currentParams.sphereRadius = 100;\n   455→sphereRadiusSlider.addEventListener('input', () => {\n   456→  currentParams.sphereRadius = parseFloat(sphereRadiusSlider.value);\n   457→  sphereRadiusVal.textContent = currentParams.sphereRadius.toFixed(0);\n   458→  simulation.setParams(currentParams);\n   459→});\n   460→\n   461→// Particle scale slider\n   462→const particleScaleSlider = document.getElementById('particle-scale-slider');\n   463→const particleScaleVal = document.getElementById('particle-scale-val');\n   464→let particleScale = 1.0;\n   465→particleScaleSlider.addEventListener('input', () => {\n   466→  particleScale = parseFloat(particleScaleSlider.value);\n   467→  particleScaleVal.textContent = particleScale.toFixed(2);\n   468→});\n   469→\n   470→// Rendering controls\n   471→const renderModeSelect = document.getElementById('render-mode-select');\n   472→const falloffSlider = document.getElementById('falloff-slider');\n   473→const falloffVal = document.getElementById('falloff-val');\n   474→const particleCountSlider = document.getElementById('particle-count-slider');\n   475→const particleCountVal = document.getElementById('particle-count-val');\n   476→const bloomCb = document.getElementById('bloom-cb');\n   477→const bloomThreshSlider = document.getElementById('bloom-threshold-slider');\n   478→const bloomThreshVal = document.getElementById('bloom-threshold-val');\n   479→const bloomIntensitySlider = document.getElementById('bloom-intensity-slider');\n   480→const bloomIntensityVal = document.getElementById('bloom-intensity-val');\n   481→\n   482→let renderMode = 0;\n   483→let falloff = 1.0;\n   484→let bloomEnabled = false;\n   485→let bloomThreshold = 0.8;\n   486→let bloomIntensity = 0.5;\n   487→\n   488→renderModeSelect.addEventListener('change', () => { renderMode = parseInt(renderModeSelect.value); });\n   489→falloffSlider.addEventListener('input', () => {\n   490→  falloff = parseFloat(falloffSlider.value);\n   491→  falloffVal.textContent = falloff.toFixed(2);\n   492→});\n   493→\n   494→// Particle count (logarithmic slider: 10^3 to 10^6.3)\n   495→let particleCountTimeout = null;\n   496→particleCountSlider.value = Math.log10(NUM_BOIDS);\n   497→particleCountVal.textContent = NUM_BOIDS.toLocaleString();\n   498→particleCountSlider.addEventListener('input', () => {\n   499→  const count = Math.round(Math.pow(10, parseFloat(particleCountSlider.value)));\n   500→  particleCountVal.textContent = count.toLocaleString();\n   501→  clearTimeout(particleCountTimeout);\n   502→  particleCountTimeout = setTimeout(async () => {\n   503→    NUM_BOIDS = count;\n   504→    simulation = await createSimulation(device, { numBoids: count, worldSize: WORLD_SIZE });\n   505→    simulation.setParams(currentParams);\n   506→    simulation.applySizeRandomness(currentParams.sizeRandomness ?? 0);\n   507→    simulation.autoRange = autoRangeCb.checked;\n   508→    renderer.rebindSimulation(simulation);\n   509→  }, 500);\n   510→});\n   511→\n   512→bloomCb.addEventListener('change', () => { bloomEnabled = bloomCb.checked; });\n   513→bloomThreshSlider.addEventListener('input', () => {\n   514→  bloomThreshold = parseFloat(bloomThreshSlider.value);\n   515→  bloomThreshVal.textContent = bloomThreshold.toFixed(2);\n   516→});\n   517→bloomIntensitySlider.addEventListener('input', () => {\n   518→  bloomIntensity = parseFloat(bloomIntensitySlider.value);\n   519→  bloomIntensityVal.textContent = bloomIntensity.toFixed(2);\n   520→});\n   521→\n   522→// Gradient + Color Source dropdowns\n   523→const gradientSelect = document.getElementById('gradient-select');\n   524→const colorSourceSelect = document.getElementById('color-source-select');\n   525→currentParams.gradientId = 0;\n   526→currentParams.colorSource = 0;\n   527→\n   528→gradientSelect.addEventListener('change', () => {\n   529→  currentParams.gradientId = parseInt(gradientSelect.value);\n   530→  simulation.setParams(currentParams);\n   531→});\n   532→colorSourceSelect.addEventListener('change', () => {\n   533→  currentParams.colorSource = parseInt(colorSourceSelect.value);\n   534→  simulation.setParams(currentParams);\n   535→});\n   536→\n   537→// Panel toggle\n   538→const panel = document.getElementById('panel');\n   539→document.getElementById('panel-toggle').addEventListener('click', () => {\n   540→  panel.classList.toggle('open');\n   541→});\n   542→\n   543→// ============================================================\n   544→// Orbit camera\n   545→// ============================================================\n   546→let azimuth   = 0.5;\n   547→let elevation = 0.35;\n   548→let distance  = 140;\n   549→\n   550→canvas.addEventListener('pointerdown', (e) => {\n   551→  canvas.setPointerCapture(e.pointerId);\n   552→  let lastX = e.clientX, lastY = e.clientY;\n   553→  const move = (ev) => {\n   554→    azimuth   -= (ev.clientX - lastX) * 0.005;\n   555→    elevation  = Math.max(-1.5, Math.min(1.5, elevation + (ev.clientY - lastY) * 0.005));\n   556→    lastX = ev.clientX; lastY = ev.clientY;\n   557→  };\n   558→  const up = () => { canvas.removeEventListener('pointermove', move); canvas.removeEventListener('pointerup', up); };\n   559→  canvas.addEventListener('pointermove', move);\n   560→  canvas.addEventListener('pointerup', up);\n   561→});\n   562→canvas.addEventListener('wheel', (e) => {\n   563→  distance = Math.max(20, Math.min(400, distance * (1 + e.deltaY * 0.001)));\n   564→  e.preventDefault();\n   565→}, { passive: false });\n   566→\n   567→// ============================================================\n   568→// Matrix helpers\n   569→// ============================================================\n   570→function perspective(fov, aspect, near, far) {\n   571→  const f = 1 / Math.tan(fov / 2);\n   572→  const nf = 1 / (near - far);\n   573→  return new Float32Array([\n   574→    f / aspect, 0, 0, 0,\n   575→    0, f, 0, 0,\n   576→    0, 0, (far + near) * nf, -1,\n   577→    0, 0, 2 * far * near * nf, 0,\n   578→  ]);\n   579→}\n   580→\n   581→function lookAt(eye, target, up) {\n   582→  const zx = eye[0]-target[0], zy = eye[1]-target[1], zz = eye[2]-target[2];\n   583→  let len = 1 / Math.hypot(zx, zy, zz);\n   584→  const z0=zx*len, z1=zy*len, z2=zz*len;\n   585→  const x0 = up[1]*z2 - up[2]*z1, x1 = up[2]*z0 - up[0]*z2, x2 = up[0]*z1 - up[1]*z0;\n   586→  len = Math.hypot(x0,x1,x2); const rl = len ? 1/len : 0;\n   587→  const r0=x0*rl, r1=x1*rl, r2=x2*rl;\n   588→  const u0=z1*r2-z2*r1, u1=z2*r0-z0*r2, u2=z0*r1-z1*r0;\n   589→  return new Float32Array([\n   590→    r0, u0, z0, 0,\n   591→    r1, u1, z1, 0,\n   592→    r2, u2, z2, 0,\n   593→    -(r0*eye[0]+r1*eye[1]+r2*eye[2]),\n   594→    -(u0*eye[0]+u1*eye[1]+u2*eye[2]),\n   595→    -(z0*eye[0]+z1*eye[1]+z2*eye[2]),\n   596→    1,\n   597→  ]);\n   598→}\n   599→\n   600→function mat4Mul(a, b) {\n   601→  const o = new Float32Array(16);\n   602→  for (let i = 0; i < 4; i++)\n   603→    for (let j = 0; j < 4; j++)\n   604→      o[j*4+i] = a[i]*b[j*4] + a[4+i]*b[j*4+1] + a[8+i]*b[j*4+2] + a[12+i]*b[j*4+3];\n   605→  return o;\n   606→}\n   607→\n   608→// ============================================================\n   609→// FPS + Main loop + Benchmark reporting\n   610→// ============================================================\n   611→const frameTimes = [];\n   612→let lastTime = performance.now();\n   613→const hud = document.getElementById('hud');\n   614→let benchFrame = 0, benchDone = false;\n   615→\n   616→function frame() {\n   617→  const now = performance.now();\n   618→  const dt = now - lastTime;\n   619→  lastTime = now;\n   620→  benchFrame++;\n   621→  if (benchFrame > 30) frameTimes.push(dt);\n   622→  if (frameTimes.length > 200) frameTimes.shift();\n   623→\n   624→  const display = frameTimes.length ? frameTimes : [16.6];\n   625→  const avgMs = display.reduce((a,b) => a+b, 0) / display.length;\n   626→  hud.textContent = `${NUM_BOIDS.toLocaleString()} boids | ${(1000/avgMs).toFixed(0)} fps | ${avgMs.toFixed(1)} ms`;\n   627→\n   628→  if (benchmarkBoids && frameTimes.length >= 120 && !benchDone) {\n   629→    benchDone = true;\n   630→    const sorted = [...frameTimes].sort((a,b) => a - b);\n   631→    const avg = sorted.reduce((a,b) => a+b, 0) / sorted.length;\n   632→    const p99 = sorted[Math.floor(sorted.length * 0.99)];\n   633→    fetch('/api/bench_result', { method: 'POST',\n   634→      headers: { 'Content-Type': 'application/json' },\n   635→      body: JSON.stringify({ num_boids: NUM_BOIDS, frames: sorted.length,\n   636→        avg_ms: +avg.toFixed(2), p99_ms: +p99.toFixed(2),\n   637→        min_ms: +sorted[0].toFixed(2), max_ms: +sorted[sorted.length-1].toFixed(2) }),\n   638→    }).catch(() => {});\n   639→    hud.textContent += ' | BENCHMARK COMPLETE';\n   640→  }\n   641→\n   642→\n   643→\n   644→  const eye = [\n   645→    distance * Math.cos(elevation) * Math.sin(azimuth),\n   646→    distance * Math.sin(elevation),\n   647→    distance * Math.cos(elevation) * Math.cos(azimuth),\n   648→  ];\n   649→  const aspect = canvas.width / canvas.height;\n   650→  const proj = perspective(Math.PI / 3, aspect, 1.0, 600);\n   651→  const view = lookAt(eye, [0,0,0], [0,1,0]);\n   652→  const vp = mat4Mul(proj, view);\n   653→\n   654→  const encoder = device.createCommandEncoder();\n   655→  const simSteps = Math.max(1, Math.round(currentParams.simSpeed ?? 1));\n   656→  for (let s = 0; s < simSteps; s++) {\n   657→    simulation.update(encoder, s === simSteps - 1); // stats only on last step\n   658→  }\n   659→  const ar = autoRangeCb.checked;\n   660→  renderer.render(encoder, vp, {\n   661→    gradientId: currentParams.gradientId ?? 0,\n   662→    colorSource: currentParams.colorSource ?? 0,\n   663→    gain: currentParams.gain ?? 0.5,\n   664→    autoRange: ar, autoMin: simulation.autoMin, autoMax: simulation.autoMax,\n   665→    falloff, brightness, particleScale, sphereRadius: currentParams.sphereRadius ?? 100,\n   666→    renderMode, cameraPos: eye, bloomEnabled, bloomThreshold, bloomIntensity,\n   667→    numBoids: NUM_BOIDS, sim: simulation,\n   668→  });\n   669→  device.queue.submit([encoder.finish()]);\n   670→  if (ar) simulation.readStats();\n   671→\n   672→  requestAnimationFrame(frame);\n   673→}\n   674→requestAnimationFrame(frame);\n   675→\n   676→function showError(msg) {\n   677→  document.getElementById('hud').remove();\n   678→  const d = document.createElement('div'); d.id = 'error'; d.textContent = msg;\n   679→  document.body.appendChild(d);\n   680→}\n   681→</script>\n   682→</body>\n   683→</html>\n   684→"}]},"parent_tool_use_id":null,"session_id":"6b0e04ab-0a04-4fdc-bf69-142a37b30a0b","uuid":"8b1ae240-3b3e-4d27-ba02-d59d82e3c6af","timestamp":"2026-03-23T05:29:27.694Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/aaronlemke/AI/Murmuration/index.html","content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<title>3D Murmuration</title>\n<style>\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  body { background: #000; overflow: hidden; font-family: system-ui, sans-serif; }\n  canvas { display: block; width: 100vw; height: 100vh; }\n  #hud {\n    position: fixed; top: 12px; left: 16px;\n    color: #aac; font: 14px/1.4 monospace;\n    pointer-events: none; text-shadow: 0 1px 3px #000;\n  }\n  #error {\n    position: fixed; inset: 0; display: flex; align-items: center; justify-content: center;\n    color: #f88; font: 18px/1.6 system-ui; text-align: center; padding: 2em;\n  }\n\n  /* --- Settings panel --- */\n  #panel {\n    position: fixed; top: 12px; right: 16px; width: 280px;\n    z-index: 10; user-select: none;\n  }\n  #panel-toggle {\n    display: block; width: 100%; padding: 8px 14px;\n    background: rgba(20,20,40,0.85); color: #aac; border: 1px solid rgba(100,100,160,0.3);\n    border-radius: 6px; font: 13px/1 system-ui; cursor: pointer; text-align: left;\n    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);\n  }\n  #panel-toggle:hover { background: rgba(30,30,60,0.9); }\n  #panel-toggle::after { content: ' \\u25BC'; float: right; font-size: 10px; }\n  #panel.open #panel-toggle::after { content: ' \\u25B2'; }\n  #panel-body {\n    max-height: 0; overflow: hidden; transition: max-height 0.3s ease;\n    background: rgba(10,10,25,0.88); border: 1px solid rgba(100,100,160,0.25);\n    border-top: none; border-radius: 0 0 6px 6px;\n    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);\n  }\n  #panel.open #panel-body { max-height: 700px; }\n  #panel-inner { padding: 10px 14px 14px; }\n\n  .param-row {\n    display: flex; align-items: center; gap: 6px; margin-bottom: 6px;\n  }\n  .param-row label {\n    flex: 0 0 90px; color: #889; font-size: 11px; text-align: right;\n  }\n  .param-row input[type=range] {\n    flex: 1; height: 4px; accent-color: #668cff;\n  }\n  .param-row .val {\n    flex: 0 0 42px; color: #bbd; font: 11px monospace; text-align: right;\n  }\n\n  .preset-row {\n    display: flex; gap: 6px; margin-bottom: 10px; align-items: center;\n  }\n  .preset-row select {\n    flex: 1; padding: 4px 6px; font-size: 12px;\n    background: rgba(30,30,60,0.9); color: #bbd; border: 1px solid rgba(100,100,160,0.3);\n    border-radius: 4px;\n  }\n  .preset-row button {\n    padding: 4px 8px; font-size: 11px; cursor: pointer;\n    background: rgba(40,40,80,0.8); color: #aac; border: 1px solid rgba(100,100,160,0.3);\n    border-radius: 4px;\n  }\n  .preset-row button:hover { background: rgba(60,60,100,0.9); }\n  .section-label {\n    color: #667; font-size: 10px; text-transform: uppercase; letter-spacing: 1px;\n    margin: 8px 0 4px; padding-bottom: 2px; border-bottom: 1px solid rgba(100,100,160,0.15);\n  }\n</style>\n</head>\n<body>\n<canvas id=\"c\"></canvas>\n<div id=\"hud\"></div>\n\n<div id=\"panel\">\n  <button id=\"panel-toggle\">Settings</button>\n  <div id=\"panel-body\"><div id=\"panel-inner\">\n    <div class=\"section-label\">Presets</div>\n    <div class=\"preset-row\">\n      <select id=\"preset-select\"></select>\n      <button id=\"preset-save\" title=\"Save current as new preset\">Save</button>\n      <button id=\"preset-del\" title=\"Delete selected user preset\">Del</button>\n    </div>\n    <div class=\"section-label\">Visuals</div>\n    <div class=\"param-row\">\n      <label>Gradient</label>\n      <select id=\"gradient-select\" style=\"flex:1; padding:3px 6px; font-size:12px; background:rgba(30,30,60,0.9); color:#bbd; border:1px solid rgba(100,100,160,0.3); border-radius:4px;\">\n        <option value=\"0\">Viridis</option>\n        <option value=\"1\">Inferno</option>\n        <option value=\"2\">Magma</option>\n        <option value=\"3\">Plasma</option>\n        <option value=\"4\">Turbo</option>\n        <option value=\"5\">Cividis</option>\n        <option value=\"6\">Coolwarm</option>\n        <option value=\"7\">Spectral</option>\n        <option value=\"8\">Hot</option>\n        <option value=\"9\">Ocean</option>\n      </select>\n    </div>\n    <div class=\"param-row\">\n      <label>Color Source</label>\n      <select id=\"color-source-select\" style=\"flex:1; padding:3px 6px; font-size:12px; background:rgba(30,30,60,0.9); color:#bbd; border:1px solid rgba(100,100,160,0.3); border-radius:4px;\">\n        <option value=\"0\">Velocity Direction</option>\n        <option value=\"1\">Speed</option>\n        <option value=\"2\">Direction Change</option>\n        <option value=\"3\">Neighbor Count</option>\n        <option value=\"4\">Altitude</option>\n        <option value=\"5\">Distance from Center</option>\n        <option value=\"6\">Flock Alignment</option>\n        <option value=\"7\">Separation Pressure</option>\n        <option value=\"8\">Local Density</option>\n        <option value=\"9\">Boid ID</option>\n      </select>\n    </div>\n    <div class=\"param-row\">\n      <label>Gain</label>\n      <input type=\"range\" id=\"gain-slider\" min=\"0.0\" max=\"1.0\" step=\"0.01\" value=\"0.5\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"gain-val\">0.50</span>\n    </div>\n    <div class=\"param-row\">\n      <label>Auto-Range</label>\n      <label style=\"flex:1; color:#aab; font-size:12px; cursor:pointer;\">\n        <input type=\"checkbox\" id=\"auto-range-cb\" style=\"accent-color:#668cff; margin-right:4px;\">\n        Normalize to data range\n      </label>\n    </div>\n    <div class=\"param-row\">\n      <label>Brightness</label>\n      <input type=\"range\" id=\"brightness-slider\" min=\"0.1\" max=\"5.0\" step=\"0.05\" value=\"1.0\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"brightness-val\">1.00</span>\n    </div>\n    <div class=\"param-row\">\n      <label>Sphere Radius</label>\n      <input type=\"range\" id=\"sphere-radius-slider\" min=\"20\" max=\"300\" step=\"5\" value=\"100\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"sphere-radius-val\">100</span>\n    </div>\n    <div class=\"section-label\">Rendering</div>\n    <div class=\"param-row\">\n      <label>Render Mode</label>\n      <select id=\"render-mode-select\" style=\"flex:1; padding:3px 6px; font-size:12px; background:rgba(30,30,60,0.9); color:#bbd; border:1px solid rgba(100,100,160,0.3); border-radius:4px;\">\n        <option value=\"0\">Tetrahedron</option>\n        <option value=\"1\">Billboard (Additive)</option>\n        <option value=\"2\">Billboard (Opaque)</option>\n        <option value=\"3\">Reflective Tetrahedron</option>\n        <option value=\"4\">Reflective Billboard</option>\n      </select>\n    </div>\n    <div class=\"param-row\">\n      <label>Falloff</label>\n      <input type=\"range\" id=\"falloff-slider\" min=\"0.1\" max=\"3.0\" step=\"0.05\" value=\"1.0\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"falloff-val\">1.00</span>\n    </div>\n    <div class=\"param-row\">\n      <label>Particle Scale</label>\n      <input type=\"range\" id=\"particle-scale-slider\" min=\"0.05\" max=\"5.0\" step=\"0.05\" value=\"1.0\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"particle-scale-val\">1.00</span>\n    </div>\n    <div class=\"param-row\">\n      <label>Particle Count</label>\n      <input type=\"range\" id=\"particle-count-slider\" min=\"3\" max=\"6.3\" step=\"0.01\" value=\"3.7\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"particle-count-val\">5,000</span>\n    </div>\n    <div class=\"param-row\">\n      <label>Bloom</label>\n      <label style=\"flex:1; color:#aab; font-size:12px; cursor:pointer;\">\n        <input type=\"checkbox\" id=\"bloom-cb\" style=\"accent-color:#668cff; margin-right:4px;\">\n        Enable bloom\n      </label>\n    </div>\n    <div class=\"param-row\">\n      <label>Bloom Thresh</label>\n      <input type=\"range\" id=\"bloom-threshold-slider\" min=\"0.1\" max=\"2.0\" step=\"0.05\" value=\"0.8\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"bloom-threshold-val\">0.80</span>\n    </div>\n    <div class=\"param-row\">\n      <label>Bloom Intensity</label>\n      <input type=\"range\" id=\"bloom-intensity-slider\" min=\"0.0\" max=\"3.0\" step=\"0.05\" value=\"0.5\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"bloom-intensity-val\">0.50</span>\n    </div>\n    <div class=\"section-label\">Physics</div>\n    <div id=\"sliders\"></div>\n  </div></div>\n</div>\n\n<script type=\"module\">\n// Capture errors and post to server for debugging\nwindow.addEventListener('error', e => {\n  fetch('/api/bench_result', { method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ error: e.message, file: e.filename, line: e.lineno }),\n  }).catch(() => {});\n});\nwindow.addEventListener('unhandledrejection', e => {\n  fetch('/api/bench_result', { method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ error: String(e.reason) }),\n  }).catch(() => {});\n});\n\nimport { createSimulation } from './simulation.js';\nimport { createRenderer }   from './renderer.js';\n\n// Benchmark mode: ?boids=N runs a measured benchmark\nconst urlParams = new URLSearchParams(location.search);\nconst benchmarkBoids = urlParams.get('boids') ? parseInt(urlParams.get('boids')) : null;\n\nlet NUM_BOIDS = benchmarkBoids || 20000;\nconst WORLD_SIZE = 100;\n\n// ============================================================\n// Built-in presets\n// ============================================================\nconst BUILTIN_PRESETS = {\n  'Murmuration': {\n    simSpeed: 1.0, sizeRandomness: 0.0, dragFactor: 0.0, sphereRadius: 120,\n    visualRange: 15.0, separationDist: 2.0, alignFactor: 0.12,\n    cohesionFactor: 0.005, separationFactor: 0.08,\n    maxSpeed: 10.0, minSpeed: 3.0, turnFactor: 0.3, smoothing: 0.10,\n  },\n  'Tight Murmuration': {\n    simSpeed: 1.0, sizeRandomness: 0.0, dragFactor: 0.0, sphereRadius: 80,\n    visualRange: 10.0, separationDist: 1.5, alignFactor: 0.15,\n    cohesionFactor: 0.005, separationFactor: 0.12,\n    maxSpeed: 12.0, minSpeed: 5.0, turnFactor: 0.4, smoothing: 0.08,\n  },\n  'Lazy Murmuration': {\n    simSpeed: 1.0, sizeRandomness: 0.0, dragFactor: 0.0, sphereRadius: 150,\n    visualRange: 20.0, separationDist: 3.0, alignFactor: 0.08,\n    cohesionFactor: 0.001, separationFactor: 0.05,\n    maxSpeed: 5.0, minSpeed: 1.5, turnFactor: 0.2, smoothing: 0.15,\n  },\n  'Swarm': {\n    simSpeed: 1.0, sizeRandomness: 0.3, dragFactor: 0.5, sphereRadius: 100,\n    visualRange: 8.0, separationDist: 0.8, alignFactor: 0.01,\n    cohesionFactor: 0.02, separationFactor: 0.3,\n    maxSpeed: 5.0, minSpeed: 0.5, turnFactor: 0.4, smoothing: 0.15,\n  },\n  'Predator Evasion': {\n    simSpeed: 1.0, sizeRandomness: 0.0, dragFactor: 0.0, sphereRadius: 120,\n    visualRange: 12.0, separationDist: 3.0, alignFactor: 0.10,\n    cohesionFactor: 0.003, separationFactor: 0.15,\n    maxSpeed: 14.0, minSpeed: 5.0, turnFactor: 0.5, smoothing: 0.06,\n  },\n};\n\n// Slider definitions: [key, label, min, max, step]\nconst SLIDER_DEFS = [\n  ['simSpeed',        'Sim Speed',     0.1,  10.0,  0.1],\n  ['sizeRandomness',  'Size Random',   0.0,   1.0,  0.05],\n  ['dragFactor',      'Size Drag',     0.0,   1.0,  0.05],\n  ['visualRange',     'Visual Range',  1.0,  10.0,  0.1],\n  ['separationDist',  'Sep. Dist',     0.3,   5.0,  0.1],\n  ['alignFactor',     'Alignment',     0.001, 0.2,  0.001],\n  ['cohesionFactor',  'Cohesion',      0.0005,0.05, 0.0005],\n  ['separationFactor','Separation',    0.05,  2.0,  0.01],\n  ['maxSpeed',        'Max Speed',     1.0,  50.0,  0.5],\n  ['minSpeed',        'Min Speed',     0.1,   5.0,  0.1],\n  ['turnFactor',      'Turn Factor',   0.05,  1.0,  0.05],\n  ['smoothing',       'Turn Rate',     0.01,  0.3,  0.005],\n];\n\n// ============================================================\n// WebGPU init\n// ============================================================\nif (!navigator.gpu) { showError('WebGPU not supported. Use Chrome 113+ or Edge 113+.'); throw ''; }\nconst adapter = await navigator.gpu.requestAdapter();\nif (!adapter) { showError('No WebGPU adapter found.'); throw ''; }\nconst device = await adapter.requestDevice();\n\nconst canvas = document.getElementById('c');\nconst ctx    = canvas.getContext('webgpu');\n\nfunction resize() {\n  const dpr = devicePixelRatio;\n  canvas.width  = Math.floor(innerWidth * dpr);\n  canvas.height = Math.floor(innerHeight * dpr);\n}\nresize();\n\nlet simulation, renderer;\ntry {\n  simulation = await createSimulation(device, { numBoids: NUM_BOIDS, worldSize: WORLD_SIZE });\n  renderer = await createRenderer(device, ctx, simulation);\n} catch(e) {\n  showError('Init failed: ' + e.message);\n  throw e;\n}\naddEventListener('resize', () => { resize(); renderer.resize(); });\n\n// ============================================================\n// Current params state\n// ============================================================\nlet currentParams = { ...BUILTIN_PRESETS['Murmuration'] };\nsimulation.setParams(currentParams);\nsimulation.applySizeRandomness(currentParams.sizeRandomness ?? 0);\n\n// ============================================================\n// UI: Sliders\n// ============================================================\nconst sliderEls = {};\nconst slidersDiv = document.getElementById('sliders');\n\nfor (const [key, label, min, max, step] of SLIDER_DEFS) {\n  const row = document.createElement('div');\n  row.className = 'param-row';\n\n  const lbl = document.createElement('label');\n  lbl.textContent = label;\n\n  const input = document.createElement('input');\n  input.type = 'range';\n  input.min = min; input.max = max; input.step = step;\n  input.value = currentParams[key];\n\n  const val = document.createElement('span');\n  val.className = 'val';\n  val.textContent = fmtVal(currentParams[key], step);\n\n  input.addEventListener('input', () => {\n    const v = parseFloat(input.value);\n    currentParams[key] = v;\n    val.textContent = fmtVal(v, step);\n    simulation.setParams(currentParams);\n    if (key === 'sizeRandomness') simulation.applySizeRandomness(v);\n  });\n\n  row.append(lbl, input, val);\n  slidersDiv.appendChild(row);\n  sliderEls[key] = { input, val, step };\n}\n\nfunction fmtVal(v, step) {\n  const dec = step < 0.01 ? 4 : step < 0.1 ? 3 : step < 1 ? 2 : 1;\n  return v.toFixed(dec);\n}\n\nfunction syncSliders() {\n  for (const [key] of SLIDER_DEFS) {\n    const el = sliderEls[key];\n    el.input.value = currentParams[key];\n    el.val.textContent = fmtVal(currentParams[key], el.step);\n  }\n}\n\n// ============================================================\n// UI: Presets\n// ============================================================\nconst LS_KEY = 'murmuration-user-presets';\nconst presetSelect = document.getElementById('preset-select');\n\nfunction loadUserPresets() {\n  try { return JSON.parse(localStorage.getItem(LS_KEY)) || {}; } catch { return {}; }\n}\nfunction saveUserPresets(obj) {\n  localStorage.setItem(LS_KEY, JSON.stringify(obj));\n}\n\nfunction populatePresetDropdown() {\n  presetSelect.innerHTML = '';\n  // Built-in\n  for (const name of Object.keys(BUILTIN_PRESETS)) {\n    const opt = document.createElement('option');\n    opt.value = name; opt.textContent = name;\n    presetSelect.appendChild(opt);\n  }\n  // User\n  const userPresets = loadUserPresets();\n  const userNames = Object.keys(userPresets);\n  if (userNames.length) {\n    const sep = document.createElement('option');\n    sep.disabled = true; sep.textContent = '--- User Presets ---';\n    presetSelect.appendChild(sep);\n    for (const name of userNames) {\n      const opt = document.createElement('option');\n      opt.value = `user:${name}`; opt.textContent = name;\n      presetSelect.appendChild(opt);\n    }\n  }\n}\n\nfunction applyPreset(name) {\n  let params;\n  if (name.startsWith('user:')) {\n    params = loadUserPresets()[name.slice(5)];\n  } else {\n    params = BUILTIN_PRESETS[name];\n  }\n  if (!params) return;\n  currentParams = { ...params };\n  simulation.setParams(currentParams);\n  simulation.applySizeRandomness(currentParams.sizeRandomness ?? 0);\n  syncSliders();\n}\n\npresetSelect.addEventListener('change', () => applyPreset(presetSelect.value));\n\ndocument.getElementById('preset-save').addEventListener('click', () => {\n  const name = prompt('Preset name:');\n  if (!name || !name.trim()) return;\n  const userPresets = loadUserPresets();\n  userPresets[name.trim()] = { ...currentParams };\n  saveUserPresets(userPresets);\n  populatePresetDropdown();\n  presetSelect.value = `user:${name.trim()}`;\n});\n\ndocument.getElementById('preset-del').addEventListener('click', () => {\n  const sel = presetSelect.value;\n  if (!sel.startsWith('user:')) return; // can't delete built-in\n  const name = sel.slice(5);\n  const userPresets = loadUserPresets();\n  delete userPresets[name];\n  saveUserPresets(userPresets);\n  populatePresetDropdown();\n  presetSelect.value = 'Murmuration';\n  applyPreset('Murmuration');\n});\n\npopulatePresetDropdown();\npresetSelect.value = 'Murmuration';\n\n// Gain slider\nconst gainSlider = document.getElementById('gain-slider');\nconst gainVal = document.getElementById('gain-val');\ncurrentParams.gain = 0.5;\ngainSlider.addEventListener('input', () => {\n  currentParams.gain = parseFloat(gainSlider.value);\n  gainVal.textContent = currentParams.gain.toFixed(2);\n});\n\n// Auto-range checkbox\nconst autoRangeCb = document.getElementById('auto-range-cb');\nautoRangeCb.addEventListener('change', () => {\n  simulation.autoRange = autoRangeCb.checked;\n});\n\n// Brightness slider\nconst brightnessSlider = document.getElementById('brightness-slider');\nconst brightnessVal = document.getElementById('brightness-val');\nlet brightness = 1.0;\nbrightnessSlider.addEventListener('input', () => {\n  brightness = parseFloat(brightnessSlider.value);\n  brightnessVal.textContent = brightness.toFixed(2);\n});\n\n// Sphere radius slider\nconst sphereRadiusSlider = document.getElementById('sphere-radius-slider');\nconst sphereRadiusVal = document.getElementById('sphere-radius-val');\ncurrentParams.sphereRadius = 100;\nsphereRadiusSlider.addEventListener('input', () => {\n  currentParams.sphereRadius = parseFloat(sphereRadiusSlider.value);\n  sphereRadiusVal.textContent = currentParams.sphereRadius.toFixed(0);\n  simulation.setParams(currentParams);\n});\n\n// Particle scale slider\nconst particleScaleSlider = document.getElementById('particle-scale-slider');\nconst particleScaleVal = document.getElementById('particle-scale-val');\nlet particleScale = 1.0;\nparticleScaleSlider.addEventListener('input', () => {\n  particleScale = parseFloat(particleScaleSlider.value);\n  particleScaleVal.textContent = particleScale.toFixed(2);\n});\n\n// Rendering controls\nconst renderModeSelect = document.getElementById('render-mode-select');\nconst falloffSlider = document.getElementById('falloff-slider');\nconst falloffVal = document.getElementById('falloff-val');\nconst particleCountSlider = document.getElementById('particle-count-slider');\nconst particleCountVal = document.getElementById('particle-count-val');\nconst bloomCb = document.getElementById('bloom-cb');\nconst bloomThreshSlider = document.getElementById('bloom-threshold-slider');\nconst bloomThreshVal = document.getElementById('bloom-threshold-val');\nconst bloomIntensitySlider = document.getElementById('bloom-intensity-slider');\nconst bloomIntensityVal = document.getElementById('bloom-intensity-val');\n\nlet renderMode = 0;\nlet falloff = 1.0;\nlet bloomEnabled = false;\nlet bloomThreshold = 0.8;\nlet bloomIntensity = 0.5;\n\nrenderModeSelect.addEventListener('change', () => { renderMode = parseInt(renderModeSelect.value); });\nfalloffSlider.addEventListener('input', () => {\n  falloff = parseFloat(falloffSlider.value);\n  falloffVal.textContent = falloff.toFixed(2);\n});\n\n// Particle count (logarithmic slider: 10^3 to 10^6.3)\nlet particleCountTimeout = null;\nparticleCountSlider.value = Math.log10(NUM_BOIDS);\nparticleCountVal.textContent = NUM_BOIDS.toLocaleString();\nparticleCountSlider.addEventListener('input', () => {\n  const count = Math.round(Math.pow(10, parseFloat(particleCountSlider.value)));\n  particleCountVal.textContent = count.toLocaleString();\n  clearTimeout(particleCountTimeout);\n  particleCountTimeout = setTimeout(async () => {\n    NUM_BOIDS = count;\n    simulation = await createSimulation(device, { numBoids: count, worldSize: WORLD_SIZE });\n    simulation.setParams(currentParams);\n    simulation.applySizeRandomness(currentParams.sizeRandomness ?? 0);\n    simulation.autoRange = autoRangeCb.checked;\n    renderer.rebindSimulation(simulation);\n  }, 500);\n});\n\nbloomCb.addEventListener('change', () => { bloomEnabled = bloomCb.checked; });\nbloomThreshSlider.addEventListener('input', () => {\n  bloomThreshold = parseFloat(bloomThreshSlider.value);\n  bloomThreshVal.textContent = bloomThreshold.toFixed(2);\n});\nbloomIntensitySlider.addEventListener('input', () => {\n  bloomIntensity = parseFloat(bloomIntensitySlider.value);\n  bloomIntensityVal.textContent = bloomIntensity.toFixed(2);\n});\n\n// Gradient + Color Source dropdowns\nconst gradientSelect = document.getElementById('gradient-select');\nconst colorSourceSelect = document.getElementById('color-source-select');\ncurrentParams.gradientId = 0;\ncurrentParams.colorSource = 0;\n\ngradientSelect.addEventListener('change', () => {\n  currentParams.gradientId = parseInt(gradientSelect.value);\n  simulation.setParams(currentParams);\n});\ncolorSourceSelect.addEventListener('change', () => {\n  currentParams.colorSource = parseInt(colorSourceSelect.value);\n  simulation.setParams(currentParams);\n});\n\n// Panel toggle\nconst panel = document.getElementById('panel');\ndocument.getElementById('panel-toggle').addEventListener('click', () => {\n  panel.classList.toggle('open');\n});\n\n// ============================================================\n// Orbit camera\n// ============================================================\nlet azimuth   = 0.5;\nlet elevation = 0.35;\nlet distance  = 140;\n\ncanvas.addEventListener('pointerdown', (e) => {\n  canvas.setPointerCapture(e.pointerId);\n  let lastX = e.clientX, lastY = e.clientY;\n  const move = (ev) => {\n    azimuth   -= (ev.clientX - lastX) * 0.005;\n    elevation  = Math.max(-1.5, Math.min(1.5, elevation + (ev.clientY - lastY) * 0.005));\n    lastX = ev.clientX; lastY = ev.clientY;\n  };\n  const up = () => { canvas.removeEventListener('pointermove', move); canvas.removeEventListener('pointerup', up); };\n  canvas.addEventListener('pointermove', move);\n  canvas.addEventListener('pointerup', up);\n});\ncanvas.addEventListener('wheel', (e) => {\n  distance = Math.max(20, Math.min(400, distance * (1 + e.deltaY * 0.001)));\n  e.preventDefault();\n}, { passive: false });\n\n// ============================================================\n// Matrix helpers\n// ============================================================\nfunction perspective(fov, aspect, near, far) {\n  const f = 1 / Math.tan(fov / 2);\n  const nf = 1 / (near - far);\n  return new Float32Array([\n    f / aspect, 0, 0, 0,\n    0, f, 0, 0,\n    0, 0, (far + near) * nf, -1,\n    0, 0, 2 * far * near * nf, 0,\n  ]);\n}\n\nfunction lookAt(eye, target, up) {\n  const zx = eye[0]-target[0], zy = eye[1]-target[1], zz = eye[2]-target[2];\n  let len = 1 / Math.hypot(zx, zy, zz);\n  const z0=zx*len, z1=zy*len, z2=zz*len;\n  const x0 = up[1]*z2 - up[2]*z1, x1 = up[2]*z0 - up[0]*z2, x2 = up[0]*z1 - up[1]*z0;\n  len = Math.hypot(x0,x1,x2); const rl = len ? 1/len : 0;\n  const r0=x0*rl, r1=x1*rl, r2=x2*rl;\n  const u0=z1*r2-z2*r1, u1=z2*r0-z0*r2, u2=z0*r1-z1*r0;\n  return new Float32Array([\n    r0, u0, z0, 0,\n    r1, u1, z1, 0,\n    r2, u2, z2, 0,\n    -(r0*eye[0]+r1*eye[1]+r2*eye[2]),\n    -(u0*eye[0]+u1*eye[1]+u2*eye[2]),\n    -(z0*eye[0]+z1*eye[1]+z2*eye[2]),\n    1,\n  ]);\n}\n\nfunction mat4Mul(a, b) {\n  const o = new Float32Array(16);\n  for (let i = 0; i < 4; i++)\n    for (let j = 0; j < 4; j++)\n      o[j*4+i] = a[i]*b[j*4] + a[4+i]*b[j*4+1] + a[8+i]*b[j*4+2] + a[12+i]*b[j*4+3];\n  return o;\n}\n\n// ============================================================\n// FPS + Main loop + Benchmark reporting\n// ============================================================\nconst frameTimes = [];\nlet lastTime = performance.now();\nconst hud = document.getElementById('hud');\nlet benchFrame = 0, benchDone = false;\n\nfunction frame() {\n  const now = performance.now();\n  const dt = now - lastTime;\n  lastTime = now;\n  benchFrame++;\n  if (benchFrame > 30) frameTimes.push(dt);\n  if (frameTimes.length > 200) frameTimes.shift();\n\n  const display = frameTimes.length ? frameTimes : [16.6];\n  const avgMs = display.reduce((a,b) => a+b, 0) / display.length;\n  hud.textContent = `${NUM_BOIDS.toLocaleString()} boids | ${(1000/avgMs).toFixed(0)} fps | ${avgMs.toFixed(1)} ms`;\n\n  if (benchmarkBoids && frameTimes.length >= 120 && !benchDone) {\n    benchDone = true;\n    const sorted = [...frameTimes].sort((a,b) => a - b);\n    const avg = sorted.reduce((a,b) => a+b, 0) / sorted.length;\n    const p99 = sorted[Math.floor(sorted.length * 0.99)];\n    fetch('/api/bench_result', { method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ num_boids: NUM_BOIDS, frames: sorted.length,\n        avg_ms: +avg.toFixed(2), p99_ms: +p99.toFixed(2),\n        min_ms: +sorted[0].toFixed(2), max_ms: +sorted[sorted.length-1].toFixed(2) }),\n    }).catch(() => {});\n    hud.textContent += ' | BENCHMARK COMPLETE';\n  }\n\n\n\n  const eye = [\n    distance * Math.cos(elevation) * Math.sin(azimuth),\n    distance * Math.sin(elevation),\n    distance * Math.cos(elevation) * Math.cos(azimuth),\n  ];\n  const aspect = canvas.width / canvas.height;\n  const proj = perspective(Math.PI / 3, aspect, 1.0, 600);\n  const view = lookAt(eye, [0,0,0], [0,1,0]);\n  const vp = mat4Mul(proj, view);\n\n  const encoder = device.createCommandEncoder();\n  const simSteps = Math.max(1, Math.round(currentParams.simSpeed ?? 1));\n  for (let s = 0; s < simSteps; s++) {\n    simulation.update(encoder, s === simSteps - 1); // stats only on last step\n  }\n  const ar = autoRangeCb.checked;\n  renderer.render(encoder, vp, {\n    gradientId: currentParams.gradientId ?? 0,\n    colorSource: currentParams.colorSource ?? 0,\n    gain: currentParams.gain ?? 0.5,\n    autoRange: ar, autoMin: simulation.autoMin, autoMax: simulation.autoMax,\n    falloff, brightness, particleScale, sphereRadius: currentParams.sphereRadius ?? 100,\n    renderMode, cameraPos: eye, bloomEnabled, bloomThreshold, bloomIntensity,\n    numBoids: NUM_BOIDS, sim: simulation,\n  });\n  device.queue.submit([encoder.finish()]);\n  if (ar) simulation.readStats();\n\n  requestAnimationFrame(frame);\n}\nrequestAnimationFrame(frame);\n\nfunction showError(msg) {\n  document.getElementById('hud').remove();\n  const d = document.createElement('div'); d.id = 'error'; d.textContent = msg;\n  document.body.appendChild(d);\n}\n</script>\n</body>\n</html>\n","numLines":684,"startLine":1,"totalLines":684}}}
