{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TKoLKZF2fncysfRhbkwQfa","type":"tool_result","content":"     1→// === 3D Murmuration Compute Shader — Topological Neighbor Model ===\n     2→// Based on empirical starling research: birds track their nearest 7 neighbors,\n     3→// not all within a fixed radius. This produces realistic wave propagation,\n     4→// sharp flock edges, and coordinated turns.\n     5→\n     6→struct SimParams {\n     7→  num_boids: u32,\n     8→  grid_size: u32,\n     9→  grid_cells: u32,\n    10→  world_size: f32,\n    11→  cell_size: f32,\n    12→  visual_range: f32,\n    13→  visual_range_sq: f32,\n    14→  separation_dist: f32,\n    15→  separation_dist_sq: f32,\n    16→  align_factor: f32,\n    17→  cohesion_factor: f32,\n    18→  separation_factor: f32,\n    19→  max_speed: f32,\n    20→  min_speed: f32,\n    21→  dt: f32,\n    22→  turn_factor: f32,\n    23→  smoothing: f32,\n    24→  sim_speed: f32,\n    25→  size_randomness: f32,\n    26→  drag_factor: f32,\n    27→  gradient_id: u32,\n    28→  color_source: u32,\n    29→  sphere_radius: f32,\n    30→  frame_count: u32,\n    31→}\n    32→\n    33→struct Boid {\n    34→  pos: vec3f,\n    35→  size_factor: f32,\n    36→  vel: vec3f,\n    37→  speed: f32,\n    38→  heading: vec3f,\n    39→  neighbor_count: f32,\n    40→  dir_change: f32,\n    41→  flock_alignment: f32,\n    42→  sep_pressure: f32,\n    43→  density: f32,\n    44→}\n    45→\n    46→@group(0) @binding(0) var<uniform> params: SimParams;\n    47→@group(0) @binding(1) var<storage, read_write> boids_src: array<Boid>;\n    48→@group(0) @binding(2) var<storage, read_write> boids_dst: array<Boid>;\n    49→@group(0) @binding(3) var<storage, read_write> cell_counts: array<atomic<u32>>;\n    50→@group(0) @binding(4) var<storage, read_write> cell_offsets: array<u32>;\n    51→@group(0) @binding(5) var<storage, read_write> boid_cells: array<u32>;\n    52→@group(0) @binding(6) var<storage, read_write> sorted_indices: array<u32>;\n    53→@group(0) @binding(7) var<storage, read_write> scatter_counters: array<atomic<u32>>;\n    54→\n    55→fn get_cell(pos: vec3f) -> vec3u {\n    56→  let half = params.world_size * 0.5;\n    57→  return vec3u(clamp(\n    58→    vec3i(floor((pos + vec3f(half)) / params.cell_size)),\n    59→    vec3i(0),\n    60→    vec3i(i32(params.grid_size) - 1)\n    61→  ));\n    62→}\n    63→\n    64→fn cell_index(c: vec3u) -> u32 {\n    65→  return c.x + c.y * params.grid_size + c.z * params.grid_size * params.grid_size;\n    66→}\n    67→\n    68→@compute @workgroup_size(64)\n    69→fn clear_grid(@builtin(global_invocation_id) id: vec3u) {\n    70→  let i = id.x;\n    71→  if (i >= params.grid_cells) { return; }\n    72→  atomicStore(&cell_counts[i], 0u);\n    73→  atomicStore(&scatter_counters[i], 0u);\n    74→}\n    75→\n    76→@compute @workgroup_size(64)\n    77→fn assign_cells(@builtin(global_invocation_id) id: vec3u) {\n    78→  let i = id.x;\n    79→  if (i >= params.num_boids) { return; }\n    80→  let cell = cell_index(get_cell(boids_src[i].pos));\n    81→  boid_cells[i] = cell;\n    82→  atomicAdd(&cell_counts[cell], 1u);\n    83→}\n    84→\n    85→const SCAN_WG: u32 = 256u;\n    86→var<workgroup> scan_sums: array<u32, 256>;\n    87→\n    88→@compute @workgroup_size(256)\n    89→fn prefix_sum(@builtin(local_invocation_id) lid: vec3u) {\n    90→  let tid = lid.x;\n    91→  let chunk = (params.grid_cells + SCAN_WG - 1u) / SCAN_WG;\n    92→  let start = tid * chunk;\n    93→  let end = min(start + chunk, params.grid_cells);\n    94→  var local_total = 0u;\n    95→  for (var i = start; i < end; i++) {\n    96→    let count = atomicLoad(&cell_counts[i]);\n    97→    cell_offsets[i] = local_total;\n    98→    local_total += count;\n    99→  }\n   100→  scan_sums[tid] = local_total;\n   101→  workgroupBarrier();\n   102→  for (var stride = 1u; stride < SCAN_WG; stride *= 2u) {\n   103→    let val = select(0u, scan_sums[tid - stride], tid >= stride);\n   104→    workgroupBarrier();\n   105→    scan_sums[tid] += val;\n   106→    workgroupBarrier();\n   107→  }\n   108→  let prefix = select(0u, scan_sums[tid - 1u], tid > 0u);\n   109→  for (var i = start; i < end; i++) {\n   110→    cell_offsets[i] += prefix;\n   111→  }\n   112→}\n   113→\n   114→@compute @workgroup_size(64)\n   115→fn scatter(@builtin(global_invocation_id) id: vec3u) {\n   116→  let i = id.x;\n   117→  if (i >= params.num_boids) { return; }\n   118→  let cell = boid_cells[i];\n   119→  let local_offset = atomicAdd(&scatter_counters[cell], 1u);\n   120→  sorted_indices[cell_offsets[cell] + local_offset] = i;\n   121→}\n   122→\n   123→// === Topological Neighbor Flocking ===\n   124→// Find the K nearest neighbors (K=7 for alignment/cohesion, closest 1 for avoidance)\n   125→// Uses the spatial hash to find candidates, then keeps only the K closest.\n   126→\n   127→const K_NEIGHBORS: u32 = 7u;\n   128→\n   129→@compute @workgroup_size(64)\n   130→fn flock(@builtin(global_invocation_id) id: vec3u) {\n   131→  let i = id.x;\n   132→  if (i >= params.num_boids) { return; }\n   133→\n   134→  let boid = boids_src[i];\n   135→  let my_grid = get_cell(boid.pos);\n   136→  let gs = i32(params.grid_size);\n   137→  let mg = vec3i(my_grid);\n   138→\n   139→  // Track K nearest neighbors by distance (insertion sort into small array)\n   140→  // Store squared distances and indices\n   141→  var nearest_d2: array<f32, 7>;   // distances squared\n   142→  var nearest_idx: array<u32, 7>;  // boid indices\n   143→  var n_found = 0u;\n   144→\n   145→  // Initialize with large distances\n   146→  for (var k = 0u; k < K_NEIGHBORS; k++) {\n   147→    nearest_d2[k] = 1e10;\n   148→    nearest_idx[k] = 0u;\n   149→  }\n   150→\n   151→  // Search 3x3x3 neighborhood (27 cells)\n   152→  let lo = max(mg - vec3i(1), vec3i(0));\n   153→  let hi = min(mg + vec3i(1), vec3i(gs - 1));\n   154→\n   155→  var total_candidates = 0u;\n   156→\n   157→  for (var nz = lo.z; nz <= hi.z; nz++) {\n   158→    let zoff = u32(nz) * params.grid_size * params.grid_size;\n   159→    for (var ny = lo.y; ny <= hi.y; ny++) {\n   160→      let yzoff = u32(ny) * params.grid_size + zoff;\n   161→      for (var nx = lo.x; nx <= hi.x; nx++) {\n   162→        let nc = u32(nx) + yzoff;\n   163→        let start = cell_offsets[nc];\n   164→        let end_val = select(cell_offsets[nc + 1u], params.num_boids, nc + 1u >= params.grid_cells);\n   165→        if (start >= end_val) { continue; }\n   166→\n   167→        for (var j = start; j < end_val; j++) {\n   168→          let other_idx = sorted_indices[j];\n   169→          if (other_idx == i) { continue; }\n   170→\n   171→          let other_pos = boids_src[other_idx].pos;\n   172→          let diff = boid.pos - other_pos;\n   173→          let d2 = dot(diff, diff);\n   174→\n   175→          // Pre-filter by visual range before K-nearest sort\n   176→          if (d2 > params.visual_range_sq) { continue; }\n   177→\n   178→          total_candidates++;\n   179→\n   180→          // Insert into sorted K-nearest if closer than current worst\n   181→          if (d2 < nearest_d2[K_NEIGHBORS - 1u]) {\n   182→            // Find insertion position\n   183→            var pos = K_NEIGHBORS - 1u;\n   184→            for (var k = 0u; k < K_NEIGHBORS - 1u; k++) {\n   185→              if (d2 < nearest_d2[k]) {\n   186→                pos = k;\n   187→                break;\n   188→              }\n   189→            }\n   190→            // Shift larger entries down\n   191→            for (var k = K_NEIGHBORS - 1u; k > pos; k--) {\n   192→              nearest_d2[k] = nearest_d2[k - 1u];\n   193→              nearest_idx[k] = nearest_idx[k - 1u];\n   194→            }\n   195→            nearest_d2[pos] = d2;\n   196→            nearest_idx[pos] = other_idx;\n   197→            n_found = min(n_found + 1u, K_NEIGHBORS);\n   198→          }\n   199→        }\n   200→      }\n   201→    }\n   202→  }\n   203→\n   204→  // === Apply flocking rules using topological neighbors ===\n   205→  var new_vel = boid.vel;\n   206→\n   207→  // Avoidance: only the 1 nearest neighbor\n   208→  var sep_force = vec3f(0.0);\n   209→  if (n_found > 0u && nearest_d2[0] < params.separation_dist_sq) {\n   210→    let other_pos = boids_src[nearest_idx[0]].pos;\n   211→    let diff = boid.pos - other_pos;\n   212→    let d2 = nearest_d2[0];\n   213→    sep_force = diff * (1.0 - d2 / params.separation_dist_sq);\n   214→    new_vel += sep_force * params.separation_factor * 2.0; // stronger since only 1 neighbor\n   215→  }\n   216→\n   217→  // Alignment + Cohesion: all K neighbors\n   218→  var ali = vec3f(0.0);\n   219→  var coh = vec3f(0.0);\n   220→  var avg_vel = vec3f(0.0);\n   221→  if (n_found > 0u) {\n   222→    for (var k = 0u; k < min(n_found, K_NEIGHBORS); k++) {\n   223→      let other = boids_src[nearest_idx[k]];\n   224→      ali += other.vel;\n   225→      coh += other.pos;\n   226→    }\n   227→    let nf = f32(min(n_found, K_NEIGHBORS));\n   228→    avg_vel = ali / nf;\n   229→    let avg_pos = coh / nf;\n   230→    new_vel += (avg_vel - boid.vel) * params.align_factor;\n   231→    new_vel += (avg_pos - boid.pos) * params.cohesion_factor;\n   232→  }\n   233→\n   234→  // === Emergent murmuration forces ===\n   235→  // NO roost attractor, NO predator orbit — purely local interactions\n   236→  // The complex sweeping motion emerges from topological neighbor rules\n   237→  // + rare perturbations that cascade through the flock\n   238→\n   239→  // Gentle gravity (creates oblate/flat flock shape)\n   240→  new_vel.y -= 0.03;\n   241→\n   242→  // Rare strong perturbation: only ~3% of birds per frame\n   243→  // This is the primary driver of non-repetitive motion —\n   244→  // a random bird changes direction, neighbors respond via alignment,\n   245→  // creating a wave that sweeps across the entire flock\n   246→  let perturb_hash = fract(sin(f32(i * 7919u + params.frame_count * 104729u)) * 43758.5);\n   247→  if (perturb_hash < 0.04) {\n   248→    let seed = f32(i * 1973u + params.frame_count * 9277u);\n   249→    let kick = vec3f(\n   250→      fract(sin(seed) * 43758.5) - 0.5,\n   251→      fract(sin(seed * 1.3) * 22578.1) - 0.5,\n   252→      fract(sin(seed * 0.7) * 31415.9) - 0.5\n   253→    ) * 2.5;  // strong kick that cascades via topological links\n   254→    new_vel += kick;\n   255→  }\n   256→\n   257→  // Spherical boundary steering\n   258→  let dist_from_center = length(boid.pos);\n   259→  let r = params.sphere_radius;\n   260→  let soft_zone = r * 0.15;\n   261→  if (dist_from_center > r - soft_zone && dist_from_center > 0.001) {\n   262→    let penetration = (dist_from_center - (r - soft_zone)) / soft_zone;\n   263→    let push = -normalize(boid.pos) * params.turn_factor * clamp(penetration, 0.0, 3.0);\n   264→    new_vel += push;\n   265→  }\n   266→\n   267→  // Turn rate limiter (smooth heading changes — creates wave-like motion)\n   268→  let old_speed = length(boid.vel);\n   269→  var old_dir = boid.vel;\n   270→  if (old_speed > 0.001) { old_dir = old_dir / old_speed; }\n   271→  else { old_dir = vec3f(1.0, 0.0, 0.0); }\n   272→  let desired_speed = length(new_vel);\n   273→  var desired_dir = new_vel;\n   274→  if (desired_speed > 0.001) { desired_dir = desired_dir / desired_speed; }\n   275→  else { desired_dir = old_dir; }\n   276→  let final_dir = normalize(mix(old_dir, desired_dir, params.smoothing));\n   277→\n   278→  // Speed with drag\n   279→  let drag_scale = 1.0 / mix(1.0, boid.size_factor, params.drag_factor);\n   280→  var final_speed = mix(old_speed, desired_speed, 0.15);\n   281→  final_speed = clamp(final_speed, params.min_speed * drag_scale, params.max_speed * drag_scale);\n   282→  new_vel = final_dir * final_speed;\n   283→\n   284→  // Direction change metric\n   285→  let dir_change_val = 1.0 - clamp(dot(old_dir, final_dir), -1.0, 1.0);\n   286→  let effective_dt = params.dt;\n   287→\n   288→  // Write outputs\n   289→  boids_dst[i].pos = boid.pos + new_vel * effective_dt;\n   290→  boids_dst[i].vel = new_vel;\n   291→  boids_dst[i].size_factor = boid.size_factor;\n   292→  boids_dst[i].heading = final_dir;\n   293→  boids_dst[i].speed = final_speed;\n   294→  boids_dst[i].neighbor_count = f32(n_found);\n   295→  boids_dst[i].dir_change = dir_change_val;\n   296→  let vel_d2 = dot(boid.vel, boid.vel);\n   297→  let avg_d2 = dot(avg_vel, avg_vel);\n   298→  boids_dst[i].flock_alignment = select(dot(boid.vel, avg_vel) * inverseSqrt(vel_d2 * avg_d2), 0.0, vel_d2 < 0.001 || avg_d2 < 0.001);\n   299→  boids_dst[i].sep_pressure = length(sep_force);\n   300→  boids_dst[i].density = f32(n_found) / f32(K_NEIGHBORS);\n   301→}\n   302→\n   303→// === Classic Radius-Based Flocking (high performance, simpler behavior) ===\n   304→@compute @workgroup_size(64)\n   305→fn flock_radius(@builtin(global_invocation_id) id: vec3u) {\n   306→  let i = id.x;\n   307→  if (i >= params.num_boids) { return; }\n   308→\n   309→  let boid = boids_src[i];\n   310→  let my_grid = get_cell(boid.pos);\n   311→  let gs = i32(params.grid_size);\n   312→  let mg = vec3i(my_grid);\n   313→  let lo = max(mg - vec3i(1), vec3i(0));\n   314→  let hi = min(mg + vec3i(1), vec3i(gs - 1));\n   315→\n   316→  var sep = vec3f(0.0);\n   317→  var ali = vec3f(0.0);\n   318→  var coh = vec3f(0.0);\n   319→  var n_align = 0u;\n   320→  var n_sep = 0u;\n   321→\n   322→  for (var nz = lo.z; nz <= hi.z; nz++) {\n   323→    let zoff = u32(nz) * params.grid_size * params.grid_size;\n   324→    for (var ny = lo.y; ny <= hi.y; ny++) {\n   325→      let yzoff = u32(ny) * params.grid_size + zoff;\n   326→      for (var nx = lo.x; nx <= hi.x; nx++) {\n   327→        let nc = u32(nx) + yzoff;\n   328→        let start = cell_offsets[nc];\n   329→        let end_val = select(cell_offsets[nc + 1u], params.num_boids, nc + 1u >= params.grid_cells);\n   330→        if (start >= end_val) { continue; }\n   331→        for (var j = start; j < end_val; j++) {\n   332→          let other_idx = sorted_indices[j];\n   333→          if (other_idx == i) { continue; }\n   334→          let other = boids_src[other_idx];\n   335→          let diff = boid.pos - other.pos;\n   336→          let d2 = dot(diff, diff);\n   337→          if (d2 < params.visual_range_sq && d2 > 0.0001) {\n   338→            ali += other.vel;\n   339→            coh += other.pos;\n   340→            n_align++;\n   341→            if (d2 < params.separation_dist_sq) {\n   342→              sep += diff * (1.0 - d2 / params.separation_dist_sq);\n   343→              n_sep++;\n   344→            }\n   345→          }\n   346→        }\n   347→        if (n_align >= 16u) { break; }\n   348→      }\n   349→      if (n_align >= 16u) { break; }\n   350→    }\n   351→    if (n_align >= 16u) { break; }\n   352→  }\n   353→\n   354→  var new_vel = boid.vel;\n   355→  var avg_vel = vec3f(0.0);\n   356→  if (n_align > 0u) {\n   357→    let nf = f32(n_align);\n   358→    avg_vel = ali / nf;\n   359→    let avg_pos = coh / nf;\n   360→    new_vel += (avg_vel - boid.vel) * params.align_factor;\n   361→    new_vel += (avg_pos - boid.pos) * params.cohesion_factor;\n   362→  }\n   363→  if (n_sep > 0u) {\n   364→    new_vel += sep * params.separation_factor;\n   365→  }\n   366→\n   367→  // Spherical boundary\n   368→  let dist_from_center = length(boid.pos);\n   369→  let r = params.sphere_radius;\n   370→  let soft_zone = r * 0.15;\n   371→  if (dist_from_center > r - soft_zone && dist_from_center > 0.001) {\n   372→    let penetration = (dist_from_center - (r - soft_zone)) / soft_zone;\n   373→    new_vel += -normalize(boid.pos) * params.turn_factor * clamp(penetration, 0.0, 3.0);\n   374→  }\n   375→\n   376→  // Turn rate limiter + speed\n   377→  let old_speed = length(boid.vel);\n   378→  var old_dir = boid.vel;\n   379→  if (old_speed > 0.001) { old_dir = old_dir / old_speed; } else { old_dir = vec3f(1.0, 0.0, 0.0); }\n   380→  let desired_speed = length(new_vel);\n   381→  var desired_dir = new_vel;\n   382→  if (desired_speed > 0.001) { desired_dir = desired_dir / desired_speed; } else { desired_dir = old_dir; }\n   383→  let final_dir = normalize(mix(old_dir, desired_dir, params.smoothing));\n   384→  let drag_scale = 1.0 / mix(1.0, boid.size_factor, params.drag_factor);\n   385→  var final_speed = mix(old_speed, desired_speed, 0.15);\n   386→  final_speed = clamp(final_speed, params.min_speed * drag_scale, params.max_speed * drag_scale);\n   387→  new_vel = final_dir * final_speed;\n   388→\n   389→  let dir_change_val = 1.0 - clamp(dot(old_dir, final_dir), -1.0, 1.0);\n   390→  boids_dst[i].pos = boid.pos + new_vel * params.dt;\n   391→  boids_dst[i].vel = new_vel;\n   392→  boids_dst[i].size_factor = boid.size_factor;\n   393→  boids_dst[i].heading = final_dir;\n   394→  boids_dst[i].speed = final_speed;\n   395→  boids_dst[i].neighbor_count = f32(n_align);\n   396→  boids_dst[i].dir_change = dir_change_val;\n   397→  let vel_d2r = dot(boid.vel, boid.vel);\n   398→  let avg_d2r = dot(avg_vel, avg_vel);\n   399→  boids_dst[i].flock_alignment = select(dot(boid.vel, avg_vel) * inverseSqrt(vel_d2r * avg_d2r), 0.0, vel_d2r < 0.001 || avg_d2r < 0.001);\n   400→  boids_dst[i].sep_pressure = length(sep);\n   401→  boids_dst[i].density = f32(n_align) * 0.0625;\n   402→}\n   403→\n   404→// === Auto-range stats ===\n   405→@group(1) @binding(0) var<storage, read_write> stats: array<atomic<u32>, 2>;\n   406→\n   407→fn get_metric(boid: Boid, source: u32) -> f32 {\n   408→  switch (source) {\n   409→    case 0u: { return dot(normalize(boid.heading + vec3f(0.0001, 0.0, 0.0)), vec3f(0.3, 0.4, 0.3)) + 0.5; }\n   410→    case 1u: { return boid.speed; }\n   411→    case 2u: { return boid.dir_change; }\n   412→    case 3u: { return boid.neighbor_count; }\n   413→    case 4u: { return (boid.pos.y + 50.0) / 100.0; }\n   414→    case 5u: { return length(boid.pos) / 50.0; }\n   415→    case 6u: { return boid.flock_alignment * 0.5 + 0.5; }\n   416→    case 7u: { return boid.sep_pressure; }\n   417→    case 8u: { return boid.density; }\n   418→    case 9u: { return 0.5; }\n   419→    default: { return 0.5; }\n   420→  }\n   421→}\n   422→\n   423→@compute @workgroup_size(64)\n   424→fn clear_stats(@builtin(global_invocation_id) id: vec3u) {\n   425→  if (id.x == 0u) {\n   426→    atomicStore(&stats[0], bitcast<u32>(1e10));\n   427→    atomicStore(&stats[1], 0u);\n   428→  }\n   429→}\n   430→\n   431→@compute @workgroup_size(64)\n   432→fn compute_stats(@builtin(global_invocation_id) id: vec3u) {\n   433→  let i = id.x;\n   434→  if (i >= params.num_boids) { return; }\n   435→  let val = get_metric(boids_src[i], params.color_source);\n   436→  let val_bits = bitcast<u32>(val);\n   437→  atomicMin(&stats[0], val_bits);\n   438→  atomicMax(&stats[1], val_bits);\n   439→}\n   440→\n   441→// === Murmuration Quality Metrics ===\n   442→// Computes behavioral metrics for evaluating murmuration quality.\n   443→// Uses @group(1) @binding(1) for a metrics buffer (separate from auto-range stats).\n   444→// 16 atomic u32 slots, interpreted as f32 via bitcast accumulation.\n   445→\n   446→@group(1) @binding(1) var<storage, read_write> metrics: array<atomic<u32>, 16>;\n   447→\n   448→// Slots:\n   449→// 0: count of boids with >= 5 neighbors (cohesion)\n   450→// 1: sum of neighbor_count (for avg)\n   451→// 2: sum of velocity_correlation (dot products)\n   452→// 3: sum of pos.x\n   453→// 4: sum of pos.y\n   454→// 5: sum of pos.z\n   455→// 6: sum of pos.x^2\n   456→// 7: sum of pos.y^2\n   457→// 8: sum of pos.z^2\n   458→// 9: sum of neighbor_count^2 (for variance)\n   459→// 10: count of boids processed\n   460→\n   461→@compute @workgroup_size(64)\n   462→fn clear_metrics(@builtin(global_invocation_id) id: vec3u) {\n   463→  if (id.x == 0u) {\n   464→    for (var k = 0u; k < 16u; k++) {\n   465→      atomicStore(&metrics[k], 0u);\n   466→    }\n   467→  }\n   468→}\n   469→\n   470→// Atomic float add via CAS loop\n   471→fn atomic_add_f32(slot: u32, val: f32) {\n   472→  var old = atomicLoad(&metrics[slot]);\n   473→  loop {\n   474→    let new_val = bitcast<f32>(old) + val;\n   475→    let result = atomicCompareExchangeWeak(&metrics[slot], old, bitcast<u32>(new_val));\n   476→    if (result.exchanged) { break; }\n   477→    old = result.old_value;\n   478→  }\n   479→}\n   480→\n   481→@compute @workgroup_size(64)\n   482→fn compute_metrics(@builtin(global_invocation_id) id: vec3u) {\n   483→  let i = id.x;\n   484→  if (i >= params.num_boids) { return; }\n   485→\n   486→  let boid = boids_src[i];\n   487→\n   488→  // Cohesion: count boids with >= 5 neighbors\n   489→  if (boid.neighbor_count >= 5.0) {\n   490→    atomicAdd(&metrics[0], 1u);\n   491→  }\n   492→\n   493→  // Neighbor count sum\n   494→  atomic_add_f32(1u, boid.neighbor_count);\n   495→\n   496→  // Velocity correlation (flock_alignment is already dot(my_vel, avg_neighbor_vel))\n   497→  atomic_add_f32(2u, boid.flock_alignment);\n   498→\n   499→  // Position sums for covariance\n   500→  atomic_add_f32(3u, boid.pos.x);\n   501→  atomic_add_f32(4u, boid.pos.y);\n   502→  atomic_add_f32(5u, boid.pos.z);\n   503→  atomic_add_f32(6u, boid.pos.x * boid.pos.x);\n   504→  atomic_add_f32(7u, boid.pos.y * boid.pos.y);\n   505→  atomic_add_f32(8u, boid.pos.z * boid.pos.z);\n   506→\n   507→  // Neighbor count squared for variance\n   508→  atomic_add_f32(9u, boid.neighbor_count * boid.neighbor_count);\n   509→\n   510→  // Total count\n   511→  atomicAdd(&metrics[10], 1u);\n   512→}\n   513→"}]},"parent_tool_use_id":null,"session_id":"ab277b0e-46f8-4888-a52e-c14b4b8bde67","uuid":"1b312e46-cb8b-4857-abcf-77f64422e951","timestamp":"2026-03-23T19:02:23.973Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/aaronlemke/AI/Murmuration/shader.wgsl","content":"// === 3D Murmuration Compute Shader — Topological Neighbor Model ===\n// Based on empirical starling research: birds track their nearest 7 neighbors,\n// not all within a fixed radius. This produces realistic wave propagation,\n// sharp flock edges, and coordinated turns.\n\nstruct SimParams {\n  num_boids: u32,\n  grid_size: u32,\n  grid_cells: u32,\n  world_size: f32,\n  cell_size: f32,\n  visual_range: f32,\n  visual_range_sq: f32,\n  separation_dist: f32,\n  separation_dist_sq: f32,\n  align_factor: f32,\n  cohesion_factor: f32,\n  separation_factor: f32,\n  max_speed: f32,\n  min_speed: f32,\n  dt: f32,\n  turn_factor: f32,\n  smoothing: f32,\n  sim_speed: f32,\n  size_randomness: f32,\n  drag_factor: f32,\n  gradient_id: u32,\n  color_source: u32,\n  sphere_radius: f32,\n  frame_count: u32,\n}\n\nstruct Boid {\n  pos: vec3f,\n  size_factor: f32,\n  vel: vec3f,\n  speed: f32,\n  heading: vec3f,\n  neighbor_count: f32,\n  dir_change: f32,\n  flock_alignment: f32,\n  sep_pressure: f32,\n  density: f32,\n}\n\n@group(0) @binding(0) var<uniform> params: SimParams;\n@group(0) @binding(1) var<storage, read_write> boids_src: array<Boid>;\n@group(0) @binding(2) var<storage, read_write> boids_dst: array<Boid>;\n@group(0) @binding(3) var<storage, read_write> cell_counts: array<atomic<u32>>;\n@group(0) @binding(4) var<storage, read_write> cell_offsets: array<u32>;\n@group(0) @binding(5) var<storage, read_write> boid_cells: array<u32>;\n@group(0) @binding(6) var<storage, read_write> sorted_indices: array<u32>;\n@group(0) @binding(7) var<storage, read_write> scatter_counters: array<atomic<u32>>;\n\nfn get_cell(pos: vec3f) -> vec3u {\n  let half = params.world_size * 0.5;\n  return vec3u(clamp(\n    vec3i(floor((pos + vec3f(half)) / params.cell_size)),\n    vec3i(0),\n    vec3i(i32(params.grid_size) - 1)\n  ));\n}\n\nfn cell_index(c: vec3u) -> u32 {\n  return c.x + c.y * params.grid_size + c.z * params.grid_size * params.grid_size;\n}\n\n@compute @workgroup_size(64)\nfn clear_grid(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.grid_cells) { return; }\n  atomicStore(&cell_counts[i], 0u);\n  atomicStore(&scatter_counters[i], 0u);\n}\n\n@compute @workgroup_size(64)\nfn assign_cells(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.num_boids) { return; }\n  let cell = cell_index(get_cell(boids_src[i].pos));\n  boid_cells[i] = cell;\n  atomicAdd(&cell_counts[cell], 1u);\n}\n\nconst SCAN_WG: u32 = 256u;\nvar<workgroup> scan_sums: array<u32, 256>;\n\n@compute @workgroup_size(256)\nfn prefix_sum(@builtin(local_invocation_id) lid: vec3u) {\n  let tid = lid.x;\n  let chunk = (params.grid_cells + SCAN_WG - 1u) / SCAN_WG;\n  let start = tid * chunk;\n  let end = min(start + chunk, params.grid_cells);\n  var local_total = 0u;\n  for (var i = start; i < end; i++) {\n    let count = atomicLoad(&cell_counts[i]);\n    cell_offsets[i] = local_total;\n    local_total += count;\n  }\n  scan_sums[tid] = local_total;\n  workgroupBarrier();\n  for (var stride = 1u; stride < SCAN_WG; stride *= 2u) {\n    let val = select(0u, scan_sums[tid - stride], tid >= stride);\n    workgroupBarrier();\n    scan_sums[tid] += val;\n    workgroupBarrier();\n  }\n  let prefix = select(0u, scan_sums[tid - 1u], tid > 0u);\n  for (var i = start; i < end; i++) {\n    cell_offsets[i] += prefix;\n  }\n}\n\n@compute @workgroup_size(64)\nfn scatter(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.num_boids) { return; }\n  let cell = boid_cells[i];\n  let local_offset = atomicAdd(&scatter_counters[cell], 1u);\n  sorted_indices[cell_offsets[cell] + local_offset] = i;\n}\n\n// === Topological Neighbor Flocking ===\n// Find the K nearest neighbors (K=7 for alignment/cohesion, closest 1 for avoidance)\n// Uses the spatial hash to find candidates, then keeps only the K closest.\n\nconst K_NEIGHBORS: u32 = 7u;\n\n@compute @workgroup_size(64)\nfn flock(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.num_boids) { return; }\n\n  let boid = boids_src[i];\n  let my_grid = get_cell(boid.pos);\n  let gs = i32(params.grid_size);\n  let mg = vec3i(my_grid);\n\n  // Track K nearest neighbors by distance (insertion sort into small array)\n  // Store squared distances and indices\n  var nearest_d2: array<f32, 7>;   // distances squared\n  var nearest_idx: array<u32, 7>;  // boid indices\n  var n_found = 0u;\n\n  // Initialize with large distances\n  for (var k = 0u; k < K_NEIGHBORS; k++) {\n    nearest_d2[k] = 1e10;\n    nearest_idx[k] = 0u;\n  }\n\n  // Search 3x3x3 neighborhood (27 cells)\n  let lo = max(mg - vec3i(1), vec3i(0));\n  let hi = min(mg + vec3i(1), vec3i(gs - 1));\n\n  var total_candidates = 0u;\n\n  for (var nz = lo.z; nz <= hi.z; nz++) {\n    let zoff = u32(nz) * params.grid_size * params.grid_size;\n    for (var ny = lo.y; ny <= hi.y; ny++) {\n      let yzoff = u32(ny) * params.grid_size + zoff;\n      for (var nx = lo.x; nx <= hi.x; nx++) {\n        let nc = u32(nx) + yzoff;\n        let start = cell_offsets[nc];\n        let end_val = select(cell_offsets[nc + 1u], params.num_boids, nc + 1u >= params.grid_cells);\n        if (start >= end_val) { continue; }\n\n        for (var j = start; j < end_val; j++) {\n          let other_idx = sorted_indices[j];\n          if (other_idx == i) { continue; }\n\n          let other_pos = boids_src[other_idx].pos;\n          let diff = boid.pos - other_pos;\n          let d2 = dot(diff, diff);\n\n          // Pre-filter by visual range before K-nearest sort\n          if (d2 > params.visual_range_sq) { continue; }\n\n          total_candidates++;\n\n          // Insert into sorted K-nearest if closer than current worst\n          if (d2 < nearest_d2[K_NEIGHBORS - 1u]) {\n            // Find insertion position\n            var pos = K_NEIGHBORS - 1u;\n            for (var k = 0u; k < K_NEIGHBORS - 1u; k++) {\n              if (d2 < nearest_d2[k]) {\n                pos = k;\n                break;\n              }\n            }\n            // Shift larger entries down\n            for (var k = K_NEIGHBORS - 1u; k > pos; k--) {\n              nearest_d2[k] = nearest_d2[k - 1u];\n              nearest_idx[k] = nearest_idx[k - 1u];\n            }\n            nearest_d2[pos] = d2;\n            nearest_idx[pos] = other_idx;\n            n_found = min(n_found + 1u, K_NEIGHBORS);\n          }\n        }\n      }\n    }\n  }\n\n  // === Apply flocking rules using topological neighbors ===\n  var new_vel = boid.vel;\n\n  // Avoidance: only the 1 nearest neighbor\n  var sep_force = vec3f(0.0);\n  if (n_found > 0u && nearest_d2[0] < params.separation_dist_sq) {\n    let other_pos = boids_src[nearest_idx[0]].pos;\n    let diff = boid.pos - other_pos;\n    let d2 = nearest_d2[0];\n    sep_force = diff * (1.0 - d2 / params.separation_dist_sq);\n    new_vel += sep_force * params.separation_factor * 2.0; // stronger since only 1 neighbor\n  }\n\n  // Alignment + Cohesion: all K neighbors\n  var ali = vec3f(0.0);\n  var coh = vec3f(0.0);\n  var avg_vel = vec3f(0.0);\n  if (n_found > 0u) {\n    for (var k = 0u; k < min(n_found, K_NEIGHBORS); k++) {\n      let other = boids_src[nearest_idx[k]];\n      ali += other.vel;\n      coh += other.pos;\n    }\n    let nf = f32(min(n_found, K_NEIGHBORS));\n    avg_vel = ali / nf;\n    let avg_pos = coh / nf;\n    new_vel += (avg_vel - boid.vel) * params.align_factor;\n    new_vel += (avg_pos - boid.pos) * params.cohesion_factor;\n  }\n\n  // === Emergent murmuration forces ===\n  // NO roost attractor, NO predator orbit — purely local interactions\n  // The complex sweeping motion emerges from topological neighbor rules\n  // + rare perturbations that cascade through the flock\n\n  // Gentle gravity (creates oblate/flat flock shape)\n  new_vel.y -= 0.03;\n\n  // Rare strong perturbation: only ~3% of birds per frame\n  // This is the primary driver of non-repetitive motion —\n  // a random bird changes direction, neighbors respond via alignment,\n  // creating a wave that sweeps across the entire flock\n  let perturb_hash = fract(sin(f32(i * 7919u + params.frame_count * 104729u)) * 43758.5);\n  if (perturb_hash < 0.04) {\n    let seed = f32(i * 1973u + params.frame_count * 9277u);\n    let kick = vec3f(\n      fract(sin(seed) * 43758.5) - 0.5,\n      fract(sin(seed * 1.3) * 22578.1) - 0.5,\n      fract(sin(seed * 0.7) * 31415.9) - 0.5\n    ) * 2.5;  // strong kick that cascades via topological links\n    new_vel += kick;\n  }\n\n  // Spherical boundary steering\n  let dist_from_center = length(boid.pos);\n  let r = params.sphere_radius;\n  let soft_zone = r * 0.15;\n  if (dist_from_center > r - soft_zone && dist_from_center > 0.001) {\n    let penetration = (dist_from_center - (r - soft_zone)) / soft_zone;\n    let push = -normalize(boid.pos) * params.turn_factor * clamp(penetration, 0.0, 3.0);\n    new_vel += push;\n  }\n\n  // Turn rate limiter (smooth heading changes — creates wave-like motion)\n  let old_speed = length(boid.vel);\n  var old_dir = boid.vel;\n  if (old_speed > 0.001) { old_dir = old_dir / old_speed; }\n  else { old_dir = vec3f(1.0, 0.0, 0.0); }\n  let desired_speed = length(new_vel);\n  var desired_dir = new_vel;\n  if (desired_speed > 0.001) { desired_dir = desired_dir / desired_speed; }\n  else { desired_dir = old_dir; }\n  let final_dir = normalize(mix(old_dir, desired_dir, params.smoothing));\n\n  // Speed with drag\n  let drag_scale = 1.0 / mix(1.0, boid.size_factor, params.drag_factor);\n  var final_speed = mix(old_speed, desired_speed, 0.15);\n  final_speed = clamp(final_speed, params.min_speed * drag_scale, params.max_speed * drag_scale);\n  new_vel = final_dir * final_speed;\n\n  // Direction change metric\n  let dir_change_val = 1.0 - clamp(dot(old_dir, final_dir), -1.0, 1.0);\n  let effective_dt = params.dt;\n\n  // Write outputs\n  boids_dst[i].pos = boid.pos + new_vel * effective_dt;\n  boids_dst[i].vel = new_vel;\n  boids_dst[i].size_factor = boid.size_factor;\n  boids_dst[i].heading = final_dir;\n  boids_dst[i].speed = final_speed;\n  boids_dst[i].neighbor_count = f32(n_found);\n  boids_dst[i].dir_change = dir_change_val;\n  let vel_d2 = dot(boid.vel, boid.vel);\n  let avg_d2 = dot(avg_vel, avg_vel);\n  boids_dst[i].flock_alignment = select(dot(boid.vel, avg_vel) * inverseSqrt(vel_d2 * avg_d2), 0.0, vel_d2 < 0.001 || avg_d2 < 0.001);\n  boids_dst[i].sep_pressure = length(sep_force);\n  boids_dst[i].density = f32(n_found) / f32(K_NEIGHBORS);\n}\n\n// === Classic Radius-Based Flocking (high performance, simpler behavior) ===\n@compute @workgroup_size(64)\nfn flock_radius(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.num_boids) { return; }\n\n  let boid = boids_src[i];\n  let my_grid = get_cell(boid.pos);\n  let gs = i32(params.grid_size);\n  let mg = vec3i(my_grid);\n  let lo = max(mg - vec3i(1), vec3i(0));\n  let hi = min(mg + vec3i(1), vec3i(gs - 1));\n\n  var sep = vec3f(0.0);\n  var ali = vec3f(0.0);\n  var coh = vec3f(0.0);\n  var n_align = 0u;\n  var n_sep = 0u;\n\n  for (var nz = lo.z; nz <= hi.z; nz++) {\n    let zoff = u32(nz) * params.grid_size * params.grid_size;\n    for (var ny = lo.y; ny <= hi.y; ny++) {\n      let yzoff = u32(ny) * params.grid_size + zoff;\n      for (var nx = lo.x; nx <= hi.x; nx++) {\n        let nc = u32(nx) + yzoff;\n        let start = cell_offsets[nc];\n        let end_val = select(cell_offsets[nc + 1u], params.num_boids, nc + 1u >= params.grid_cells);\n        if (start >= end_val) { continue; }\n        for (var j = start; j < end_val; j++) {\n          let other_idx = sorted_indices[j];\n          if (other_idx == i) { continue; }\n          let other = boids_src[other_idx];\n          let diff = boid.pos - other.pos;\n          let d2 = dot(diff, diff);\n          if (d2 < params.visual_range_sq && d2 > 0.0001) {\n            ali += other.vel;\n            coh += other.pos;\n            n_align++;\n            if (d2 < params.separation_dist_sq) {\n              sep += diff * (1.0 - d2 / params.separation_dist_sq);\n              n_sep++;\n            }\n          }\n        }\n        if (n_align >= 16u) { break; }\n      }\n      if (n_align >= 16u) { break; }\n    }\n    if (n_align >= 16u) { break; }\n  }\n\n  var new_vel = boid.vel;\n  var avg_vel = vec3f(0.0);\n  if (n_align > 0u) {\n    let nf = f32(n_align);\n    avg_vel = ali / nf;\n    let avg_pos = coh / nf;\n    new_vel += (avg_vel - boid.vel) * params.align_factor;\n    new_vel += (avg_pos - boid.pos) * params.cohesion_factor;\n  }\n  if (n_sep > 0u) {\n    new_vel += sep * params.separation_factor;\n  }\n\n  // Spherical boundary\n  let dist_from_center = length(boid.pos);\n  let r = params.sphere_radius;\n  let soft_zone = r * 0.15;\n  if (dist_from_center > r - soft_zone && dist_from_center > 0.001) {\n    let penetration = (dist_from_center - (r - soft_zone)) / soft_zone;\n    new_vel += -normalize(boid.pos) * params.turn_factor * clamp(penetration, 0.0, 3.0);\n  }\n\n  // Turn rate limiter + speed\n  let old_speed = length(boid.vel);\n  var old_dir = boid.vel;\n  if (old_speed > 0.001) { old_dir = old_dir / old_speed; } else { old_dir = vec3f(1.0, 0.0, 0.0); }\n  let desired_speed = length(new_vel);\n  var desired_dir = new_vel;\n  if (desired_speed > 0.001) { desired_dir = desired_dir / desired_speed; } else { desired_dir = old_dir; }\n  let final_dir = normalize(mix(old_dir, desired_dir, params.smoothing));\n  let drag_scale = 1.0 / mix(1.0, boid.size_factor, params.drag_factor);\n  var final_speed = mix(old_speed, desired_speed, 0.15);\n  final_speed = clamp(final_speed, params.min_speed * drag_scale, params.max_speed * drag_scale);\n  new_vel = final_dir * final_speed;\n\n  let dir_change_val = 1.0 - clamp(dot(old_dir, final_dir), -1.0, 1.0);\n  boids_dst[i].pos = boid.pos + new_vel * params.dt;\n  boids_dst[i].vel = new_vel;\n  boids_dst[i].size_factor = boid.size_factor;\n  boids_dst[i].heading = final_dir;\n  boids_dst[i].speed = final_speed;\n  boids_dst[i].neighbor_count = f32(n_align);\n  boids_dst[i].dir_change = dir_change_val;\n  let vel_d2r = dot(boid.vel, boid.vel);\n  let avg_d2r = dot(avg_vel, avg_vel);\n  boids_dst[i].flock_alignment = select(dot(boid.vel, avg_vel) * inverseSqrt(vel_d2r * avg_d2r), 0.0, vel_d2r < 0.001 || avg_d2r < 0.001);\n  boids_dst[i].sep_pressure = length(sep);\n  boids_dst[i].density = f32(n_align) * 0.0625;\n}\n\n// === Auto-range stats ===\n@group(1) @binding(0) var<storage, read_write> stats: array<atomic<u32>, 2>;\n\nfn get_metric(boid: Boid, source: u32) -> f32 {\n  switch (source) {\n    case 0u: { return dot(normalize(boid.heading + vec3f(0.0001, 0.0, 0.0)), vec3f(0.3, 0.4, 0.3)) + 0.5; }\n    case 1u: { return boid.speed; }\n    case 2u: { return boid.dir_change; }\n    case 3u: { return boid.neighbor_count; }\n    case 4u: { return (boid.pos.y + 50.0) / 100.0; }\n    case 5u: { return length(boid.pos) / 50.0; }\n    case 6u: { return boid.flock_alignment * 0.5 + 0.5; }\n    case 7u: { return boid.sep_pressure; }\n    case 8u: { return boid.density; }\n    case 9u: { return 0.5; }\n    default: { return 0.5; }\n  }\n}\n\n@compute @workgroup_size(64)\nfn clear_stats(@builtin(global_invocation_id) id: vec3u) {\n  if (id.x == 0u) {\n    atomicStore(&stats[0], bitcast<u32>(1e10));\n    atomicStore(&stats[1], 0u);\n  }\n}\n\n@compute @workgroup_size(64)\nfn compute_stats(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.num_boids) { return; }\n  let val = get_metric(boids_src[i], params.color_source);\n  let val_bits = bitcast<u32>(val);\n  atomicMin(&stats[0], val_bits);\n  atomicMax(&stats[1], val_bits);\n}\n\n// === Murmuration Quality Metrics ===\n// Computes behavioral metrics for evaluating murmuration quality.\n// Uses @group(1) @binding(1) for a metrics buffer (separate from auto-range stats).\n// 16 atomic u32 slots, interpreted as f32 via bitcast accumulation.\n\n@group(1) @binding(1) var<storage, read_write> metrics: array<atomic<u32>, 16>;\n\n// Slots:\n// 0: count of boids with >= 5 neighbors (cohesion)\n// 1: sum of neighbor_count (for avg)\n// 2: sum of velocity_correlation (dot products)\n// 3: sum of pos.x\n// 4: sum of pos.y\n// 5: sum of pos.z\n// 6: sum of pos.x^2\n// 7: sum of pos.y^2\n// 8: sum of pos.z^2\n// 9: sum of neighbor_count^2 (for variance)\n// 10: count of boids processed\n\n@compute @workgroup_size(64)\nfn clear_metrics(@builtin(global_invocation_id) id: vec3u) {\n  if (id.x == 0u) {\n    for (var k = 0u; k < 16u; k++) {\n      atomicStore(&metrics[k], 0u);\n    }\n  }\n}\n\n// Atomic float add via CAS loop\nfn atomic_add_f32(slot: u32, val: f32) {\n  var old = atomicLoad(&metrics[slot]);\n  loop {\n    let new_val = bitcast<f32>(old) + val;\n    let result = atomicCompareExchangeWeak(&metrics[slot], old, bitcast<u32>(new_val));\n    if (result.exchanged) { break; }\n    old = result.old_value;\n  }\n}\n\n@compute @workgroup_size(64)\nfn compute_metrics(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.num_boids) { return; }\n\n  let boid = boids_src[i];\n\n  // Cohesion: count boids with >= 5 neighbors\n  if (boid.neighbor_count >= 5.0) {\n    atomicAdd(&metrics[0], 1u);\n  }\n\n  // Neighbor count sum\n  atomic_add_f32(1u, boid.neighbor_count);\n\n  // Velocity correlation (flock_alignment is already dot(my_vel, avg_neighbor_vel))\n  atomic_add_f32(2u, boid.flock_alignment);\n\n  // Position sums for covariance\n  atomic_add_f32(3u, boid.pos.x);\n  atomic_add_f32(4u, boid.pos.y);\n  atomic_add_f32(5u, boid.pos.z);\n  atomic_add_f32(6u, boid.pos.x * boid.pos.x);\n  atomic_add_f32(7u, boid.pos.y * boid.pos.y);\n  atomic_add_f32(8u, boid.pos.z * boid.pos.z);\n\n  // Neighbor count squared for variance\n  atomic_add_f32(9u, boid.neighbor_count * boid.neighbor_count);\n\n  // Total count\n  atomicAdd(&metrics[10], 1u);\n}\n","numLines":513,"startLine":1,"totalLines":513}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013uhQe8qXS8eTMYVzD2ZqpS","type":"tool_result","content":"     1→<!DOCTYPE html>\n     2→<html lang=\"en\">\n     3→<head>\n     4→<meta charset=\"utf-8\">\n     5→<title>3D Murmuration</title>\n     6→<style>\n     7→  * { margin: 0; padding: 0; box-sizing: border-box; }\n     8→  body { background: #000; overflow: hidden; font-family: system-ui, sans-serif; }\n     9→  canvas { display: block; width: 100vw; height: 100vh; }\n    10→  #hud {\n    11→    position: fixed; top: 12px; left: 16px;\n    12→    color: #aac; font: 14px/1.4 monospace;\n    13→    pointer-events: none; text-shadow: 0 1px 3px #000;\n    14→  }\n    15→  #error {\n    16→    position: fixed; inset: 0; display: flex; align-items: center; justify-content: center;\n    17→    color: #f88; font: 18px/1.6 system-ui; text-align: center; padding: 2em;\n    18→  }\n    19→\n    20→  /* --- Settings panel --- */\n    21→  #panel {\n    22→    position: fixed; top: 12px; right: 16px; width: 280px;\n    23→    z-index: 10; user-select: none;\n    24→  }\n    25→  #panel-toggle {\n    26→    display: block; width: 100%; padding: 8px 14px;\n    27→    background: rgba(20,20,40,0.85); color: #aac; border: 1px solid rgba(100,100,160,0.3);\n    28→    border-radius: 6px; font: 13px/1 system-ui; cursor: pointer; text-align: left;\n    29→    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);\n    30→  }\n    31→  #panel-toggle:hover { background: rgba(30,30,60,0.9); }\n    32→  #panel-toggle::after { content: ' \\u25BC'; float: right; font-size: 10px; }\n    33→  #panel.open #panel-toggle::after { content: ' \\u25B2'; }\n    34→  #panel-body {\n    35→    max-height: 0; overflow: hidden; transition: max-height 0.3s ease;\n    36→    background: rgba(10,10,25,0.88); border: 1px solid rgba(100,100,160,0.25);\n    37→    border-top: none; border-radius: 0 0 6px 6px;\n    38→    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);\n    39→  }\n    40→  #panel.open #panel-body { max-height: 700px; }\n    41→  #panel-inner { padding: 10px 14px 14px; }\n    42→\n    43→  .param-row {\n    44→    display: flex; align-items: center; gap: 6px; margin-bottom: 6px;\n    45→  }\n    46→  .param-row label {\n    47→    flex: 0 0 90px; color: #889; font-size: 11px; text-align: right;\n    48→  }\n    49→  .param-row input[type=range] {\n    50→    flex: 1; height: 4px; accent-color: #668cff;\n    51→  }\n    52→  .param-row .val {\n    53→    flex: 0 0 42px; color: #bbd; font: 11px monospace; text-align: right;\n    54→  }\n    55→\n    56→  .preset-row {\n    57→    display: flex; gap: 6px; margin-bottom: 10px; align-items: center;\n    58→  }\n    59→  .preset-row select {\n    60→    flex: 1; padding: 4px 6px; font-size: 12px;\n    61→    background: rgba(30,30,60,0.9); color: #bbd; border: 1px solid rgba(100,100,160,0.3);\n    62→    border-radius: 4px;\n    63→  }\n    64→  .preset-row button {\n    65→    padding: 4px 8px; font-size: 11px; cursor: pointer;\n    66→    background: rgba(40,40,80,0.8); color: #aac; border: 1px solid rgba(100,100,160,0.3);\n    67→    border-radius: 4px;\n    68→  }\n    69→  .preset-row button:hover { background: rgba(60,60,100,0.9); }\n    70→  .section-label {\n    71→    color: #667; font-size: 10px; text-transform: uppercase; letter-spacing: 1px;\n    72→    margin: 8px 0 4px; padding-bottom: 2px; border-bottom: 1px solid rgba(100,100,160,0.15);\n    73→  }\n    74→</style>\n    75→</head>\n    76→<body>\n    77→<canvas id=\"c\"></canvas>\n    78→<div id=\"hud\"></div>\n    79→\n    80→<div id=\"panel\">\n    81→  <button id=\"panel-toggle\">Settings</button>\n    82→  <div id=\"panel-body\"><div id=\"panel-inner\">\n    83→    <div class=\"section-label\">Presets</div>\n    84→    <div class=\"preset-row\">\n    85→      <select id=\"preset-select\"></select>\n    86→      <button id=\"preset-save\" title=\"Save current as new preset\">Save</button>\n    87→      <button id=\"preset-del\" title=\"Delete selected user preset\">Del</button>\n    88→    </div>\n    89→    <div class=\"section-label\">Visuals</div>\n    90→    <div class=\"param-row\">\n    91→      <label>Gradient</label>\n    92→      <select id=\"gradient-select\" style=\"flex:1; padding:3px 6px; font-size:12px; background:rgba(30,30,60,0.9); color:#bbd; border:1px solid rgba(100,100,160,0.3); border-radius:4px;\">\n    93→        <option value=\"0\">Viridis</option>\n    94→        <option value=\"1\">Inferno</option>\n    95→        <option value=\"2\">Magma</option>\n    96→        <option value=\"3\">Plasma</option>\n    97→        <option value=\"4\">Turbo</option>\n    98→        <option value=\"5\">Cividis</option>\n    99→        <option value=\"6\">Coolwarm</option>\n   100→        <option value=\"7\">Spectral</option>\n   101→        <option value=\"8\">Hot</option>\n   102→        <option value=\"9\">Ocean</option>\n   103→      </select>\n   104→    </div>\n   105→    <div class=\"param-row\">\n   106→      <label>Color Source</label>\n   107→      <select id=\"color-source-select\" style=\"flex:1; padding:3px 6px; font-size:12px; background:rgba(30,30,60,0.9); color:#bbd; border:1px solid rgba(100,100,160,0.3); border-radius:4px;\">\n   108→        <option value=\"0\">Velocity Direction</option>\n   109→        <option value=\"1\">Speed</option>\n   110→        <option value=\"2\">Direction Change</option>\n   111→        <option value=\"3\">Neighbor Count</option>\n   112→        <option value=\"4\">Altitude</option>\n   113→        <option value=\"5\">Distance from Center</option>\n   114→        <option value=\"6\">Flock Alignment</option>\n   115→        <option value=\"7\">Separation Pressure</option>\n   116→        <option value=\"8\">Local Density</option>\n   117→        <option value=\"9\">Boid ID</option>\n   118→      </select>\n   119→    </div>\n   120→    <div class=\"param-row\">\n   121→      <label>Gain</label>\n   122→      <input type=\"range\" id=\"gain-slider\" min=\"0.0\" max=\"1.0\" step=\"0.01\" value=\"0.5\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n   123→      <span class=\"val\" id=\"gain-val\">0.50</span>\n   124→    </div>\n   125→    <div class=\"param-row\">\n   126→      <label>Auto-Range</label>\n   127→      <label style=\"flex:1; color:#aab; font-size:12px; cursor:pointer;\">\n   128→        <input type=\"checkbox\" id=\"auto-range-cb\" style=\"accent-color:#668cff; margin-right:4px;\">\n   129→        Normalize to data range\n   130→      </label>\n   131→    </div>\n   132→    <div class=\"param-row\">\n   133→      <label>Brightness</label>\n   134→      <input type=\"range\" id=\"brightness-slider\" min=\"0.1\" max=\"5.0\" step=\"0.05\" value=\"1.0\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n   135→      <span class=\"val\" id=\"brightness-val\">1.00</span>\n   136→    </div>\n   137→    <div class=\"param-row\">\n   138→      <label>Sphere Radius</label>\n   139→      <input type=\"range\" id=\"sphere-radius-slider\" min=\"20\" max=\"300\" step=\"5\" value=\"100\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n   140→      <span class=\"val\" id=\"sphere-radius-val\">100</span>\n   141→    </div>\n   142→    <div class=\"param-row\">\n   143→      <label>Neighbor Mode</label>\n   144→      <select id=\"neighbor-mode-select\" style=\"flex:1; padding:3px 6px; font-size:12px; background:rgba(30,30,60,0.9); color:#bbd; border:1px solid rgba(100,100,160,0.3); border-radius:4px;\">\n   145→        <option value=\"0\">Topological (K=7 nearest)</option>\n   146→        <option value=\"1\">Radius (classic, fast)</option>\n   147→      </select>\n   148→    </div>\n   149→    <div class=\"section-label\">Rendering</div>\n   150→    <div class=\"param-row\">\n   151→      <label>Render Mode</label>\n   152→      <select id=\"render-mode-select\" style=\"flex:1; padding:3px 6px; font-size:12px; background:rgba(30,30,60,0.9); color:#bbd; border:1px solid rgba(100,100,160,0.3); border-radius:4px;\">\n   153→        <option value=\"0\">Tetrahedron</option>\n   154→        <option value=\"1\">Billboard (Additive)</option>\n   155→        <option value=\"2\">Billboard (Opaque)</option>\n   156→        <option value=\"3\">Reflective Tetrahedron</option>\n   157→        <option value=\"4\">Reflective Billboard</option>\n   158→      </select>\n   159→    </div>\n   160→    <div class=\"param-row\">\n   161→      <label>Falloff</label>\n   162→      <input type=\"range\" id=\"falloff-slider\" min=\"0.1\" max=\"3.0\" step=\"0.05\" value=\"1.0\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n   163→      <span class=\"val\" id=\"falloff-val\">1.00</span>\n   164→    </div>\n   165→    <div class=\"param-row\">\n   166→      <label>Particle Scale</label>\n   167→      <input type=\"range\" id=\"particle-scale-slider\" min=\"0.05\" max=\"5.0\" step=\"0.05\" value=\"1.0\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n   168→      <span class=\"val\" id=\"particle-scale-val\">1.00</span>\n   169→    </div>\n   170→    <div class=\"param-row\">\n   171→      <label>Particle Count</label>\n   172→      <input type=\"range\" id=\"particle-count-slider\" min=\"3\" max=\"6.3\" step=\"0.01\" value=\"3.7\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n   173→      <span class=\"val\" id=\"particle-count-val\">5,000</span>\n   174→    </div>\n   175→    <div class=\"param-row\">\n   176→      <label>Bloom</label>\n   177→      <label style=\"flex:1; color:#aab; font-size:12px; cursor:pointer;\">\n   178→        <input type=\"checkbox\" id=\"bloom-cb\" style=\"accent-color:#668cff; margin-right:4px;\">\n   179→        Enable bloom\n   180→      </label>\n   181→    </div>\n   182→    <div class=\"param-row\">\n   183→      <label>Bloom Thresh</label>\n   184→      <input type=\"range\" id=\"bloom-threshold-slider\" min=\"0.1\" max=\"2.0\" step=\"0.05\" value=\"0.8\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n   185→      <span class=\"val\" id=\"bloom-threshold-val\">0.80</span>\n   186→    </div>\n   187→    <div class=\"param-row\">\n   188→      <label>Bloom Intensity</label>\n   189→      <input type=\"range\" id=\"bloom-intensity-slider\" min=\"0.0\" max=\"3.0\" step=\"0.05\" value=\"0.5\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n   190→      <span class=\"val\" id=\"bloom-intensity-val\">0.50</span>\n   191→    </div>\n   192→    <div class=\"section-label\">Physics</div>\n   193→    <div id=\"sliders\"></div>\n   194→  </div></div>\n   195→</div>\n   196→\n   197→<script type=\"module\">\n   198→// Capture errors and post to server for debugging\n   199→window.addEventListener('error', e => {\n   200→  fetch('/api/bench_result', { method: 'POST',\n   201→    headers: { 'Content-Type': 'application/json' },\n   202→    body: JSON.stringify({ error: e.message, file: e.filename, line: e.lineno }),\n   203→  }).catch(() => {});\n   204→});\n   205→window.addEventListener('unhandledrejection', e => {\n   206→  fetch('/api/bench_result', { method: 'POST',\n   207→    headers: { 'Content-Type': 'application/json' },\n   208→    body: JSON.stringify({ error: String(e.reason) }),\n   209→  }).catch(() => {});\n   210→});\n   211→\n   212→import { createSimulation } from './simulation.js';\n   213→import { createRenderer }   from './renderer.js';\n   214→\n   215→// Benchmark mode: ?boids=N runs a measured benchmark\n   216→const urlParams = new URLSearchParams(location.search);\n   217→const benchmarkBoids = urlParams.get('boids') ? parseInt(urlParams.get('boids')) : null;\n   218→\n   219→let NUM_BOIDS = benchmarkBoids || 40000;\n   220→const WORLD_SIZE = 100;\n   221→\n   222→// ============================================================\n   223→// Built-in presets\n   224→// ============================================================\n   225→const BUILTIN_PRESETS = {\n   226→  'Murmuration': {\n   227→    simSpeed: 1.0, sizeRandomness: 0.0, dragFactor: 0.0, sphereRadius: 120,\n   228→    visualRange: 15.0, separationDist: 2.0, alignFactor: 0.12,\n   229→    cohesionFactor: 0.003, separationFactor: 0.08,\n   230→    maxSpeed: 10.0, minSpeed: 3.0, turnFactor: 0.3, smoothing: 0.10,\n   231→  },\n   232→  'Tight Murmuration': {\n   233→    simSpeed: 1.0, sizeRandomness: 0.0, dragFactor: 0.0, sphereRadius: 80,\n   234→    visualRange: 10.0, separationDist: 1.5, alignFactor: 0.15,\n   235→    cohesionFactor: 0.005, separationFactor: 0.12,\n   236→    maxSpeed: 12.0, minSpeed: 5.0, turnFactor: 0.4, smoothing: 0.08,\n   237→  },\n   238→  'Lazy Murmuration': {\n   239→    simSpeed: 1.0, sizeRandomness: 0.0, dragFactor: 0.0, sphereRadius: 150,\n   240→    visualRange: 20.0, separationDist: 3.0, alignFactor: 0.08,\n   241→    cohesionFactor: 0.001, separationFactor: 0.05,\n   242→    maxSpeed: 5.0, minSpeed: 1.5, turnFactor: 0.2, smoothing: 0.15,\n   243→  },\n   244→  'Swarm': {\n   245→    simSpeed: 1.0, sizeRandomness: 0.3, dragFactor: 0.5, sphereRadius: 100,\n   246→    visualRange: 8.0, separationDist: 0.8, alignFactor: 0.01,\n   247→    cohesionFactor: 0.02, separationFactor: 0.3,\n   248→    maxSpeed: 5.0, minSpeed: 0.5, turnFactor: 0.4, smoothing: 0.15,\n   249→  },\n   250→  'Predator Evasion': {\n   251→    simSpeed: 1.0, sizeRandomness: 0.0, dragFactor: 0.0, sphereRadius: 120,\n   252→    visualRange: 12.0, separationDist: 3.0, alignFactor: 0.10,\n   253→    cohesionFactor: 0.003, separationFactor: 0.15,\n   254→    maxSpeed: 14.0, minSpeed: 5.0, turnFactor: 0.5, smoothing: 0.06,\n   255→  },\n   256→};\n   257→\n   258→// Slider definitions: [key, label, min, max, step]\n   259→const SLIDER_DEFS = [\n   260→  ['simSpeed',        'Sim Speed',     0.1,  10.0,  0.1],\n   261→  ['sizeRandomness',  'Size Random',   0.0,   1.0,  0.05],\n   262→  ['dragFactor',      'Size Drag',     0.0,   1.0,  0.05],\n   263→  ['visualRange',     'Visual Range',  1.0,  10.0,  0.1],\n   264→  ['separationDist',  'Sep. Dist',     0.3,   5.0,  0.1],\n   265→  ['alignFactor',     'Alignment',     0.001, 0.2,  0.001],\n   266→  ['cohesionFactor',  'Cohesion',      0.0005,0.05, 0.0005],\n   267→  ['separationFactor','Separation',    0.05,  2.0,  0.01],\n   268→  ['maxSpeed',        'Max Speed',     1.0,  50.0,  0.5],\n   269→  ['minSpeed',        'Min Speed',     0.1,   5.0,  0.1],\n   270→  ['turnFactor',      'Turn Factor',   0.05,  1.0,  0.05],\n   271→  ['smoothing',       'Turn Rate',     0.01,  0.3,  0.005],\n   272→];\n   273→\n   274→// ============================================================\n   275→// WebGPU init\n   276→// ============================================================\n   277→if (!navigator.gpu) { showError('WebGPU not supported. Use Chrome 113+ or Edge 113+.'); throw ''; }\n   278→const adapter = await navigator.gpu.requestAdapter();\n   279→if (!adapter) { showError('No WebGPU adapter found.'); throw ''; }\n   280→const device = await adapter.requestDevice();\n   281→\n   282→const canvas = document.getElementById('c');\n   283→const ctx    = canvas.getContext('webgpu');\n   284→\n   285→function resize() {\n   286→  const dpr = devicePixelRatio;\n   287→  canvas.width  = Math.floor(innerWidth * dpr);\n   288→  canvas.height = Math.floor(innerHeight * dpr);\n   289→}\n   290→resize();\n   291→\n   292→let simulation, renderer;\n   293→try {\n   294→  simulation = await createSimulation(device, { numBoids: NUM_BOIDS, worldSize: WORLD_SIZE });\n   295→  renderer = await createRenderer(device, ctx, simulation);\n   296→} catch(e) {\n   297→  showError('Init failed: ' + e.message);\n   298→  throw e;\n   299→}\n   300→addEventListener('resize', () => { resize(); renderer.resize(); });\n   301→\n   302→// ============================================================\n   303→// Current params state\n   304→// ============================================================\n   305→let currentParams = { ...BUILTIN_PRESETS['Murmuration'] };\n   306→simulation.setParams(currentParams);\n   307→simulation.applySizeRandomness(currentParams.sizeRandomness ?? 0);\n   308→\n   309→// ============================================================\n   310→// UI: Sliders\n   311→// ============================================================\n   312→const sliderEls = {};\n   313→const slidersDiv = document.getElementById('sliders');\n   314→\n   315→for (const [key, label, min, max, step] of SLIDER_DEFS) {\n   316→  const row = document.createElement('div');\n   317→  row.className = 'param-row';\n   318→\n   319→  const lbl = document.createElement('label');\n   320→  lbl.textContent = label;\n   321→\n   322→  const input = document.createElement('input');\n   323→  input.type = 'range';\n   324→  input.min = min; input.max = max; input.step = step;\n   325→  input.value = currentParams[key];\n   326→\n   327→  const val = document.createElement('span');\n   328→  val.className = 'val';\n   329→  val.textContent = fmtVal(currentParams[key], step);\n   330→\n   331→  input.addEventListener('input', () => {\n   332→    const v = parseFloat(input.value);\n   333→    currentParams[key] = v;\n   334→    val.textContent = fmtVal(v, step);\n   335→    simulation.setParams(currentParams);\n   336→    if (key === 'sizeRandomness') simulation.applySizeRandomness(v);\n   337→  });\n   338→\n   339→  row.append(lbl, input, val);\n   340→  slidersDiv.appendChild(row);\n   341→  sliderEls[key] = { input, val, step };\n   342→}\n   343→\n   344→function fmtVal(v, step) {\n   345→  const dec = step < 0.01 ? 4 : step < 0.1 ? 3 : step < 1 ? 2 : 1;\n   346→  return v.toFixed(dec);\n   347→}\n   348→\n   349→function syncSliders() {\n   350→  for (const [key] of SLIDER_DEFS) {\n   351→    const el = sliderEls[key];\n   352→    el.input.value = currentParams[key];\n   353→    el.val.textContent = fmtVal(currentParams[key], el.step);\n   354→  }\n   355→}\n   356→\n   357→// ============================================================\n   358→// UI: Presets\n   359→// ============================================================\n   360→const LS_KEY = 'murmuration-user-presets';\n   361→const presetSelect = document.getElementById('preset-select');\n   362→\n   363→function loadUserPresets() {\n   364→  try { return JSON.parse(localStorage.getItem(LS_KEY)) || {}; } catch { return {}; }\n   365→}\n   366→function saveUserPresets(obj) {\n   367→  localStorage.setItem(LS_KEY, JSON.stringify(obj));\n   368→}\n   369→\n   370→function populatePresetDropdown() {\n   371→  presetSelect.innerHTML = '';\n   372→  // Built-in\n   373→  for (const name of Object.keys(BUILTIN_PRESETS)) {\n   374→    const opt = document.createElement('option');\n   375→    opt.value = name; opt.textContent = name;\n   376→    presetSelect.appendChild(opt);\n   377→  }\n   378→  // User\n   379→  const userPresets = loadUserPresets();\n   380→  const userNames = Object.keys(userPresets);\n   381→  if (userNames.length) {\n   382→    const sep = document.createElement('option');\n   383→    sep.disabled = true; sep.textContent = '--- User Presets ---';\n   384→    presetSelect.appendChild(sep);\n   385→    for (const name of userNames) {\n   386→      const opt = document.createElement('option');\n   387→      opt.value = `user:${name}`; opt.textContent = name;\n   388→      presetSelect.appendChild(opt);\n   389→    }\n   390→  }\n   391→}\n   392→\n   393→function applyPreset(name) {\n   394→  let params;\n   395→  if (name.startsWith('user:')) {\n   396→    params = loadUserPresets()[name.slice(5)];\n   397→  } else {\n   398→    params = BUILTIN_PRESETS[name];\n   399→  }\n   400→  if (!params) return;\n   401→  currentParams = { ...params };\n   402→  simulation.setParams(currentParams);\n   403→  simulation.applySizeRandomness(currentParams.sizeRandomness ?? 0);\n   404→  syncSliders();\n   405→}\n   406→\n   407→presetSelect.addEventListener('change', () => applyPreset(presetSelect.value));\n   408→\n   409→document.getElementById('preset-save').addEventListener('click', () => {\n   410→  const name = prompt('Preset name:');\n   411→  if (!name || !name.trim()) return;\n   412→  const userPresets = loadUserPresets();\n   413→  userPresets[name.trim()] = { ...currentParams };\n   414→  saveUserPresets(userPresets);\n   415→  populatePresetDropdown();\n   416→  presetSelect.value = `user:${name.trim()}`;\n   417→});\n   418→\n   419→document.getElementById('preset-del').addEventListener('click', () => {\n   420→  const sel = presetSelect.value;\n   421→  if (!sel.startsWith('user:')) return; // can't delete built-in\n   422→  const name = sel.slice(5);\n   423→  const userPresets = loadUserPresets();\n   424→  delete userPresets[name];\n   425→  saveUserPresets(userPresets);\n   426→  populatePresetDropdown();\n   427→  presetSelect.value = 'Murmuration';\n   428→  applyPreset('Murmuration');\n   429→});\n   430→\n   431→populatePresetDropdown();\n   432→presetSelect.value = 'Murmuration';\n   433→\n   434→// Gain slider\n   435→const gainSlider = document.getElementById('gain-slider');\n   436→const gainVal = document.getElementById('gain-val');\n   437→currentParams.gain = 0.5;\n   438→gainSlider.addEventListener('input', () => {\n   439→  currentParams.gain = parseFloat(gainSlider.value);\n   440→  gainVal.textContent = currentParams.gain.toFixed(2);\n   441→});\n   442→\n   443→// Auto-range checkbox\n   444→const autoRangeCb = document.getElementById('auto-range-cb');\n   445→autoRangeCb.addEventListener('change', () => {\n   446→  simulation.autoRange = autoRangeCb.checked;\n   447→});\n   448→\n   449→// Brightness slider\n   450→const brightnessSlider = document.getElementById('brightness-slider');\n   451→const brightnessVal = document.getElementById('brightness-val');\n   452→let brightness = 1.0;\n   453→brightnessSlider.addEventListener('input', () => {\n   454→  brightness = parseFloat(brightnessSlider.value);\n   455→  brightnessVal.textContent = brightness.toFixed(2);\n   456→});\n   457→\n   458→// Sphere radius slider\n   459→const sphereRadiusSlider = document.getElementById('sphere-radius-slider');\n   460→const sphereRadiusVal = document.getElementById('sphere-radius-val');\n   461→currentParams.sphereRadius = 100;\n   462→sphereRadiusSlider.addEventListener('input', () => {\n   463→  currentParams.sphereRadius = parseFloat(sphereRadiusSlider.value);\n   464→  sphereRadiusVal.textContent = currentParams.sphereRadius.toFixed(0);\n   465→  simulation.setParams(currentParams);\n   466→});\n   467→\n   468→// Particle scale slider\n   469→const particleScaleSlider = document.getElementById('particle-scale-slider');\n   470→const particleScaleVal = document.getElementById('particle-scale-val');\n   471→let particleScale = 1.0;\n   472→particleScaleSlider.addEventListener('input', () => {\n   473→  particleScale = parseFloat(particleScaleSlider.value);\n   474→  particleScaleVal.textContent = particleScale.toFixed(2);\n   475→});\n   476→\n   477→// Neighbor mode\n   478→const neighborModeSelect = document.getElementById('neighbor-mode-select');\n   479→let neighborMode = 0;\n   480→neighborModeSelect.addEventListener('change', () => {\n   481→  neighborMode = parseInt(neighborModeSelect.value);\n   482→});\n   483→\n   484→// Rendering controls\n   485→const renderModeSelect = document.getElementById('render-mode-select');\n   486→const falloffSlider = document.getElementById('falloff-slider');\n   487→const falloffVal = document.getElementById('falloff-val');\n   488→const particleCountSlider = document.getElementById('particle-count-slider');\n   489→const particleCountVal = document.getElementById('particle-count-val');\n   490→const bloomCb = document.getElementById('bloom-cb');\n   491→const bloomThreshSlider = document.getElementById('bloom-threshold-slider');\n   492→const bloomThreshVal = document.getElementById('bloom-threshold-val');\n   493→const bloomIntensitySlider = document.getElementById('bloom-intensity-slider');\n   494→const bloomIntensityVal = document.getElementById('bloom-intensity-val');\n   495→\n   496→let renderMode = 0;\n   497→let falloff = 1.0;\n   498→let bloomEnabled = false;\n   499→let bloomThreshold = 0.8;\n   500→let bloomIntensity = 0.5;\n   501→\n   502→renderModeSelect.addEventListener('change', () => { renderMode = parseInt(renderModeSelect.value); });\n   503→falloffSlider.addEventListener('input', () => {\n   504→  falloff = parseFloat(falloffSlider.value);\n   505→  falloffVal.textContent = falloff.toFixed(2);\n   506→});\n   507→\n   508→// Particle count (logarithmic slider: 10^3 to 10^6.3)\n   509→let particleCountTimeout = null;\n   510→particleCountSlider.value = Math.log10(NUM_BOIDS);\n   511→particleCountVal.textContent = NUM_BOIDS.toLocaleString();\n   512→particleCountSlider.addEventListener('input', () => {\n   513→  const count = Math.round(Math.pow(10, parseFloat(particleCountSlider.value)));\n   514→  particleCountVal.textContent = count.toLocaleString();\n   515→  clearTimeout(particleCountTimeout);\n   516→  particleCountTimeout = setTimeout(async () => {\n   517→    NUM_BOIDS = count;\n   518→    simulation = await createSimulation(device, { numBoids: count, worldSize: WORLD_SIZE });\n   519→    simulation.setParams(currentParams);\n   520→    simulation.applySizeRandomness(currentParams.sizeRandomness ?? 0);\n   521→    simulation.autoRange = autoRangeCb.checked;\n   522→    renderer.rebindSimulation(simulation);\n   523→  }, 500);\n   524→});\n   525→\n   526→bloomCb.addEventListener('change', () => { bloomEnabled = bloomCb.checked; });\n   527→bloomThreshSlider.addEventListener('input', () => {\n   528→  bloomThreshold = parseFloat(bloomThreshSlider.value);\n   529→  bloomThreshVal.textContent = bloomThreshold.toFixed(2);\n   530→});\n   531→bloomIntensitySlider.addEventListener('input', () => {\n   532→  bloomIntensity = parseFloat(bloomIntensitySlider.value);\n   533→  bloomIntensityVal.textContent = bloomIntensity.toFixed(2);\n   534→});\n   535→\n   536→// Gradient + Color Source dropdowns\n   537→const gradientSelect = document.getElementById('gradient-select');\n   538→const colorSourceSelect = document.getElementById('color-source-select');\n   539→currentParams.gradientId = 0;\n   540→currentParams.colorSource = 0;\n   541→\n   542→gradientSelect.addEventListener('change', () => {\n   543→  currentParams.gradientId = parseInt(gradientSelect.value);\n   544→  simulation.setParams(currentParams);\n   545→});\n   546→colorSourceSelect.addEventListener('change', () => {\n   547→  currentParams.colorSource = parseInt(colorSourceSelect.value);\n   548→  simulation.setParams(currentParams);\n   549→});\n   550→\n   551→// Panel toggle\n   552→const panel = document.getElementById('panel');\n   553→document.getElementById('panel-toggle').addEventListener('click', () => {\n   554→  panel.classList.toggle('open');\n   555→});\n   556→\n   557→// ============================================================\n   558→// Orbit camera\n   559→// ============================================================\n   560→let azimuth   = 0.5;\n   561→let elevation = 0.35;\n   562→let distance  = 140;\n   563→\n   564→canvas.addEventListener('pointerdown', (e) => {\n   565→  canvas.setPointerCapture(e.pointerId);\n   566→  let lastX = e.clientX, lastY = e.clientY;\n   567→  const move = (ev) => {\n   568→    azimuth   -= (ev.clientX - lastX) * 0.005;\n   569→    elevation  = Math.max(-1.5, Math.min(1.5, elevation + (ev.clientY - lastY) * 0.005));\n   570→    lastX = ev.clientX; lastY = ev.clientY;\n   571→  };\n   572→  const up = () => { canvas.removeEventListener('pointermove', move); canvas.removeEventListener('pointerup', up); };\n   573→  canvas.addEventListener('pointermove', move);\n   574→  canvas.addEventListener('pointerup', up);\n   575→});\n   576→canvas.addEventListener('wheel', (e) => {\n   577→  distance = Math.max(20, Math.min(400, distance * (1 + e.deltaY * 0.001)));\n   578→  e.preventDefault();\n   579→}, { passive: false });\n   580→\n   581→// ============================================================\n   582→// Matrix helpers\n   583→// ============================================================\n   584→function perspective(fov, aspect, near, far) {\n   585→  const f = 1 / Math.tan(fov / 2);\n   586→  const nf = 1 / (near - far);\n   587→  return new Float32Array([\n   588→    f / aspect, 0, 0, 0,\n   589→    0, f, 0, 0,\n   590→    0, 0, (far + near) * nf, -1,\n   591→    0, 0, 2 * far * near * nf, 0,\n   592→  ]);\n   593→}\n   594→\n   595→function lookAt(eye, target, up) {\n   596→  const zx = eye[0]-target[0], zy = eye[1]-target[1], zz = eye[2]-target[2];\n   597→  let len = 1 / Math.hypot(zx, zy, zz);\n   598→  const z0=zx*len, z1=zy*len, z2=zz*len;\n   599→  const x0 = up[1]*z2 - up[2]*z1, x1 = up[2]*z0 - up[0]*z2, x2 = up[0]*z1 - up[1]*z0;\n   600→  len = Math.hypot(x0,x1,x2); const rl = len ? 1/len : 0;\n   601→  const r0=x0*rl, r1=x1*rl, r2=x2*rl;\n   602→  const u0=z1*r2-z2*r1, u1=z2*r0-z0*r2, u2=z0*r1-z1*r0;\n   603→  return new Float32Array([\n   604→    r0, u0, z0, 0,\n   605→    r1, u1, z1, 0,\n   606→    r2, u2, z2, 0,\n   607→    -(r0*eye[0]+r1*eye[1]+r2*eye[2]),\n   608→    -(u0*eye[0]+u1*eye[1]+u2*eye[2]),\n   609→    -(z0*eye[0]+z1*eye[1]+z2*eye[2]),\n   610→    1,\n   611→  ]);\n   612→}\n   613→\n   614→function mat4Mul(a, b) {\n   615→  const o = new Float32Array(16);\n   616→  for (let i = 0; i < 4; i++)\n   617→    for (let j = 0; j < 4; j++)\n   618→      o[j*4+i] = a[i]*b[j*4] + a[4+i]*b[j*4+1] + a[8+i]*b[j*4+2] + a[12+i]*b[j*4+3];\n   619→  return o;\n   620→}\n   621→\n   622→// ============================================================\n   623→// FPS + Main loop + Benchmark reporting\n   624→// ============================================================\n   625→const frameTimes = [];\n   626→let lastTime = performance.now();\n   627→const hud = document.getElementById('hud');\n   628→let benchFrame = 0, benchDone = false;\n   629→\n   630→function frame() {\n   631→  const now = performance.now();\n   632→  const dt = now - lastTime;\n   633→  lastTime = now;\n   634→  benchFrame++;\n   635→  if (benchFrame > 30) frameTimes.push(dt);\n   636→  if (frameTimes.length > 200) frameTimes.shift();\n   637→\n   638→  const display = frameTimes.length ? frameTimes : [16.6];\n   639→  const avgMs = display.reduce((a,b) => a+b, 0) / display.length;\n   640→  hud.textContent = `${NUM_BOIDS.toLocaleString()} boids | ${(1000/avgMs).toFixed(0)} fps | ${avgMs.toFixed(1)} ms`;\n   641→\n   642→  if (benchmarkBoids && frameTimes.length >= 120 && !benchDone) {\n   643→    benchDone = true;\n   644→    const sorted = [...frameTimes].sort((a,b) => a - b);\n   645→    const avg = sorted.reduce((a,b) => a+b, 0) / sorted.length;\n   646→    const p99 = sorted[Math.floor(sorted.length * 0.99)];\n   647→    fetch('/api/bench_result', { method: 'POST',\n   648→      headers: { 'Content-Type': 'application/json' },\n   649→      body: JSON.stringify({ num_boids: NUM_BOIDS, frames: sorted.length,\n   650→        avg_ms: +avg.toFixed(2), p99_ms: +p99.toFixed(2),\n   651→        min_ms: +sorted[0].toFixed(2), max_ms: +sorted[sorted.length-1].toFixed(2) }),\n   652→    }).catch(() => {});\n   653→    hud.textContent += ' | BENCHMARK COMPLETE';\n   654→  }\n   655→\n   656→\n   657→\n   658→  const eye = [\n   659→    distance * Math.cos(elevation) * Math.sin(azimuth),\n   660→    distance * Math.sin(elevation),\n   661→    distance * Math.cos(elevation) * Math.cos(azimuth),\n   662→  ];\n   663→  const aspect = canvas.width / canvas.height;\n   664→  const proj = perspective(Math.PI / 3, aspect, 1.0, 600);\n   665→  const view = lookAt(eye, [0,0,0], [0,1,0]);\n   666→  const vp = mat4Mul(proj, view);\n   667→\n   668→  const encoder = device.createCommandEncoder();\n   669→  const simSteps = Math.max(1, Math.round(currentParams.simSpeed ?? 1));\n   670→  for (let s = 0; s < simSteps; s++) {\n   671→    simulation.update(encoder, s === simSteps - 1, neighborMode);\n   672→  }\n   673→  const ar = autoRangeCb.checked;\n   674→  renderer.render(encoder, vp, {\n   675→    gradientId: currentParams.gradientId ?? 0,\n   676→    colorSource: currentParams.colorSource ?? 0,\n   677→    gain: currentParams.gain ?? 0.5,\n   678→    autoRange: ar, autoMin: simulation.autoMin, autoMax: simulation.autoMax,\n   679→    falloff, brightness, particleScale, sphereRadius: currentParams.sphereRadius ?? 100,\n   680→    renderMode, cameraPos: eye, bloomEnabled, bloomThreshold, bloomIntensity,\n   681→    numBoids: NUM_BOIDS, sim: simulation,\n   682→  });\n   683→  device.queue.submit([encoder.finish()]);\n   684→  if (ar) simulation.readStats();\n   685→\n   686→  requestAnimationFrame(frame);\n   687→}\n   688→requestAnimationFrame(frame);\n   689→\n   690→function showError(msg) {\n   691→  document.getElementById('hud').remove();\n   692→  const d = document.createElement('div'); d.id = 'error'; d.textContent = msg;\n   693→  document.body.appendChild(d);\n   694→}\n   695→</script>\n   696→</body>\n   697→</html>\n   698→"}]},"parent_tool_use_id":null,"session_id":"ab277b0e-46f8-4888-a52e-c14b4b8bde67","uuid":"06b2ceae-6829-453a-8375-17b5962ada96","timestamp":"2026-03-23T19:02:24.325Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/aaronlemke/AI/Murmuration/index.html","content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<title>3D Murmuration</title>\n<style>\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  body { background: #000; overflow: hidden; font-family: system-ui, sans-serif; }\n  canvas { display: block; width: 100vw; height: 100vh; }\n  #hud {\n    position: fixed; top: 12px; left: 16px;\n    color: #aac; font: 14px/1.4 monospace;\n    pointer-events: none; text-shadow: 0 1px 3px #000;\n  }\n  #error {\n    position: fixed; inset: 0; display: flex; align-items: center; justify-content: center;\n    color: #f88; font: 18px/1.6 system-ui; text-align: center; padding: 2em;\n  }\n\n  /* --- Settings panel --- */\n  #panel {\n    position: fixed; top: 12px; right: 16px; width: 280px;\n    z-index: 10; user-select: none;\n  }\n  #panel-toggle {\n    display: block; width: 100%; padding: 8px 14px;\n    background: rgba(20,20,40,0.85); color: #aac; border: 1px solid rgba(100,100,160,0.3);\n    border-radius: 6px; font: 13px/1 system-ui; cursor: pointer; text-align: left;\n    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);\n  }\n  #panel-toggle:hover { background: rgba(30,30,60,0.9); }\n  #panel-toggle::after { content: ' \\u25BC'; float: right; font-size: 10px; }\n  #panel.open #panel-toggle::after { content: ' \\u25B2'; }\n  #panel-body {\n    max-height: 0; overflow: hidden; transition: max-height 0.3s ease;\n    background: rgba(10,10,25,0.88); border: 1px solid rgba(100,100,160,0.25);\n    border-top: none; border-radius: 0 0 6px 6px;\n    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);\n  }\n  #panel.open #panel-body { max-height: 700px; }\n  #panel-inner { padding: 10px 14px 14px; }\n\n  .param-row {\n    display: flex; align-items: center; gap: 6px; margin-bottom: 6px;\n  }\n  .param-row label {\n    flex: 0 0 90px; color: #889; font-size: 11px; text-align: right;\n  }\n  .param-row input[type=range] {\n    flex: 1; height: 4px; accent-color: #668cff;\n  }\n  .param-row .val {\n    flex: 0 0 42px; color: #bbd; font: 11px monospace; text-align: right;\n  }\n\n  .preset-row {\n    display: flex; gap: 6px; margin-bottom: 10px; align-items: center;\n  }\n  .preset-row select {\n    flex: 1; padding: 4px 6px; font-size: 12px;\n    background: rgba(30,30,60,0.9); color: #bbd; border: 1px solid rgba(100,100,160,0.3);\n    border-radius: 4px;\n  }\n  .preset-row button {\n    padding: 4px 8px; font-size: 11px; cursor: pointer;\n    background: rgba(40,40,80,0.8); color: #aac; border: 1px solid rgba(100,100,160,0.3);\n    border-radius: 4px;\n  }\n  .preset-row button:hover { background: rgba(60,60,100,0.9); }\n  .section-label {\n    color: #667; font-size: 10px; text-transform: uppercase; letter-spacing: 1px;\n    margin: 8px 0 4px; padding-bottom: 2px; border-bottom: 1px solid rgba(100,100,160,0.15);\n  }\n</style>\n</head>\n<body>\n<canvas id=\"c\"></canvas>\n<div id=\"hud\"></div>\n\n<div id=\"panel\">\n  <button id=\"panel-toggle\">Settings</button>\n  <div id=\"panel-body\"><div id=\"panel-inner\">\n    <div class=\"section-label\">Presets</div>\n    <div class=\"preset-row\">\n      <select id=\"preset-select\"></select>\n      <button id=\"preset-save\" title=\"Save current as new preset\">Save</button>\n      <button id=\"preset-del\" title=\"Delete selected user preset\">Del</button>\n    </div>\n    <div class=\"section-label\">Visuals</div>\n    <div class=\"param-row\">\n      <label>Gradient</label>\n      <select id=\"gradient-select\" style=\"flex:1; padding:3px 6px; font-size:12px; background:rgba(30,30,60,0.9); color:#bbd; border:1px solid rgba(100,100,160,0.3); border-radius:4px;\">\n        <option value=\"0\">Viridis</option>\n        <option value=\"1\">Inferno</option>\n        <option value=\"2\">Magma</option>\n        <option value=\"3\">Plasma</option>\n        <option value=\"4\">Turbo</option>\n        <option value=\"5\">Cividis</option>\n        <option value=\"6\">Coolwarm</option>\n        <option value=\"7\">Spectral</option>\n        <option value=\"8\">Hot</option>\n        <option value=\"9\">Ocean</option>\n      </select>\n    </div>\n    <div class=\"param-row\">\n      <label>Color Source</label>\n      <select id=\"color-source-select\" style=\"flex:1; padding:3px 6px; font-size:12px; background:rgba(30,30,60,0.9); color:#bbd; border:1px solid rgba(100,100,160,0.3); border-radius:4px;\">\n        <option value=\"0\">Velocity Direction</option>\n        <option value=\"1\">Speed</option>\n        <option value=\"2\">Direction Change</option>\n        <option value=\"3\">Neighbor Count</option>\n        <option value=\"4\">Altitude</option>\n        <option value=\"5\">Distance from Center</option>\n        <option value=\"6\">Flock Alignment</option>\n        <option value=\"7\">Separation Pressure</option>\n        <option value=\"8\">Local Density</option>\n        <option value=\"9\">Boid ID</option>\n      </select>\n    </div>\n    <div class=\"param-row\">\n      <label>Gain</label>\n      <input type=\"range\" id=\"gain-slider\" min=\"0.0\" max=\"1.0\" step=\"0.01\" value=\"0.5\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"gain-val\">0.50</span>\n    </div>\n    <div class=\"param-row\">\n      <label>Auto-Range</label>\n      <label style=\"flex:1; color:#aab; font-size:12px; cursor:pointer;\">\n        <input type=\"checkbox\" id=\"auto-range-cb\" style=\"accent-color:#668cff; margin-right:4px;\">\n        Normalize to data range\n      </label>\n    </div>\n    <div class=\"param-row\">\n      <label>Brightness</label>\n      <input type=\"range\" id=\"brightness-slider\" min=\"0.1\" max=\"5.0\" step=\"0.05\" value=\"1.0\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"brightness-val\">1.00</span>\n    </div>\n    <div class=\"param-row\">\n      <label>Sphere Radius</label>\n      <input type=\"range\" id=\"sphere-radius-slider\" min=\"20\" max=\"300\" step=\"5\" value=\"100\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"sphere-radius-val\">100</span>\n    </div>\n    <div class=\"param-row\">\n      <label>Neighbor Mode</label>\n      <select id=\"neighbor-mode-select\" style=\"flex:1; padding:3px 6px; font-size:12px; background:rgba(30,30,60,0.9); color:#bbd; border:1px solid rgba(100,100,160,0.3); border-radius:4px;\">\n        <option value=\"0\">Topological (K=7 nearest)</option>\n        <option value=\"1\">Radius (classic, fast)</option>\n      </select>\n    </div>\n    <div class=\"section-label\">Rendering</div>\n    <div class=\"param-row\">\n      <label>Render Mode</label>\n      <select id=\"render-mode-select\" style=\"flex:1; padding:3px 6px; font-size:12px; background:rgba(30,30,60,0.9); color:#bbd; border:1px solid rgba(100,100,160,0.3); border-radius:4px;\">\n        <option value=\"0\">Tetrahedron</option>\n        <option value=\"1\">Billboard (Additive)</option>\n        <option value=\"2\">Billboard (Opaque)</option>\n        <option value=\"3\">Reflective Tetrahedron</option>\n        <option value=\"4\">Reflective Billboard</option>\n      </select>\n    </div>\n    <div class=\"param-row\">\n      <label>Falloff</label>\n      <input type=\"range\" id=\"falloff-slider\" min=\"0.1\" max=\"3.0\" step=\"0.05\" value=\"1.0\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"falloff-val\">1.00</span>\n    </div>\n    <div class=\"param-row\">\n      <label>Particle Scale</label>\n      <input type=\"range\" id=\"particle-scale-slider\" min=\"0.05\" max=\"5.0\" step=\"0.05\" value=\"1.0\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"particle-scale-val\">1.00</span>\n    </div>\n    <div class=\"param-row\">\n      <label>Particle Count</label>\n      <input type=\"range\" id=\"particle-count-slider\" min=\"3\" max=\"6.3\" step=\"0.01\" value=\"3.7\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"particle-count-val\">5,000</span>\n    </div>\n    <div class=\"param-row\">\n      <label>Bloom</label>\n      <label style=\"flex:1; color:#aab; font-size:12px; cursor:pointer;\">\n        <input type=\"checkbox\" id=\"bloom-cb\" style=\"accent-color:#668cff; margin-right:4px;\">\n        Enable bloom\n      </label>\n    </div>\n    <div class=\"param-row\">\n      <label>Bloom Thresh</label>\n      <input type=\"range\" id=\"bloom-threshold-slider\" min=\"0.1\" max=\"2.0\" step=\"0.05\" value=\"0.8\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"bloom-threshold-val\">0.80</span>\n    </div>\n    <div class=\"param-row\">\n      <label>Bloom Intensity</label>\n      <input type=\"range\" id=\"bloom-intensity-slider\" min=\"0.0\" max=\"3.0\" step=\"0.05\" value=\"0.5\" style=\"flex:1; height:4px; accent-color:#668cff;\">\n      <span class=\"val\" id=\"bloom-intensity-val\">0.50</span>\n    </div>\n    <div class=\"section-label\">Physics</div>\n    <div id=\"sliders\"></div>\n  </div></div>\n</div>\n\n<script type=\"module\">\n// Capture errors and post to server for debugging\nwindow.addEventListener('error', e => {\n  fetch('/api/bench_result', { method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ error: e.message, file: e.filename, line: e.lineno }),\n  }).catch(() => {});\n});\nwindow.addEventListener('unhandledrejection', e => {\n  fetch('/api/bench_result', { method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ error: String(e.reason) }),\n  }).catch(() => {});\n});\n\nimport { createSimulation } from './simulation.js';\nimport { createRenderer }   from './renderer.js';\n\n// Benchmark mode: ?boids=N runs a measured benchmark\nconst urlParams = new URLSearchParams(location.search);\nconst benchmarkBoids = urlParams.get('boids') ? parseInt(urlParams.get('boids')) : null;\n\nlet NUM_BOIDS = benchmarkBoids || 40000;\nconst WORLD_SIZE = 100;\n\n// ============================================================\n// Built-in presets\n// ============================================================\nconst BUILTIN_PRESETS = {\n  'Murmuration': {\n    simSpeed: 1.0, sizeRandomness: 0.0, dragFactor: 0.0, sphereRadius: 120,\n    visualRange: 15.0, separationDist: 2.0, alignFactor: 0.12,\n    cohesionFactor: 0.003, separationFactor: 0.08,\n    maxSpeed: 10.0, minSpeed: 3.0, turnFactor: 0.3, smoothing: 0.10,\n  },\n  'Tight Murmuration': {\n    simSpeed: 1.0, sizeRandomness: 0.0, dragFactor: 0.0, sphereRadius: 80,\n    visualRange: 10.0, separationDist: 1.5, alignFactor: 0.15,\n    cohesionFactor: 0.005, separationFactor: 0.12,\n    maxSpeed: 12.0, minSpeed: 5.0, turnFactor: 0.4, smoothing: 0.08,\n  },\n  'Lazy Murmuration': {\n    simSpeed: 1.0, sizeRandomness: 0.0, dragFactor: 0.0, sphereRadius: 150,\n    visualRange: 20.0, separationDist: 3.0, alignFactor: 0.08,\n    cohesionFactor: 0.001, separationFactor: 0.05,\n    maxSpeed: 5.0, minSpeed: 1.5, turnFactor: 0.2, smoothing: 0.15,\n  },\n  'Swarm': {\n    simSpeed: 1.0, sizeRandomness: 0.3, dragFactor: 0.5, sphereRadius: 100,\n    visualRange: 8.0, separationDist: 0.8, alignFactor: 0.01,\n    cohesionFactor: 0.02, separationFactor: 0.3,\n    maxSpeed: 5.0, minSpeed: 0.5, turnFactor: 0.4, smoothing: 0.15,\n  },\n  'Predator Evasion': {\n    simSpeed: 1.0, sizeRandomness: 0.0, dragFactor: 0.0, sphereRadius: 120,\n    visualRange: 12.0, separationDist: 3.0, alignFactor: 0.10,\n    cohesionFactor: 0.003, separationFactor: 0.15,\n    maxSpeed: 14.0, minSpeed: 5.0, turnFactor: 0.5, smoothing: 0.06,\n  },\n};\n\n// Slider definitions: [key, label, min, max, step]\nconst SLIDER_DEFS = [\n  ['simSpeed',        'Sim Speed',     0.1,  10.0,  0.1],\n  ['sizeRandomness',  'Size Random',   0.0,   1.0,  0.05],\n  ['dragFactor',      'Size Drag',     0.0,   1.0,  0.05],\n  ['visualRange',     'Visual Range',  1.0,  10.0,  0.1],\n  ['separationDist',  'Sep. Dist',     0.3,   5.0,  0.1],\n  ['alignFactor',     'Alignment',     0.001, 0.2,  0.001],\n  ['cohesionFactor',  'Cohesion',      0.0005,0.05, 0.0005],\n  ['separationFactor','Separation',    0.05,  2.0,  0.01],\n  ['maxSpeed',        'Max Speed',     1.0,  50.0,  0.5],\n  ['minSpeed',        'Min Speed',     0.1,   5.0,  0.1],\n  ['turnFactor',      'Turn Factor',   0.05,  1.0,  0.05],\n  ['smoothing',       'Turn Rate',     0.01,  0.3,  0.005],\n];\n\n// ============================================================\n// WebGPU init\n// ============================================================\nif (!navigator.gpu) { showError('WebGPU not supported. Use Chrome 113+ or Edge 113+.'); throw ''; }\nconst adapter = await navigator.gpu.requestAdapter();\nif (!adapter) { showError('No WebGPU adapter found.'); throw ''; }\nconst device = await adapter.requestDevice();\n\nconst canvas = document.getElementById('c');\nconst ctx    = canvas.getContext('webgpu');\n\nfunction resize() {\n  const dpr = devicePixelRatio;\n  canvas.width  = Math.floor(innerWidth * dpr);\n  canvas.height = Math.floor(innerHeight * dpr);\n}\nresize();\n\nlet simulation, renderer;\ntry {\n  simulation = await createSimulation(device, { numBoids: NUM_BOIDS, worldSize: WORLD_SIZE });\n  renderer = await createRenderer(device, ctx, simulation);\n} catch(e) {\n  showError('Init failed: ' + e.message);\n  throw e;\n}\naddEventListener('resize', () => { resize(); renderer.resize(); });\n\n// ============================================================\n// Current params state\n// ============================================================\nlet currentParams = { ...BUILTIN_PRESETS['Murmuration'] };\nsimulation.setParams(currentParams);\nsimulation.applySizeRandomness(currentParams.sizeRandomness ?? 0);\n\n// ============================================================\n// UI: Sliders\n// ============================================================\nconst sliderEls = {};\nconst slidersDiv = document.getElementById('sliders');\n\nfor (const [key, label, min, max, step] of SLIDER_DEFS) {\n  const row = document.createElement('div');\n  row.className = 'param-row';\n\n  const lbl = document.createElement('label');\n  lbl.textContent = label;\n\n  const input = document.createElement('input');\n  input.type = 'range';\n  input.min = min; input.max = max; input.step = step;\n  input.value = currentParams[key];\n\n  const val = document.createElement('span');\n  val.className = 'val';\n  val.textContent = fmtVal(currentParams[key], step);\n\n  input.addEventListener('input', () => {\n    const v = parseFloat(input.value);\n    currentParams[key] = v;\n    val.textContent = fmtVal(v, step);\n    simulation.setParams(currentParams);\n    if (key === 'sizeRandomness') simulation.applySizeRandomness(v);\n  });\n\n  row.append(lbl, input, val);\n  slidersDiv.appendChild(row);\n  sliderEls[key] = { input, val, step };\n}\n\nfunction fmtVal(v, step) {\n  const dec = step < 0.01 ? 4 : step < 0.1 ? 3 : step < 1 ? 2 : 1;\n  return v.toFixed(dec);\n}\n\nfunction syncSliders() {\n  for (const [key] of SLIDER_DEFS) {\n    const el = sliderEls[key];\n    el.input.value = currentParams[key];\n    el.val.textContent = fmtVal(currentParams[key], el.step);\n  }\n}\n\n// ============================================================\n// UI: Presets\n// ============================================================\nconst LS_KEY = 'murmuration-user-presets';\nconst presetSelect = document.getElementById('preset-select');\n\nfunction loadUserPresets() {\n  try { return JSON.parse(localStorage.getItem(LS_KEY)) || {}; } catch { return {}; }\n}\nfunction saveUserPresets(obj) {\n  localStorage.setItem(LS_KEY, JSON.stringify(obj));\n}\n\nfunction populatePresetDropdown() {\n  presetSelect.innerHTML = '';\n  // Built-in\n  for (const name of Object.keys(BUILTIN_PRESETS)) {\n    const opt = document.createElement('option');\n    opt.value = name; opt.textContent = name;\n    presetSelect.appendChild(opt);\n  }\n  // User\n  const userPresets = loadUserPresets();\n  const userNames = Object.keys(userPresets);\n  if (userNames.length) {\n    const sep = document.createElement('option');\n    sep.disabled = true; sep.textContent = '--- User Presets ---';\n    presetSelect.appendChild(sep);\n    for (const name of userNames) {\n      const opt = document.createElement('option');\n      opt.value = `user:${name}`; opt.textContent = name;\n      presetSelect.appendChild(opt);\n    }\n  }\n}\n\nfunction applyPreset(name) {\n  let params;\n  if (name.startsWith('user:')) {\n    params = loadUserPresets()[name.slice(5)];\n  } else {\n    params = BUILTIN_PRESETS[name];\n  }\n  if (!params) return;\n  currentParams = { ...params };\n  simulation.setParams(currentParams);\n  simulation.applySizeRandomness(currentParams.sizeRandomness ?? 0);\n  syncSliders();\n}\n\npresetSelect.addEventListener('change', () => applyPreset(presetSelect.value));\n\ndocument.getElementById('preset-save').addEventListener('click', () => {\n  const name = prompt('Preset name:');\n  if (!name || !name.trim()) return;\n  const userPresets = loadUserPresets();\n  userPresets[name.trim()] = { ...currentParams };\n  saveUserPresets(userPresets);\n  populatePresetDropdown();\n  presetSelect.value = `user:${name.trim()}`;\n});\n\ndocument.getElementById('preset-del').addEventListener('click', () => {\n  const sel = presetSelect.value;\n  if (!sel.startsWith('user:')) return; // can't delete built-in\n  const name = sel.slice(5);\n  const userPresets = loadUserPresets();\n  delete userPresets[name];\n  saveUserPresets(userPresets);\n  populatePresetDropdown();\n  presetSelect.value = 'Murmuration';\n  applyPreset('Murmuration');\n});\n\npopulatePresetDropdown();\npresetSelect.value = 'Murmuration';\n\n// Gain slider\nconst gainSlider = document.getElementById('gain-slider');\nconst gainVal = document.getElementById('gain-val');\ncurrentParams.gain = 0.5;\ngainSlider.addEventListener('input', () => {\n  currentParams.gain = parseFloat(gainSlider.value);\n  gainVal.textContent = currentParams.gain.toFixed(2);\n});\n\n// Auto-range checkbox\nconst autoRangeCb = document.getElementById('auto-range-cb');\nautoRangeCb.addEventListener('change', () => {\n  simulation.autoRange = autoRangeCb.checked;\n});\n\n// Brightness slider\nconst brightnessSlider = document.getElementById('brightness-slider');\nconst brightnessVal = document.getElementById('brightness-val');\nlet brightness = 1.0;\nbrightnessSlider.addEventListener('input', () => {\n  brightness = parseFloat(brightnessSlider.value);\n  brightnessVal.textContent = brightness.toFixed(2);\n});\n\n// Sphere radius slider\nconst sphereRadiusSlider = document.getElementById('sphere-radius-slider');\nconst sphereRadiusVal = document.getElementById('sphere-radius-val');\ncurrentParams.sphereRadius = 100;\nsphereRadiusSlider.addEventListener('input', () => {\n  currentParams.sphereRadius = parseFloat(sphereRadiusSlider.value);\n  sphereRadiusVal.textContent = currentParams.sphereRadius.toFixed(0);\n  simulation.setParams(currentParams);\n});\n\n// Particle scale slider\nconst particleScaleSlider = document.getElementById('particle-scale-slider');\nconst particleScaleVal = document.getElementById('particle-scale-val');\nlet particleScale = 1.0;\nparticleScaleSlider.addEventListener('input', () => {\n  particleScale = parseFloat(particleScaleSlider.value);\n  particleScaleVal.textContent = particleScale.toFixed(2);\n});\n\n// Neighbor mode\nconst neighborModeSelect = document.getElementById('neighbor-mode-select');\nlet neighborMode = 0;\nneighborModeSelect.addEventListener('change', () => {\n  neighborMode = parseInt(neighborModeSelect.value);\n});\n\n// Rendering controls\nconst renderModeSelect = document.getElementById('render-mode-select');\nconst falloffSlider = document.getElementById('falloff-slider');\nconst falloffVal = document.getElementById('falloff-val');\nconst particleCountSlider = document.getElementById('particle-count-slider');\nconst particleCountVal = document.getElementById('particle-count-val');\nconst bloomCb = document.getElementById('bloom-cb');\nconst bloomThreshSlider = document.getElementById('bloom-threshold-slider');\nconst bloomThreshVal = document.getElementById('bloom-threshold-val');\nconst bloomIntensitySlider = document.getElementById('bloom-intensity-slider');\nconst bloomIntensityVal = document.getElementById('bloom-intensity-val');\n\nlet renderMode = 0;\nlet falloff = 1.0;\nlet bloomEnabled = false;\nlet bloomThreshold = 0.8;\nlet bloomIntensity = 0.5;\n\nrenderModeSelect.addEventListener('change', () => { renderMode = parseInt(renderModeSelect.value); });\nfalloffSlider.addEventListener('input', () => {\n  falloff = parseFloat(falloffSlider.value);\n  falloffVal.textContent = falloff.toFixed(2);\n});\n\n// Particle count (logarithmic slider: 10^3 to 10^6.3)\nlet particleCountTimeout = null;\nparticleCountSlider.value = Math.log10(NUM_BOIDS);\nparticleCountVal.textContent = NUM_BOIDS.toLocaleString();\nparticleCountSlider.addEventListener('input', () => {\n  const count = Math.round(Math.pow(10, parseFloat(particleCountSlider.value)));\n  particleCountVal.textContent = count.toLocaleString();\n  clearTimeout(particleCountTimeout);\n  particleCountTimeout = setTimeout(async () => {\n    NUM_BOIDS = count;\n    simulation = await createSimulation(device, { numBoids: count, worldSize: WORLD_SIZE });\n    simulation.setParams(currentParams);\n    simulation.applySizeRandomness(currentParams.sizeRandomness ?? 0);\n    simulation.autoRange = autoRangeCb.checked;\n    renderer.rebindSimulation(simulation);\n  }, 500);\n});\n\nbloomCb.addEventListener('change', () => { bloomEnabled = bloomCb.checked; });\nbloomThreshSlider.addEventListener('input', () => {\n  bloomThreshold = parseFloat(bloomThreshSlider.value);\n  bloomThreshVal.textContent = bloomThreshold.toFixed(2);\n});\nbloomIntensitySlider.addEventListener('input', () => {\n  bloomIntensity = parseFloat(bloomIntensitySlider.value);\n  bloomIntensityVal.textContent = bloomIntensity.toFixed(2);\n});\n\n// Gradient + Color Source dropdowns\nconst gradientSelect = document.getElementById('gradient-select');\nconst colorSourceSelect = document.getElementById('color-source-select');\ncurrentParams.gradientId = 0;\ncurrentParams.colorSource = 0;\n\ngradientSelect.addEventListener('change', () => {\n  currentParams.gradientId = parseInt(gradientSelect.value);\n  simulation.setParams(currentParams);\n});\ncolorSourceSelect.addEventListener('change', () => {\n  currentParams.colorSource = parseInt(colorSourceSelect.value);\n  simulation.setParams(currentParams);\n});\n\n// Panel toggle\nconst panel = document.getElementById('panel');\ndocument.getElementById('panel-toggle').addEventListener('click', () => {\n  panel.classList.toggle('open');\n});\n\n// ============================================================\n// Orbit camera\n// ============================================================\nlet azimuth   = 0.5;\nlet elevation = 0.35;\nlet distance  = 140;\n\ncanvas.addEventListener('pointerdown', (e) => {\n  canvas.setPointerCapture(e.pointerId);\n  let lastX = e.clientX, lastY = e.clientY;\n  const move = (ev) => {\n    azimuth   -= (ev.clientX - lastX) * 0.005;\n    elevation  = Math.max(-1.5, Math.min(1.5, elevation + (ev.clientY - lastY) * 0.005));\n    lastX = ev.clientX; lastY = ev.clientY;\n  };\n  const up = () => { canvas.removeEventListener('pointermove', move); canvas.removeEventListener('pointerup', up); };\n  canvas.addEventListener('pointermove', move);\n  canvas.addEventListener('pointerup', up);\n});\ncanvas.addEventListener('wheel', (e) => {\n  distance = Math.max(20, Math.min(400, distance * (1 + e.deltaY * 0.001)));\n  e.preventDefault();\n}, { passive: false });\n\n// ============================================================\n// Matrix helpers\n// ============================================================\nfunction perspective(fov, aspect, near, far) {\n  const f = 1 / Math.tan(fov / 2);\n  const nf = 1 / (near - far);\n  return new Float32Array([\n    f / aspect, 0, 0, 0,\n    0, f, 0, 0,\n    0, 0, (far + near) * nf, -1,\n    0, 0, 2 * far * near * nf, 0,\n  ]);\n}\n\nfunction lookAt(eye, target, up) {\n  const zx = eye[0]-target[0], zy = eye[1]-target[1], zz = eye[2]-target[2];\n  let len = 1 / Math.hypot(zx, zy, zz);\n  const z0=zx*len, z1=zy*len, z2=zz*len;\n  const x0 = up[1]*z2 - up[2]*z1, x1 = up[2]*z0 - up[0]*z2, x2 = up[0]*z1 - up[1]*z0;\n  len = Math.hypot(x0,x1,x2); const rl = len ? 1/len : 0;\n  const r0=x0*rl, r1=x1*rl, r2=x2*rl;\n  const u0=z1*r2-z2*r1, u1=z2*r0-z0*r2, u2=z0*r1-z1*r0;\n  return new Float32Array([\n    r0, u0, z0, 0,\n    r1, u1, z1, 0,\n    r2, u2, z2, 0,\n    -(r0*eye[0]+r1*eye[1]+r2*eye[2]),\n    -(u0*eye[0]+u1*eye[1]+u2*eye[2]),\n    -(z0*eye[0]+z1*eye[1]+z2*eye[2]),\n    1,\n  ]);\n}\n\nfunction mat4Mul(a, b) {\n  const o = new Float32Array(16);\n  for (let i = 0; i < 4; i++)\n    for (let j = 0; j < 4; j++)\n      o[j*4+i] = a[i]*b[j*4] + a[4+i]*b[j*4+1] + a[8+i]*b[j*4+2] + a[12+i]*b[j*4+3];\n  return o;\n}\n\n// ============================================================\n// FPS + Main loop + Benchmark reporting\n// ============================================================\nconst frameTimes = [];\nlet lastTime = performance.now();\nconst hud = document.getElementById('hud');\nlet benchFrame = 0, benchDone = false;\n\nfunction frame() {\n  const now = performance.now();\n  const dt = now - lastTime;\n  lastTime = now;\n  benchFrame++;\n  if (benchFrame > 30) frameTimes.push(dt);\n  if (frameTimes.length > 200) frameTimes.shift();\n\n  const display = frameTimes.length ? frameTimes : [16.6];\n  const avgMs = display.reduce((a,b) => a+b, 0) / display.length;\n  hud.textContent = `${NUM_BOIDS.toLocaleString()} boids | ${(1000/avgMs).toFixed(0)} fps | ${avgMs.toFixed(1)} ms`;\n\n  if (benchmarkBoids && frameTimes.length >= 120 && !benchDone) {\n    benchDone = true;\n    const sorted = [...frameTimes].sort((a,b) => a - b);\n    const avg = sorted.reduce((a,b) => a+b, 0) / sorted.length;\n    const p99 = sorted[Math.floor(sorted.length * 0.99)];\n    fetch('/api/bench_result', { method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ num_boids: NUM_BOIDS, frames: sorted.length,\n        avg_ms: +avg.toFixed(2), p99_ms: +p99.toFixed(2),\n        min_ms: +sorted[0].toFixed(2), max_ms: +sorted[sorted.length-1].toFixed(2) }),\n    }).catch(() => {});\n    hud.textContent += ' | BENCHMARK COMPLETE';\n  }\n\n\n\n  const eye = [\n    distance * Math.cos(elevation) * Math.sin(azimuth),\n    distance * Math.sin(elevation),\n    distance * Math.cos(elevation) * Math.cos(azimuth),\n  ];\n  const aspect = canvas.width / canvas.height;\n  const proj = perspective(Math.PI / 3, aspect, 1.0, 600);\n  const view = lookAt(eye, [0,0,0], [0,1,0]);\n  const vp = mat4Mul(proj, view);\n\n  const encoder = device.createCommandEncoder();\n  const simSteps = Math.max(1, Math.round(currentParams.simSpeed ?? 1));\n  for (let s = 0; s < simSteps; s++) {\n    simulation.update(encoder, s === simSteps - 1, neighborMode);\n  }\n  const ar = autoRangeCb.checked;\n  renderer.render(encoder, vp, {\n    gradientId: currentParams.gradientId ?? 0,\n    colorSource: currentParams.colorSource ?? 0,\n    gain: currentParams.gain ?? 0.5,\n    autoRange: ar, autoMin: simulation.autoMin, autoMax: simulation.autoMax,\n    falloff, brightness, particleScale, sphereRadius: currentParams.sphereRadius ?? 100,\n    renderMode, cameraPos: eye, bloomEnabled, bloomThreshold, bloomIntensity,\n    numBoids: NUM_BOIDS, sim: simulation,\n  });\n  device.queue.submit([encoder.finish()]);\n  if (ar) simulation.readStats();\n\n  requestAnimationFrame(frame);\n}\nrequestAnimationFrame(frame);\n\nfunction showError(msg) {\n  document.getElementById('hud').remove();\n  const d = document.createElement('div'); d.id = 'error'; d.textContent = msg;\n  document.body.appendChild(d);\n}\n</script>\n</body>\n</html>\n","numLines":698,"startLine":1,"totalLines":698}}}
