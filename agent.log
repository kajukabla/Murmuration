{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B7NzZMhz4Q9bGG7oo7P2UU","type":"tool_result","content":"     1→// === 3D Flocking Compute Shader with Spatial Hashing ===\n     2→\n     3→struct SimParams {\n     4→  num_boids: u32,\n     5→  grid_size: u32,\n     6→  grid_cells: u32,\n     7→  world_size: f32,\n     8→  cell_size: f32,\n     9→  visual_range: f32,\n    10→  visual_range_sq: f32,\n    11→  separation_dist: f32,\n    12→  separation_dist_sq: f32,\n    13→  align_factor: f32,\n    14→  cohesion_factor: f32,\n    15→  separation_factor: f32,\n    16→  max_speed: f32,\n    17→  min_speed: f32,\n    18→  dt: f32,\n    19→  turn_factor: f32,\n    20→  smoothing: f32,\n    21→  sim_speed: f32,\n    22→  size_randomness: f32,\n    23→  drag_factor: f32,\n    24→  gradient_id: u32,\n    25→  color_source: u32,\n    26→  _pad0: u32,\n    27→  _pad1: u32,\n    28→}\n    29→\n    30→struct Boid {\n    31→  pos: vec3f,\n    32→  size_factor: f32,\n    33→  vel: vec3f,\n    34→  speed: f32,\n    35→  heading: vec3f,\n    36→  neighbor_count: f32,\n    37→  dir_change: f32,\n    38→  flock_alignment: f32,\n    39→  sep_pressure: f32,\n    40→  density: f32,\n    41→}\n    42→\n    43→@group(0) @binding(0) var<uniform> params: SimParams;\n    44→@group(0) @binding(1) var<storage, read_write> boids_src: array<Boid>;\n    45→@group(0) @binding(2) var<storage, read_write> boids_dst: array<Boid>;\n    46→@group(0) @binding(3) var<storage, read_write> cell_counts: array<atomic<u32>>;\n    47→@group(0) @binding(4) var<storage, read_write> cell_offsets: array<u32>;\n    48→@group(0) @binding(5) var<storage, read_write> boid_cells: array<u32>;\n    49→@group(0) @binding(6) var<storage, read_write> sorted_indices: array<u32>;\n    50→@group(0) @binding(7) var<storage, read_write> scatter_counters: array<atomic<u32>>;\n    51→\n    52→fn get_cell(pos: vec3f) -> vec3u {\n    53→  let half = params.world_size * 0.5;\n    54→  return vec3u(clamp(\n    55→    vec3i(floor((pos + vec3f(half)) / params.cell_size)),\n    56→    vec3i(0),\n    57→    vec3i(i32(params.grid_size) - 1)\n    58→  ));\n    59→}\n    60→\n    61→fn cell_index(c: vec3u) -> u32 {\n    62→  return c.x + c.y * params.grid_size + c.z * params.grid_size * params.grid_size;\n    63→}\n    64→\n    65→@compute @workgroup_size(64)\n    66→fn clear_grid(@builtin(global_invocation_id) id: vec3u) {\n    67→  let i = id.x;\n    68→  if (i >= params.grid_cells) { return; }\n    69→  atomicStore(&cell_counts[i], 0u);\n    70→  atomicStore(&scatter_counters[i], 0u);\n    71→}\n    72→\n    73→@compute @workgroup_size(64)\n    74→fn assign_cells(@builtin(global_invocation_id) id: vec3u) {\n    75→  let i = id.x;\n    76→  if (i >= params.num_boids) { return; }\n    77→  let cell = cell_index(get_cell(boids_src[i].pos));\n    78→  boid_cells[i] = cell;\n    79→  atomicAdd(&cell_counts[cell], 1u);\n    80→}\n    81→\n    82→const SCAN_WG: u32 = 256u;\n    83→var<workgroup> scan_sums: array<u32, 256>;\n    84→\n    85→@compute @workgroup_size(256)\n    86→fn prefix_sum(@builtin(local_invocation_id) lid: vec3u) {\n    87→  let tid = lid.x;\n    88→  let chunk = (params.grid_cells + SCAN_WG - 1u) / SCAN_WG;\n    89→  let start = tid * chunk;\n    90→  let end = min(start + chunk, params.grid_cells);\n    91→  var local_total = 0u;\n    92→  for (var i = start; i < end; i++) {\n    93→    let count = atomicLoad(&cell_counts[i]);\n    94→    cell_offsets[i] = local_total;\n    95→    local_total += count;\n    96→  }\n    97→  scan_sums[tid] = local_total;\n    98→  workgroupBarrier();\n    99→  for (var stride = 1u; stride < SCAN_WG; stride *= 2u) {\n   100→    let val = select(0u, scan_sums[tid - stride], tid >= stride);\n   101→    workgroupBarrier();\n   102→    scan_sums[tid] += val;\n   103→    workgroupBarrier();\n   104→  }\n   105→  let prefix = select(0u, scan_sums[tid - 1u], tid > 0u);\n   106→  for (var i = start; i < end; i++) {\n   107→    cell_offsets[i] += prefix;\n   108→  }\n   109→}\n   110→\n   111→@compute @workgroup_size(64)\n   112→fn scatter(@builtin(global_invocation_id) id: vec3u) {\n   113→  let i = id.x;\n   114→  if (i >= params.num_boids) { return; }\n   115→  let cell = boid_cells[i];\n   116→  let local_offset = atomicAdd(&scatter_counters[cell], 1u);\n   117→  sorted_indices[cell_offsets[cell] + local_offset] = i;\n   118→}\n   119→\n   120→@compute @workgroup_size(64)\n   121→fn flock(@builtin(global_invocation_id) id: vec3u) {\n   122→  let i = id.x;\n   123→  if (i >= params.num_boids) { return; }\n   124→\n   125→  let boid = boids_src[i];\n   126→  let my_grid = get_cell(boid.pos);\n   127→\n   128→  var sep = vec3f(0.0);\n   129→  var ali = vec3f(0.0);\n   130→  var coh = vec3f(0.0);\n   131→  var n_align = 0u;\n   132→  var n_sep   = 0u;\n   133→\n   134→  let gs = i32(params.grid_size);\n   135→  let mg = vec3i(my_grid);\n   136→  let lo = max(mg - vec3i(1), vec3i(0));\n   137→  let hi = min(mg + vec3i(1), vec3i(gs - 1));\n   138→\n   139→  for (var nz = lo.z; nz <= hi.z; nz++) {\n   140→    let zoff = u32(nz) * params.grid_size * params.grid_size;\n   141→    for (var ny = lo.y; ny <= hi.y; ny++) {\n   142→      let yzoff = u32(ny) * params.grid_size + zoff;\n   143→      for (var nx = lo.x; nx <= hi.x; nx++) {\n   144→        let nc = u32(nx) + yzoff;\n   145→        let start = cell_offsets[nc];\n   146→        let end_val = select(cell_offsets[nc + 1u], params.num_boids, nc + 1u >= params.grid_cells);\n   147→        if (start >= end_val) { continue; }\n   148→        for (var j = start; j < end_val; j++) {\n   149→          let other_idx = sorted_indices[j];\n   150→          if (other_idx == i) { continue; }\n   151→          let other_pos = boids_src[other_idx].pos;\n   152→          let diff = boid.pos - other_pos;\n   153→          let d2 = dot(diff, diff);\n   154→          if (d2 < params.visual_range_sq && d2 > 0.0001) {\n   155→            ali += boids_src[other_idx].vel;\n   156→            coh += other_pos;\n   157→            n_align++;\n   158→            if (d2 < params.separation_dist_sq) {\n   159→              sep += diff * (1.0 - d2 / params.separation_dist_sq);\n   160→              n_sep++;\n   161→            }\n   162→          }\n   163→        }\n   164→        if (n_align >= 10u) { break; }\n   165→      }\n   166→      if (n_align >= 10u) { break; }\n   167→    }\n   168→    if (n_align >= 10u) { break; }\n   169→  }\n   170→\n   171→  var new_vel = boid.vel;\n   172→  var avg_vel = vec3f(0.0);\n   173→  if (n_align > 0u) {\n   174→    let nf = f32(n_align);\n   175→    avg_vel = ali / nf;\n   176→    let avg_pos = coh / nf;\n   177→    new_vel += (avg_vel - boid.vel) * params.align_factor;\n   178→    new_vel += (avg_pos - boid.pos) * params.cohesion_factor;\n   179→  }\n   180→  if (n_sep > 0u) {\n   181→    new_vel += sep * params.separation_factor;\n   182→  }\n   183→\n   184→  let margin = params.world_size * 0.4;\n   185→  let inv_soft = 1.0 / (params.world_size * 0.1);\n   186→  let btf = params.turn_factor;\n   187→  let low_push = max(vec3f(0.0), (-margin - boid.pos) * inv_soft);\n   188→  let high_push = max(vec3f(0.0), (boid.pos - vec3f(margin)) * inv_soft);\n   189→  new_vel += btf * (low_push - high_push);\n   190→\n   191→  let old_speed = length(boid.vel);\n   192→  var old_dir = boid.vel;\n   193→  if (old_speed > 0.001) { old_dir = old_dir / old_speed; }\n   194→  else { old_dir = vec3f(1.0, 0.0, 0.0); }\n   195→  let desired_speed = length(new_vel);\n   196→  var desired_dir = new_vel;\n   197→  if (desired_speed > 0.001) { desired_dir = desired_dir / desired_speed; }\n   198→  else { desired_dir = old_dir; }\n   199→  let final_dir = normalize(mix(old_dir, desired_dir, params.smoothing));\n   200→\n   201→  let drag_scale = 1.0 / mix(1.0, boid.size_factor, params.drag_factor);\n   202→  var final_speed = mix(old_speed, desired_speed, 0.15);\n   203→  final_speed = clamp(final_speed, params.min_speed * drag_scale, params.max_speed * drag_scale);\n   204→  new_vel = final_dir * final_speed;\n   205→\n   206→  let dir_change_val = 1.0 - clamp(dot(old_dir, final_dir), -1.0, 1.0);\n   207→  let effective_dt = params.dt;\n   208→\n   209→  boids_dst[i].pos = boid.pos + new_vel * effective_dt;\n   210→  boids_dst[i].vel = new_vel;\n   211→  boids_dst[i].size_factor = boid.size_factor;\n   212→\n   213→  // Heading: use final_dir directly (already normalized, saves 2 normalize+length+mix)\n   214→  boids_dst[i].heading = final_dir;\n   215→\n   216→  boids_dst[i].speed = final_speed;\n   217→  boids_dst[i].neighbor_count = f32(n_align);\n   218→  boids_dst[i].dir_change = dir_change_val;\n   219→  // Approximate alignment: dot of velocity directions (cheap, no extra normalize)\n   220→  let vel_d2 = dot(boid.vel, boid.vel);\n   221→  let avg_d2 = dot(avg_vel, avg_vel);\n   222→  boids_dst[i].flock_alignment = select(dot(boid.vel, avg_vel) * inverseSqrt(vel_d2 * avg_d2), 0.0, vel_d2 < 0.001 || avg_d2 < 0.001);\n   223→  boids_dst[i].sep_pressure = dot(sep, sep);\n   224→  boids_dst[i].density = f32(n_align) * 0.0625;  // n/16, normalized to neighbor cap\n   225→}\n   226→\n   227→// === Auto-range: compute min/max of selected color source metric ===\n   228→// Uses separate bind group: @group(1) for stats buffer\n   229→@group(1) @binding(0) var<storage, read_write> stats: array<atomic<u32>, 2>;\n   230→\n   231→fn get_metric(boid: Boid, source: u32) -> f32 {\n   232→  switch (source) {\n   233→    case 0u: { return dot(normalize(boid.heading + vec3f(0.0001, 0.0, 0.0)), vec3f(0.3, 0.4, 0.3)) + 0.5; }\n   234→    case 1u: { return boid.speed; }\n   235→    case 2u: { return boid.dir_change; }\n   236→    case 3u: { return boid.neighbor_count; }\n   237→    case 4u: { return (boid.pos.y + 50.0) / 100.0; }\n   238→    case 5u: { return length(boid.pos) / 50.0; }\n   239→    case 6u: { return boid.flock_alignment * 0.5 + 0.5; }\n   240→    case 7u: { return boid.sep_pressure; }\n   241→    case 8u: { return boid.density; }\n   242→    case 9u: { return 0.5; } // Boid ID is static, no range needed\n   243→    default: { return 0.5; }\n   244→  }\n   245→}\n   246→\n   247→@compute @workgroup_size(64)\n   248→fn clear_stats(@builtin(global_invocation_id) id: vec3u) {\n   249→  if (id.x == 0u) {\n   250→    // Init min to large positive, max to 0 (as bitcast u32)\n   251→    atomicStore(&stats[0], bitcast<u32>(1e10));\n   252→    atomicStore(&stats[1], 0u);\n   253→  }\n   254→}\n   255→\n   256→@compute @workgroup_size(64)\n   257→fn compute_stats(@builtin(global_invocation_id) id: vec3u) {\n   258→  let i = id.x;\n   259→  if (i >= params.num_boids) { return; }\n   260→  let val = get_metric(boids_src[i], params.color_source);\n   261→  let val_bits = bitcast<u32>(val);\n   262→  // Atomic min: smaller float = smaller u32 for positive floats\n   263→  atomicMin(&stats[0], val_bits);\n   264→  atomicMax(&stats[1], val_bits);\n   265→}\n   266→"}]},"parent_tool_use_id":null,"session_id":"7ffa1055-e97b-4b91-bfbd-0531ff2ae3b8","uuid":"511a5b05-968d-4e3a-838d-a6d478f96793","timestamp":"2026-03-22T22:44:19.792Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/aaronlemke/AI/Murmuration/shader.wgsl","content":"// === 3D Flocking Compute Shader with Spatial Hashing ===\n\nstruct SimParams {\n  num_boids: u32,\n  grid_size: u32,\n  grid_cells: u32,\n  world_size: f32,\n  cell_size: f32,\n  visual_range: f32,\n  visual_range_sq: f32,\n  separation_dist: f32,\n  separation_dist_sq: f32,\n  align_factor: f32,\n  cohesion_factor: f32,\n  separation_factor: f32,\n  max_speed: f32,\n  min_speed: f32,\n  dt: f32,\n  turn_factor: f32,\n  smoothing: f32,\n  sim_speed: f32,\n  size_randomness: f32,\n  drag_factor: f32,\n  gradient_id: u32,\n  color_source: u32,\n  _pad0: u32,\n  _pad1: u32,\n}\n\nstruct Boid {\n  pos: vec3f,\n  size_factor: f32,\n  vel: vec3f,\n  speed: f32,\n  heading: vec3f,\n  neighbor_count: f32,\n  dir_change: f32,\n  flock_alignment: f32,\n  sep_pressure: f32,\n  density: f32,\n}\n\n@group(0) @binding(0) var<uniform> params: SimParams;\n@group(0) @binding(1) var<storage, read_write> boids_src: array<Boid>;\n@group(0) @binding(2) var<storage, read_write> boids_dst: array<Boid>;\n@group(0) @binding(3) var<storage, read_write> cell_counts: array<atomic<u32>>;\n@group(0) @binding(4) var<storage, read_write> cell_offsets: array<u32>;\n@group(0) @binding(5) var<storage, read_write> boid_cells: array<u32>;\n@group(0) @binding(6) var<storage, read_write> sorted_indices: array<u32>;\n@group(0) @binding(7) var<storage, read_write> scatter_counters: array<atomic<u32>>;\n\nfn get_cell(pos: vec3f) -> vec3u {\n  let half = params.world_size * 0.5;\n  return vec3u(clamp(\n    vec3i(floor((pos + vec3f(half)) / params.cell_size)),\n    vec3i(0),\n    vec3i(i32(params.grid_size) - 1)\n  ));\n}\n\nfn cell_index(c: vec3u) -> u32 {\n  return c.x + c.y * params.grid_size + c.z * params.grid_size * params.grid_size;\n}\n\n@compute @workgroup_size(64)\nfn clear_grid(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.grid_cells) { return; }\n  atomicStore(&cell_counts[i], 0u);\n  atomicStore(&scatter_counters[i], 0u);\n}\n\n@compute @workgroup_size(64)\nfn assign_cells(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.num_boids) { return; }\n  let cell = cell_index(get_cell(boids_src[i].pos));\n  boid_cells[i] = cell;\n  atomicAdd(&cell_counts[cell], 1u);\n}\n\nconst SCAN_WG: u32 = 256u;\nvar<workgroup> scan_sums: array<u32, 256>;\n\n@compute @workgroup_size(256)\nfn prefix_sum(@builtin(local_invocation_id) lid: vec3u) {\n  let tid = lid.x;\n  let chunk = (params.grid_cells + SCAN_WG - 1u) / SCAN_WG;\n  let start = tid * chunk;\n  let end = min(start + chunk, params.grid_cells);\n  var local_total = 0u;\n  for (var i = start; i < end; i++) {\n    let count = atomicLoad(&cell_counts[i]);\n    cell_offsets[i] = local_total;\n    local_total += count;\n  }\n  scan_sums[tid] = local_total;\n  workgroupBarrier();\n  for (var stride = 1u; stride < SCAN_WG; stride *= 2u) {\n    let val = select(0u, scan_sums[tid - stride], tid >= stride);\n    workgroupBarrier();\n    scan_sums[tid] += val;\n    workgroupBarrier();\n  }\n  let prefix = select(0u, scan_sums[tid - 1u], tid > 0u);\n  for (var i = start; i < end; i++) {\n    cell_offsets[i] += prefix;\n  }\n}\n\n@compute @workgroup_size(64)\nfn scatter(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.num_boids) { return; }\n  let cell = boid_cells[i];\n  let local_offset = atomicAdd(&scatter_counters[cell], 1u);\n  sorted_indices[cell_offsets[cell] + local_offset] = i;\n}\n\n@compute @workgroup_size(64)\nfn flock(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.num_boids) { return; }\n\n  let boid = boids_src[i];\n  let my_grid = get_cell(boid.pos);\n\n  var sep = vec3f(0.0);\n  var ali = vec3f(0.0);\n  var coh = vec3f(0.0);\n  var n_align = 0u;\n  var n_sep   = 0u;\n\n  let gs = i32(params.grid_size);\n  let mg = vec3i(my_grid);\n  let lo = max(mg - vec3i(1), vec3i(0));\n  let hi = min(mg + vec3i(1), vec3i(gs - 1));\n\n  for (var nz = lo.z; nz <= hi.z; nz++) {\n    let zoff = u32(nz) * params.grid_size * params.grid_size;\n    for (var ny = lo.y; ny <= hi.y; ny++) {\n      let yzoff = u32(ny) * params.grid_size + zoff;\n      for (var nx = lo.x; nx <= hi.x; nx++) {\n        let nc = u32(nx) + yzoff;\n        let start = cell_offsets[nc];\n        let end_val = select(cell_offsets[nc + 1u], params.num_boids, nc + 1u >= params.grid_cells);\n        if (start >= end_val) { continue; }\n        for (var j = start; j < end_val; j++) {\n          let other_idx = sorted_indices[j];\n          if (other_idx == i) { continue; }\n          let other_pos = boids_src[other_idx].pos;\n          let diff = boid.pos - other_pos;\n          let d2 = dot(diff, diff);\n          if (d2 < params.visual_range_sq && d2 > 0.0001) {\n            ali += boids_src[other_idx].vel;\n            coh += other_pos;\n            n_align++;\n            if (d2 < params.separation_dist_sq) {\n              sep += diff * (1.0 - d2 / params.separation_dist_sq);\n              n_sep++;\n            }\n          }\n        }\n        if (n_align >= 10u) { break; }\n      }\n      if (n_align >= 10u) { break; }\n    }\n    if (n_align >= 10u) { break; }\n  }\n\n  var new_vel = boid.vel;\n  var avg_vel = vec3f(0.0);\n  if (n_align > 0u) {\n    let nf = f32(n_align);\n    avg_vel = ali / nf;\n    let avg_pos = coh / nf;\n    new_vel += (avg_vel - boid.vel) * params.align_factor;\n    new_vel += (avg_pos - boid.pos) * params.cohesion_factor;\n  }\n  if (n_sep > 0u) {\n    new_vel += sep * params.separation_factor;\n  }\n\n  let margin = params.world_size * 0.4;\n  let inv_soft = 1.0 / (params.world_size * 0.1);\n  let btf = params.turn_factor;\n  let low_push = max(vec3f(0.0), (-margin - boid.pos) * inv_soft);\n  let high_push = max(vec3f(0.0), (boid.pos - vec3f(margin)) * inv_soft);\n  new_vel += btf * (low_push - high_push);\n\n  let old_speed = length(boid.vel);\n  var old_dir = boid.vel;\n  if (old_speed > 0.001) { old_dir = old_dir / old_speed; }\n  else { old_dir = vec3f(1.0, 0.0, 0.0); }\n  let desired_speed = length(new_vel);\n  var desired_dir = new_vel;\n  if (desired_speed > 0.001) { desired_dir = desired_dir / desired_speed; }\n  else { desired_dir = old_dir; }\n  let final_dir = normalize(mix(old_dir, desired_dir, params.smoothing));\n\n  let drag_scale = 1.0 / mix(1.0, boid.size_factor, params.drag_factor);\n  var final_speed = mix(old_speed, desired_speed, 0.15);\n  final_speed = clamp(final_speed, params.min_speed * drag_scale, params.max_speed * drag_scale);\n  new_vel = final_dir * final_speed;\n\n  let dir_change_val = 1.0 - clamp(dot(old_dir, final_dir), -1.0, 1.0);\n  let effective_dt = params.dt;\n\n  boids_dst[i].pos = boid.pos + new_vel * effective_dt;\n  boids_dst[i].vel = new_vel;\n  boids_dst[i].size_factor = boid.size_factor;\n\n  // Heading: use final_dir directly (already normalized, saves 2 normalize+length+mix)\n  boids_dst[i].heading = final_dir;\n\n  boids_dst[i].speed = final_speed;\n  boids_dst[i].neighbor_count = f32(n_align);\n  boids_dst[i].dir_change = dir_change_val;\n  // Approximate alignment: dot of velocity directions (cheap, no extra normalize)\n  let vel_d2 = dot(boid.vel, boid.vel);\n  let avg_d2 = dot(avg_vel, avg_vel);\n  boids_dst[i].flock_alignment = select(dot(boid.vel, avg_vel) * inverseSqrt(vel_d2 * avg_d2), 0.0, vel_d2 < 0.001 || avg_d2 < 0.001);\n  boids_dst[i].sep_pressure = dot(sep, sep);\n  boids_dst[i].density = f32(n_align) * 0.0625;  // n/16, normalized to neighbor cap\n}\n\n// === Auto-range: compute min/max of selected color source metric ===\n// Uses separate bind group: @group(1) for stats buffer\n@group(1) @binding(0) var<storage, read_write> stats: array<atomic<u32>, 2>;\n\nfn get_metric(boid: Boid, source: u32) -> f32 {\n  switch (source) {\n    case 0u: { return dot(normalize(boid.heading + vec3f(0.0001, 0.0, 0.0)), vec3f(0.3, 0.4, 0.3)) + 0.5; }\n    case 1u: { return boid.speed; }\n    case 2u: { return boid.dir_change; }\n    case 3u: { return boid.neighbor_count; }\n    case 4u: { return (boid.pos.y + 50.0) / 100.0; }\n    case 5u: { return length(boid.pos) / 50.0; }\n    case 6u: { return boid.flock_alignment * 0.5 + 0.5; }\n    case 7u: { return boid.sep_pressure; }\n    case 8u: { return boid.density; }\n    case 9u: { return 0.5; } // Boid ID is static, no range needed\n    default: { return 0.5; }\n  }\n}\n\n@compute @workgroup_size(64)\nfn clear_stats(@builtin(global_invocation_id) id: vec3u) {\n  if (id.x == 0u) {\n    // Init min to large positive, max to 0 (as bitcast u32)\n    atomicStore(&stats[0], bitcast<u32>(1e10));\n    atomicStore(&stats[1], 0u);\n  }\n}\n\n@compute @workgroup_size(64)\nfn compute_stats(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.num_boids) { return; }\n  let val = get_metric(boids_src[i], params.color_source);\n  let val_bits = bitcast<u32>(val);\n  // Atomic min: smaller float = smaller u32 for positive floats\n  atomicMin(&stats[0], val_bits);\n  atomicMax(&stats[1], val_bits);\n}\n","numLines":266,"startLine":1,"totalLines":266}}}
