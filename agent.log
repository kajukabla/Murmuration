   48→    f[9]  = p.alignFactor;\n    49→    f[10] = p.cohesionFactor;\n    50→    f[11] = p.separationFactor;\n    51→    f[12] = p.maxSpeed;\n    52→    f[13] = p.minSpeed;\n    53→    f[15] = p.turnFactor;\n    54→    f[16] = p.smoothing;\n    55→    f[17] = p.simSpeed ?? 1.0;\n    56→    f[18] = p.sizeRandomness ?? 0.0;\n    57→    f[19] = p.dragFactor ?? 0.3;\n    58→    u[20] = p.gradientId ?? 0;\n    59→    u[21] = p.colorSource ?? 0;\n    60→    f[22] = p.sphereRadius ?? 100.0;\n    61→    u[23] = frameCount;\n    62→    device.queue.writeBuffer(paramsBuffer, 0, paramsData);\n    63→  }\n    64→\n    65→  const paramsBuffer = device.createBuffer({\n    66→    size: PARAMS_SIZE,\n    67→    usage: GPUBufferUsage.UNIFORM | GPUBufferUsage.COPY_DST,\n    68→  });\n    69→\n    70→  // --- Boid buffers (ping-pong) ---\n    71→  // Boid struct: 64 bytes = 16 floats\n    72→  // pos(3) + size_factor(1) + vel(3) + speed(1) + heading(3) + neighbor_count(1) +\n    73→  // dir_change(1) + flock_alignment(1) + sep_pressure(1) + density(1)\n    74→  const BOID_FLOATS = 16;\n    75→  const boidBytes = numBoids * BOID_FLOATS * 4;\n    76→  const initData = new Float32Array(numBoids * BOID_FLOATS);\n    77→  for (let i = 0; i < numBoids; i++) {\n    78→    const o = i * BOID_FLOATS;\n    79→    const r = sphereRadius * 0.3; // spawn within inner 30% of sphere\n    80→    // pos\n    81→    // Spawn inside sphere using rejection sampling\n    82→    let px, py, pz;\n    83→    do {\n    84→      px = (Math.random() - 0.5) * 2;\n    85→      py = (Math.random() - 0.5) * 2;\n    86→      pz = (Math.random() - 0.5) * 2;\n    87→    } while (px*px + py*py + pz*pz > 1);\n    88→    initData[o]     = px * r;\n    89→    initData[o + 1] = py * r;\n    90→    initData[o + 2] = pz * r;\n    91→    // size_factor (default 1.0, randomized via sizeRandomness param)\n    92→    initData[o + 3] = 1.0;\n    93→    // vel\n    94→    const vx = (Math.random() - 0.5) * 4;\n    95→    const v