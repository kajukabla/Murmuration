{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012zLsn2KT1sXZVYdUkzFSDs","type":"tool_result","content":"     1→#!/usr/bin/env -S deno run --unstable-webgpu --allow-read\n     2→/**\n     3→ * Headless WebGPU benchmark with murmuration quality metrics.\n     4→ * Runs simulation to steady state, then measures behavioral quality.\n     5→ *\n     6→ * Output JSON includes:\n     7→ * - Frame timing (avg_ms, p99_ms)\n     8→ * - Murmuration quality score (0-1) and sub-metrics\n     9→ *\n    10→ * Usage: deno run --unstable-webgpu --allow-read benchmark.ts [--boids N] [--frames N]\n    11→ */\n    12→\n    13→const args = parseArgs(Deno.args);\n    14→const NUM_BOIDS = args.boids ?? 20000;\n    15→const NUM_FRAMES = args.frames ?? 60;\n    16→const WARMUP_FRAMES = 3750; // ~1 minute sim time at dt=0.016\n    17→\n    18→const simCode = await Deno.readTextFile(\"simulation.js\");\n    19→const WORKGROUP_SIZE = parseInt(simCode.match(/const WORKGROUP_SIZE\\s*=\\s*(\\d+)/)?.[1] ?? \"64\");\n    20→const PARAMS_SIZE = parseInt(simCode.match(/const PARAMS_SIZE\\s*=\\s*(\\d+)/)?.[1] ?? \"96\");\n    21→\n    22→const GRID_SIZE = Math.max(8, Math.min(128, Math.round(Math.cbrt(NUM_BOIDS) * 0.8)));\n    23→const GRID_CELLS = GRID_SIZE ** 3;\n    24→const WORLD_SIZE = 100.0;\n    25→const CELL_SIZE = WORLD_SIZE / GRID_SIZE;\n    26→\n    27→const adapter = await navigator.gpu?.requestAdapter();\n    28→if (!adapter) { console.error(\"No WebGPU adapter\"); Deno.exit(1); }\n    29→const device = await adapter.requestDevice();\n    30→\n    31→const shaderCode = await Deno.readTextFile(\"shader.wgsl\");\n    32→const module = device.createShaderModule({ code: shaderCode });\n    33→\n    34→// --- Params ---\n    35→const paramsData = new ArrayBuffer(PARAMS_SIZE);\n    36→const u32 = new Uint32Array(paramsData);\n    37→const f32 = new Float32Array(paramsData);\n    38→\n    39→u32[0] = NUM_BOIDS;\n    40→u32[1] = GRID_SIZE;\n    41→u32[2] = GRID_CELLS;\n    42→f32[3] = WORLD_SIZE;\n    43→f32[4] = CELL_SIZE;\n    44→// Read preset values from index.html (Murmuration preset)\n    45→const htmlCode = await Deno.readTextFile(\"index.html\");\n    46→const presetMatch = htmlCode.match(/'Murmuration':\\s*\\{([^}]+)\\}/);\n    47→const preset: Record<string, number> = {};\n    48→if (presetMatch) {\n    49→  for (const m of presetMatch[1].matchAll(/(\\w+):\\s*([\\d.]+)/g)) {\n    50→    preset[m[1]] = parseFloat(m[2]);\n    51→  }\n    52→}\n    53→f32[5]  = preset.visualRange ?? 15.0;\n    54→f32[6]  = (preset.visualRange ?? 15.0) ** 2;\n    55→f32[7]  = preset.separationDist ?? 2.0;\n    56→f32[8]  = (preset.separationDist ?? 2.0) ** 2;\n    57→f32[9]  = preset.alignFactor ?? 0.12;\n    58→f32[10] = preset.cohesionFactor ?? 0.003;\n    59→f32[11] = preset.separationFactor ?? 0.08;\n    60→f32[12] = preset.maxSpeed ?? 8.0;\n    61→f32[13] = preset.minSpeed ?? 3.0;\n    62→f32[14] = 0.016;\n    63→f32[15] = preset.turnFactor ?? 0.3;\n    64→f32[16] = preset.smoothing ?? 0.10;\n    65→f32[17] = 1.0;  // sim_speed\n    66→f32[18] = 0.0;  // size_randomness\n    67→f32[19] = 0.0;  // drag_factor\n    68→u32[20] = 0;\n    69→u32[21] = 0;\n    70→f32[22] = preset.sphereRadius ?? 120.0;\n    71→u32[23] = 0;  // frame_count — updated each step\n    72→\n    73→const paramsBuffer = device.createBuffer({\n    74→  size: PARAMS_SIZE,\n    75→  usage: GPUBufferUsage.UNIFORM | GPUBufferUsage.COPY_DST,\n    76→});\n    77→\n    78→// --- Boid buffers ---\n    79→const BOID_FLOATS = 16;\n    80→const BOID_BYTES = NUM_BOIDS * BOID_FLOATS * 4;\n    81→const initData = new Float32Array(NUM_BOIDS * BOID_FLOATS);\n    82→const spawnR = WORLD_SIZE * 0.08;\n    83→for (let i = 0; i < NUM_BOIDS; i++) {\n    84→  const o = i * BOID_FLOATS;\n    85→  // Spawn in sphere\n    86→  let px, py, pz;\n    87→  do { px = (Math.random()-0.5)*2; py = (Math.random()-0.5)*2; pz = (Math.random()-0.5)*2; }\n    88→  while (px*px+py*py+pz*pz > 1);\n    89→  initData[o] = px * spawnR;\n    90→  initData[o+1] = py * spawnR;\n    91→  initData[o+2] = pz * spawnR;\n    92→  initData[o+3] = 1.0;\n    93→  const vx = (Math.random()-0.5)*4, vy = (Math.random()-0.5)*4, vz = (Math.random()-0.5)*4;\n    94→  initData[o+4] = vx; initData[o+5] = vy; initData[o+6] = vz;\n    95→  initData[o+7] = Math.hypot(vx,vy,vz);\n    96→  const vl = initData[o+7] || 1;\n    97→  initData[o+8] = vx/vl; initData[o+9] = vy/vl; initData[o+10] = vz/vl;\n    98→}\n    99→\n   100→function makeBuf(size: number, usage: number, data?: Float32Array) {\n   101→  const buf = device.createBuffer({ size, usage });\n   102→  if (data) device.queue.writeBuffer(buf, 0, data);\n   103→  return buf;\n   104→}\n   105→\n   106→const boidA = makeBuf(BOID_BYTES, GPUBufferUsage.STORAGE | GPUBufferUsage.COPY_DST, initData);\n   107→const boidB = makeBuf(BOID_BYTES, GPUBufferUsage.STORAGE | GPUBufferUsage.COPY_DST);\n   108→const cellCounts = makeBuf(GRID_CELLS * 4, GPUBufferUsage.STORAGE);\n   109→const cellOffsets = makeBuf(GRID_CELLS * 4, GPUBufferUsage.STORAGE);\n   110→const boidCells = makeBuf(NUM_BOIDS * 4, GPUBufferUsage.STORAGE);\n   111→const sortedIndices = makeBuf(NUM_BOIDS * 4, GPUBufferUsage.STORAGE);\n   112→const scatterCounters = makeBuf(GRID_CELLS * 4, GPUBufferUsage.STORAGE);\n   113→\n   114→// --- Metrics buffers (group 1) ---\n   115→const statsBuf = makeBuf(8, GPUBufferUsage.STORAGE);  // auto-range stats (binding 0)\n   116→const metricsBuf = makeBuf(64, GPUBufferUsage.STORAGE | GPUBufferUsage.COPY_SRC);  // quality metrics (binding 1)\n   117→const metricsReadBuf = device.createBuffer({\n   118→  size: 64, usage: GPUBufferUsage.MAP_READ | GPUBufferUsage.COPY_DST,\n   119→});\n   120→\n   121→// --- Bind group layouts ---\n   122→const bgl = device.createBindGroupLayout({\n   123→  entries: Array.from({ length: 8 }, (_, i) => ({\n   124→    binding: i, visibility: GPUShaderStage.COMPUTE,\n   125→    buffer: { type: (i === 0 ? \"uniform\" : \"storage\") as GPUBufferBindingType },\n   126→  })),\n   127→});\n   128→\n   129→const metricsBGL = device.createBindGroupLayout({\n   130→  entries: [\n   131→    { binding: 0, visibility: GPUShaderStage.COMPUTE, buffer: { type: \"storage\" as GPUBufferBindingType } },\n   132→    { binding: 1, visibility: GPUShaderStage.COMPUTE, buffer: { type: \"storage\" as GPUBufferBindingType } },\n   133→  ],\n   134→});\n   135→\n   136→// Sim pipelines use group(0) only\n   137→const simPipeLayout = device.createPipelineLayout({ bindGroupLayouts: [bgl] });\n   138→// Metrics pipelines use group(0) + group(1)\n   139→const metricsPipeLayout = device.createPipelineLayout({ bindGroupLayouts: [bgl, metricsBGL] });\n   140→\n   141→function makeBG(src: GPUBuffer, dst: GPUBuffer) {\n   142→  return device.createBindGroup({\n   143→    layout: bgl,\n   144→    entries: [\n   145→      { binding: 0, resource: { buffer: paramsBuffer } },\n   146→      { binding: 1, resource: { buffer: src } },\n   147→      { binding: 2, resource: { buffer: dst } },\n   148→      { binding: 3, resource: { buffer: cellCounts } },\n   149→      { binding: 4, resource: { buffer: cellOffsets } },\n   150→      { binding: 5, resource: { buffer: boidCells } },\n   151→      { binding: 6, resource: { buffer: sortedIndices } },\n   152→      { binding: 7, resource: { buffer: scatterCounters } },\n   153→    ],\n   154→  });\n   155→}\n   156→const bgA = makeBG(boidA, boidB);\n   157→const bgB = makeBG(boidB, boidA);\n   158→\n   159→const metricsBG = device.createBindGroup({\n   160→  layout: metricsBGL,\n   161→  entries: [\n   162→    { binding: 0, resource: { buffer: statsBuf } },\n   163→    { binding: 1, resource: { buffer: metricsBuf } },\n   164→  ],\n   165→});\n   166→\n   167→// --- Compute pipelines ---\n   168→const makeSP = (ep: string) => device.createComputePipeline({ layout: simPipeLayout, compute: { module, entryPoint: ep } });\n   169→const makeMP = (ep: string) => device.createComputePipeline({ layout: metricsPipeLayout, compute: { module, entryPoint: ep } });\n   170→\n   171→const clearPipe = makeSP(\"clear_grid\");\n   172→const assignPipe = makeSP(\"assign_cells\");\n   173→const prefixPipe = makeSP(\"prefix_sum\");\n   174→const scatterPipe = makeSP(\"scatter\");\n   175→const flockPipe = makeSP(\"flock\");\n   176→const clearMetricsPipe = makeMP(\"clear_metrics\");\n   177→const computeMetricsPipe = makeMP(\"compute_metrics\");\n   178→\n   179→const gridWG = Math.ceil(GRID_CELLS / WORKGROUP_SIZE);\n   180→const boidWG = Math.ceil(NUM_BOIDS / WORKGROUP_SIZE);\n   181→\n   182→function encodeFrame(encoder: GPUCommandEncoder, step: number) {\n   183→  // Update frame_count in params\n   184→  u32[23] = step;\n   185→  device.queue.writeBuffer(paramsBuffer, 0, new Uint8Array(paramsData));\n   186→\n   187→  const bg = step % 2 === 0 ? bgA : bgB;\n   188→  for (const [pipe, wg] of [[clearPipe, gridWG], [assignPipe, boidWG], [prefixPipe, 1], [scatterPipe, boidWG], [flockPipe, boidWG]] as [GPUComputePipeline, number][]) {\n   189→    const p = encoder.beginComputePass();\n   190→    p.setPipeline(pipe);\n   191→    p.setBindGroup(0, bg);\n   192→    p.dispatchWorkgroups(wg);\n   193→    p.end();\n   194→  }\n   195→}\n   196→\n   197→function encodeMetrics(encoder: GPUCommandEncoder, step: number) {\n   198→  const bg = step % 2 === 0 ? bgA : bgB;\n   199→  // Clear\n   200→  const c = encoder.beginComputePass();\n   201→  c.setPipeline(clearMetricsPipe);\n   202→  c.setBindGroup(0, bg);\n   203→  c.setBindGroup(1, metricsBG);\n   204→  c.dispatchWorkgroups(1);\n   205→  c.end();\n   206→  // Compute\n   207→  const s = encoder.beginComputePass();\n   208→  s.setPipeline(computeMetricsPipe);\n   209→  s.setBindGroup(0, bg);\n   210→  s.setBindGroup(1, metricsBG);\n   211→  s.dispatchWorkgroups(boidWG);\n   212→  s.end();\n   213→  // Copy to readback\n   214→  encoder.copyBufferToBuffer(metricsBuf, 0, metricsReadBuf, 0, 64);\n   215→}\n   216→\n   217→async function readMetrics(): Promise<Float32Array> {\n   218→  await metricsReadBuf.mapAsync(GPUMapMode.READ);\n   219→  const data = new Float32Array(metricsReadBuf.getMappedRange().slice(0));\n   220→  metricsReadBuf.unmap();\n   221→  return data;\n   222→}\n   223→\n   224→function computeScore(raw: Float32Array, raw2: Float32Array | null) {\n   225→  const n = raw[10] || 1; // total boids processed (slot 10, as u32 → read via f32)\n   226→  // Reinterpret slot 10 as u32\n   227→  const nBoids = new Uint32Array(raw.buffer)[10] || 1;\n   228→  const cohesionCount = new Uint32Array(raw.buffer)[0]; // slot 0: boids with 5+ neighbors (u32)\n   229→\n   230→  const cohesion_ratio = cohesionCount / nBoids;\n   231→  const avg_neighbors = raw[1] / nBoids; // slot 1: sum of neighbor_count\n   232→  const velocity_corr = raw[2] / nBoids; // slot 2: sum of flock_alignment\n   233→\n   234→  // Position variance for aspect ratio\n   235→  const mx = raw[3] / nBoids, my = raw[4] / nBoids, mz = raw[5] / nBoids;\n   236→  const vx = raw[6] / nBoids - mx*mx;\n   237→  const vy = raw[7] / nBoids - my*my;\n   238→  const vz = raw[8] / nBoids - mz*mz;\n   239→  const variances = [Math.max(vx, 0.01), Math.max(vy, 0.01), Math.max(vz, 0.01)].sort((a,b) => b-a);\n   240→  const aspect_ratio = variances[0] / variances[2]; // largest / smallest\n   241→\n   242→  // Density uniformity (CV of neighbor counts)\n   243→  const avg_n = raw[1] / nBoids;\n   244→  const avg_n2 = raw[9] / nBoids;\n   245→  const var_n = Math.max(0, avg_n2 - avg_n * avg_n);\n   246→  const density_cv = avg_n > 0.01 ? Math.sqrt(var_n) / avg_n : 10.0;\n   247→\n   248→  // Shape dynamics (compare two measurements)\n   249→  let dynamics = 0.05; // default if no second measurement\n   250→  if (raw2) {\n   251→    const n2 = new Uint32Array(raw2.buffer)[10] || 1;\n   252→    const mx2 = raw2[3]/n2, my2 = raw2[4]/n2, mz2 = raw2[5]/n2;\n   253→    const vx2 = raw2[6]/n2 - mx2*mx2, vy2 = raw2[7]/n2 - my2*my2, vz2 = raw2[8]/n2 - mz2*mz2;\n   254→    const vars2 = [Math.max(vx2,0.01), Math.max(vy2,0.01), Math.max(vz2,0.01)].sort((a,b) => b-a);\n   255→    const ar2 = vars2[0] / vars2[2];\n   256→    dynamics = Math.abs(aspect_ratio - ar2) / Math.max(aspect_ratio, 0.01);\n   257→  }\n   258→\n   259→  // Composite score\n   260→  const cr = Math.min(cohesion_ratio, 1.0);\n   261→  const vc = Math.max(velocity_corr, 0.0);\n   262→  const ar_norm = Math.min(aspect_ratio, 5.0) / 5.0;\n   263→  const du_norm = 1.0 / (1.0 + density_cv);\n   264→  const dyn_norm = Math.min(dynamics * 20, 1.0);\n   265→\n   266→  const score = cr * cr * vc * ar_norm * du_norm * dyn_norm;\n   267→\n   268→  return {\n   269→    score: +score.toFixed(4),\n   270→    cohesion_ratio: +cr.toFixed(3),\n   271→    velocity_corr: +vc.toFixed(3),\n   272→    aspect_ratio: +aspect_ratio.toFixed(2),\n   273→    density_cv: +density_cv.toFixed(3),\n   274→    dynamics: +dynamics.toFixed(4),\n   275→    avg_neighbors: +avg_neighbors.toFixed(1),\n   276→  };\n   277→}\n   278→\n   279→// === Main ===\n   280→// Warmup (batched)\n   281→const BATCH = 50;\n   282→for (let i = 0; i < WARMUP_FRAMES; i += BATCH) {\n   283→  const n = Math.min(BATCH, WARMUP_FRAMES - i);\n   284→  const encoder = device.createCommandEncoder();\n   285→  for (let j = 0; j < n; j++) encodeFrame(encoder, i + j);\n   286→  device.queue.submit([encoder.finish()]);\n   287→  await device.queue.onSubmittedWorkDone();\n   288→}\n   289→\n   290→// Measure metrics at steady state\n   291→let step = WARMUP_FRAMES;\n   292→{\n   293→  const encoder = device.createCommandEncoder();\n   294→  encodeMetrics(encoder, step);\n   295→  device.queue.submit([encoder.finish()]);\n   296→  await device.queue.onSubmittedWorkDone();\n   297→}\n   298→const metrics1 = await readMetrics();\n   299→\n   300→// Run 100 more steps, measure again for dynamics\n   301→for (let i = 0; i < 100; i++) {\n   302→  const encoder = device.createCommandEncoder();\n   303→  encodeFrame(encoder, step + i);\n   304→  device.queue.submit([encoder.finish()]);\n   305→}\n   306→step += 100;\n   307→await device.queue.onSubmittedWorkDone();\n   308→\n   309→{\n   310→  const encoder = device.createCommandEncoder();\n   311→  encodeMetrics(encoder, step);\n   312→  device.queue.submit([encoder.finish()]);\n   313→  await device.queue.onSubmittedWorkDone();\n   314→}\n   315→const metrics2 = await readMetrics();\n   316→\n   317→// Timing (quick)\n   318→const frameTimes: number[] = [];\n   319→for (let b = 0; b < Math.ceil(NUM_FRAMES/BATCH); b++) {\n   320→  const n = Math.min(BATCH, NUM_FRAMES - b*BATCH);\n   321→  const t0 = performance.now();\n   322→  const encoder = device.createCommandEncoder();\n   323→  for (let i = 0; i < n; i++) encodeFrame(encoder, step++);\n   324→  device.queue.submit([encoder.finish()]);\n   325→  await device.queue.onSubmittedWorkDone();\n   326→  const pf = (performance.now() - t0) / n;\n   327→  for (let i = 0; i < n; i++) frameTimes.push(pf);\n   328→}\n   329→frameTimes.sort((a,b) => a-b);\n   330→const avg = frameTimes.reduce((a,b) => a+b, 0) / frameTimes.length;\n   331→\n   332→const result = computeScore(metrics1, metrics2);\n   333→\n   334→console.log(JSON.stringify({\n   335→  num_boids: NUM_BOIDS,\n   336→  avg_ms: +avg.toFixed(2),\n   337→  p99_ms: +frameTimes[Math.floor(frameTimes.length * 0.99)].toFixed(2),\n   338→  ...result,\n   339→}));\n   340→\n   341→device.destroy();\n   342→Deno.exit(0);\n   343→\n   344→function parseArgs(args: string[]): Record<string, number> {\n   345→  const result: Record<string, number> = {};\n   346→  for (let i = 0; i < args.length; i++) {\n   347→    if (args[i].startsWith(\"--\") && i + 1 < args.length) {\n   348→      result[args[i].slice(2)] = parseInt(args[i + 1]);\n   349→      i++;\n   350→    }\n   351→  }\n   352→  return result;\n   353→}\n   354→"}]},"parent_tool_use_id":null,"session_id":"0d6d1a49-a9d2-43e7-86d8-3b4d26279dc9","uuid":"b3ba7122-2cad-4e8f-a304-4deb67ae651f","timestamp":"2026-03-23T04:54:48.494Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/aaronlemke/AI/Murmuration/benchmark.ts","content":"#!/usr/bin/env -S deno run --unstable-webgpu --allow-read\n/**\n * Headless WebGPU benchmark with murmuration quality metrics.\n * Runs simulation to steady state, then measures behavioral quality.\n *\n * Output JSON includes:\n * - Frame timing (avg_ms, p99_ms)\n * - Murmuration quality score (0-1) and sub-metrics\n *\n * Usage: deno run --unstable-webgpu --allow-read benchmark.ts [--boids N] [--frames N]\n */\n\nconst args = parseArgs(Deno.args);\nconst NUM_BOIDS = args.boids ?? 20000;\nconst NUM_FRAMES = args.frames ?? 60;\nconst WARMUP_FRAMES = 3750; // ~1 minute sim time at dt=0.016\n\nconst simCode = await Deno.readTextFile(\"simulation.js\");\nconst WORKGROUP_SIZE = parseInt(simCode.match(/const WORKGROUP_SIZE\\s*=\\s*(\\d+)/)?.[1] ?? \"64\");\nconst PARAMS_SIZE = parseInt(simCode.match(/const PARAMS_SIZE\\s*=\\s*(\\d+)/)?.[1] ?? \"96\");\n\nconst GRID_SIZE = Math.max(8, Math.min(128, Math.round(Math.cbrt(NUM_BOIDS) * 0.8)));\nconst GRID_CELLS = GRID_SIZE ** 3;\nconst WORLD_SIZE = 100.0;\nconst CELL_SIZE = WORLD_SIZE / GRID_SIZE;\n\nconst adapter = await navigator.gpu?.requestAdapter();\nif (!adapter) { console.error(\"No WebGPU adapter\"); Deno.exit(1); }\nconst device = await adapter.requestDevice();\n\nconst shaderCode = await Deno.readTextFile(\"shader.wgsl\");\nconst module = device.createShaderModule({ code: shaderCode });\n\n// --- Params ---\nconst paramsData = new ArrayBuffer(PARAMS_SIZE);\nconst u32 = new Uint32Array(paramsData);\nconst f32 = new Float32Array(paramsData);\n\nu32[0] = NUM_BOIDS;\nu32[1] = GRID_SIZE;\nu32[2] = GRID_CELLS;\nf32[3] = WORLD_SIZE;\nf32[4] = CELL_SIZE;\n// Read preset values from index.html (Murmuration preset)\nconst htmlCode = await Deno.readTextFile(\"index.html\");\nconst presetMatch = htmlCode.match(/'Murmuration':\\s*\\{([^}]+)\\}/);\nconst preset: Record<string, number> = {};\nif (presetMatch) {\n  for (const m of presetMatch[1].matchAll(/(\\w+):\\s*([\\d.]+)/g)) {\n    preset[m[1]] = parseFloat(m[2]);\n  }\n}\nf32[5]  = preset.visualRange ?? 15.0;\nf32[6]  = (preset.visualRange ?? 15.0) ** 2;\nf32[7]  = preset.separationDist ?? 2.0;\nf32[8]  = (preset.separationDist ?? 2.0) ** 2;\nf32[9]  = preset.alignFactor ?? 0.12;\nf32[10] = preset.cohesionFactor ?? 0.003;\nf32[11] = preset.separationFactor ?? 0.08;\nf32[12] = preset.maxSpeed ?? 8.0;\nf32[13] = preset.minSpeed ?? 3.0;\nf32[14] = 0.016;\nf32[15] = preset.turnFactor ?? 0.3;\nf32[16] = preset.smoothing ?? 0.10;\nf32[17] = 1.0;  // sim_speed\nf32[18] = 0.0;  // size_randomness\nf32[19] = 0.0;  // drag_factor\nu32[20] = 0;\nu32[21] = 0;\nf32[22] = preset.sphereRadius ?? 120.0;\nu32[23] = 0;  // frame_count — updated each step\n\nconst paramsBuffer = device.createBuffer({\n  size: PARAMS_SIZE,\n  usage: GPUBufferUsage.UNIFORM | GPUBufferUsage.COPY_DST,\n});\n\n// --- Boid buffers ---\nconst BOID_FLOATS = 16;\nconst BOID_BYTES = NUM_BOIDS * BOID_FLOATS * 4;\nconst initData = new Float32Array(NUM_BOIDS * BOID_FLOATS);\nconst spawnR = WORLD_SIZE * 0.08;\nfor (let i = 0; i < NUM_BOIDS; i++) {\n  const o = i * BOID_FLOATS;\n  // Spawn in sphere\n  let px, py, pz;\n  do { px = (Math.random()-0.5)*2; py = (Math.random()-0.5)*2; pz = (Math.random()-0.5)*2; }\n  while (px*px+py*py+pz*pz > 1);\n  initData[o] = px * spawnR;\n  initData[o+1] = py * spawnR;\n  initData[o+2] = pz * spawnR;\n  initData[o+3] = 1.0;\n  const vx = (Math.random()-0.5)*4, vy = (Math.random()-0.5)*4, vz = (Math.random()-0.5)*4;\n  initData[o+4] = vx; initData[o+5] = vy; initData[o+6] = vz;\n  initData[o+7] = Math.hypot(vx,vy,vz);\n  const vl = initData[o+7] || 1;\n  initData[o+8] = vx/vl; initData[o+9] = vy/vl; initData[o+10] = vz/vl;\n}\n\nfunction makeBuf(size: number, usage: number, data?: Float32Array) {\n  const buf = device.createBuffer({ size, usage });\n  if (data) device.queue.writeBuffer(buf, 0, data);\n  return buf;\n}\n\nconst boidA = makeBuf(BOID_BYTES, GPUBufferUsage.STORAGE | GPUBufferUsage.COPY_DST, initData);\nconst boidB = makeBuf(BOID_BYTES, GPUBufferUsage.STORAGE | GPUBufferUsage.COPY_DST);\nconst cellCounts = makeBuf(GRID_CELLS * 4, GPUBufferUsage.STORAGE);\nconst cellOffsets = makeBuf(GRID_CELLS * 4, GPUBufferUsage.STORAGE);\nconst boidCells = makeBuf(NUM_BOIDS * 4, GPUBufferUsage.STORAGE);\nconst sortedIndices = makeBuf(NUM_BOIDS * 4, GPUBufferUsage.STORAGE);\nconst scatterCounters = makeBuf(GRID_CELLS * 4, GPUBufferUsage.STORAGE);\n\n// --- Metrics buffers (group 1) ---\nconst statsBuf = makeBuf(8, GPUBufferUsage.STORAGE);  // auto-range stats (binding 0)\nconst metricsBuf = makeBuf(64, GPUBufferUsage.STORAGE | GPUBufferUsage.COPY_SRC);  // quality metrics (binding 1)\nconst metricsReadBuf = device.createBuffer({\n  size: 64, usage: GPUBufferUsage.MAP_READ | GPUBufferUsage.COPY_DST,\n});\n\n// --- Bind group layouts ---\nconst bgl = device.createBindGroupLayout({\n  entries: Array.from({ length: 8 }, (_, i) => ({\n    binding: i, visibility: GPUShaderStage.COMPUTE,\n    buffer: { type: (i === 0 ? \"uniform\" : \"storage\") as GPUBufferBindingType },\n  })),\n});\n\nconst metricsBGL = device.createBindGroupLayout({\n  entries: [\n    { binding: 0, visibility: GPUShaderStage.COMPUTE, buffer: { type: \"storage\" as GPUBufferBindingType } },\n    { binding: 1, visibility: GPUShaderStage.COMPUTE, buffer: { type: \"storage\" as GPUBufferBindingType } },\n  ],\n});\n\n// Sim pipelines use group(0) only\nconst simPipeLayout = device.createPipelineLayout({ bindGroupLayouts: [bgl] });\n// Metrics pipelines use group(0) + group(1)\nconst metricsPipeLayout = device.createPipelineLayout({ bindGroupLayouts: [bgl, metricsBGL] });\n\nfunction makeBG(src: GPUBuffer, dst: GPUBuffer) {\n  return device.createBindGroup({\n    layout: bgl,\n    entries: [\n      { binding: 0, resource: { buffer: paramsBuffer } },\n      { binding: 1, resource: { buffer: src } },\n      { binding: 2, resource: { buffer: dst } },\n      { binding: 3, resource: { buffer: cellCounts } },\n      { binding: 4, resource: { buffer: cellOffsets } },\n      { binding: 5, resource: { buffer: boidCells } },\n      { binding: 6, resource: { buffer: sortedIndices } },\n      { binding: 7, resource: { buffer: scatterCounters } },\n    ],\n  });\n}\nconst bgA = makeBG(boidA, boidB);\nconst bgB = makeBG(boidB, boidA);\n\nconst metricsBG = device.createBindGroup({\n  layout: metricsBGL,\n  entries: [\n    { binding: 0, resource: { buffer: statsBuf } },\n    { binding: 1, resource: { buffer: metricsBuf } },\n  ],\n});\n\n// --- Compute pipelines ---\nconst makeSP = (ep: string) => device.createComputePipeline({ layout: simPipeLayout, compute: { module, entryPoint: ep } });\nconst makeMP = (ep: string) => device.createComputePipeline({ layout: metricsPipeLayout, compute: { module, entryPoint: ep } });\n\nconst clearPipe = makeSP(\"clear_grid\");\nconst assignPipe = makeSP(\"assign_cells\");\nconst prefixPipe = makeSP(\"prefix_sum\");\nconst scatterPipe = makeSP(\"scatter\");\nconst flockPipe = makeSP(\"flock\");\nconst clearMetricsPipe = makeMP(\"clear_metrics\");\nconst computeMetricsPipe = makeMP(\"compute_metrics\");\n\nconst gridWG = Math.ceil(GRID_CELLS / WORKGROUP_SIZE);\nconst boidWG = Math.ceil(NUM_BOIDS / WORKGROUP_SIZE);\n\nfunction encodeFrame(encoder: GPUCommandEncoder, step: number) {\n  // Update frame_count in params\n  u32[23] = step;\n  device.queue.writeBuffer(paramsBuffer, 0, new Uint8Array(paramsData));\n\n  const bg = step % 2 === 0 ? bgA : bgB;\n  for (const [pipe, wg] of [[clearPipe, gridWG], [assignPipe, boidWG], [prefixPipe, 1], [scatterPipe, boidWG], [flockPipe, boidWG]] as [GPUComputePipeline, number][]) {\n    const p = encoder.beginComputePass();\n    p.setPipeline(pipe);\n    p.setBindGroup(0, bg);\n    p.dispatchWorkgroups(wg);\n    p.end();\n  }\n}\n\nfunction encodeMetrics(encoder: GPUCommandEncoder, step: number) {\n  const bg = step % 2 === 0 ? bgA : bgB;\n  // Clear\n  const c = encoder.beginComputePass();\n  c.setPipeline(clearMetricsPipe);\n  c.setBindGroup(0, bg);\n  c.setBindGroup(1, metricsBG);\n  c.dispatchWorkgroups(1);\n  c.end();\n  // Compute\n  const s = encoder.beginComputePass();\n  s.setPipeline(computeMetricsPipe);\n  s.setBindGroup(0, bg);\n  s.setBindGroup(1, metricsBG);\n  s.dispatchWorkgroups(boidWG);\n  s.end();\n  // Copy to readback\n  encoder.copyBufferToBuffer(metricsBuf, 0, metricsReadBuf, 0, 64);\n}\n\nasync function readMetrics(): Promise<Float32Array> {\n  await metricsReadBuf.mapAsync(GPUMapMode.READ);\n  const data = new Float32Array(metricsReadBuf.getMappedRange().slice(0));\n  metricsReadBuf.unmap();\n  return data;\n}\n\nfunction computeScore(raw: Float32Array, raw2: Float32Array | null) {\n  const n = raw[10] || 1; // total boids processed (slot 10, as u32 → read via f32)\n  // Reinterpret slot 10 as u32\n  const nBoids = new Uint32Array(raw.buffer)[10] || 1;\n  const cohesionCount = new Uint32Array(raw.buffer)[0]; // slot 0: boids with 5+ neighbors (u32)\n\n  const cohesion_ratio = cohesionCount / nBoids;\n  const avg_neighbors = raw[1] / nBoids; // slot 1: sum of neighbor_count\n  const velocity_corr = raw[2] / nBoids; // slot 2: sum of flock_alignment\n\n  // Position variance for aspect ratio\n  const mx = raw[3] / nBoids, my = raw[4] / nBoids, mz = raw[5] / nBoids;\n  const vx = raw[6] / nBoids - mx*mx;\n  const vy = raw[7] / nBoids - my*my;\n  const vz = raw[8] / nBoids - mz*mz;\n  const variances = [Math.max(vx, 0.01), Math.max(vy, 0.01), Math.max(vz, 0.01)].sort((a,b) => b-a);\n  const aspect_ratio = variances[0] / variances[2]; // largest / smallest\n\n  // Density uniformity (CV of neighbor counts)\n  const avg_n = raw[1] / nBoids;\n  const avg_n2 = raw[9] / nBoids;\n  const var_n = Math.max(0, avg_n2 - avg_n * avg_n);\n  const density_cv = avg_n > 0.01 ? Math.sqrt(var_n) / avg_n : 10.0;\n\n  // Shape dynamics (compare two measurements)\n  let dynamics = 0.05; // default if no second measurement\n  if (raw2) {\n    const n2 = new Uint32Array(raw2.buffer)[10] || 1;\n    const mx2 = raw2[3]/n2, my2 = raw2[4]/n2, mz2 = raw2[5]/n2;\n    const vx2 = raw2[6]/n2 - mx2*mx2, vy2 = raw2[7]/n2 - my2*my2, vz2 = raw2[8]/n2 - mz2*mz2;\n    const vars2 = [Math.max(vx2,0.01), Math.max(vy2,0.01), Math.max(vz2,0.01)].sort((a,b) => b-a);\n    const ar2 = vars2[0] / vars2[2];\n    dynamics = Math.abs(aspect_ratio - ar2) / Math.max(aspect_ratio, 0.01);\n  }\n\n  // Composite score\n  const cr = Math.min(cohesion_ratio, 1.0);\n  const vc = Math.max(velocity_corr, 0.0);\n  const ar_norm = Math.min(aspect_ratio, 5.0) / 5.0;\n  const du_norm = 1.0 / (1.0 + density_cv);\n  const dyn_norm = Math.min(dynamics * 20, 1.0);\n\n  const score = cr * cr * vc * ar_norm * du_norm * dyn_norm;\n\n  return {\n    score: +score.toFixed(4),\n    cohesion_ratio: +cr.toFixed(3),\n    velocity_corr: +vc.toFixed(3),\n    aspect_ratio: +aspect_ratio.toFixed(2),\n    density_cv: +density_cv.toFixed(3),\n    dynamics: +dynamics.toFixed(4),\n    avg_neighbors: +avg_neighbors.toFixed(1),\n  };\n}\n\n// === Main ===\n// Warmup (batched)\nconst BATCH = 50;\nfor (let i = 0; i < WARMUP_FRAMES; i += BATCH) {\n  const n = Math.min(BATCH, WARMUP_FRAMES - i);\n  const encoder = device.createCommandEncoder();\n  for (let j = 0; j < n; j++) encodeFrame(encoder, i + j);\n  device.queue.submit([encoder.finish()]);\n  await device.queue.onSubmittedWorkDone();\n}\n\n// Measure metrics at steady state\nlet step = WARMUP_FRAMES;\n{\n  const encoder = device.createCommandEncoder();\n  encodeMetrics(encoder, step);\n  device.queue.submit([encoder.finish()]);\n  await device.queue.onSubmittedWorkDone();\n}\nconst metrics1 = await readMetrics();\n\n// Run 100 more steps, measure again for dynamics\nfor (let i = 0; i < 100; i++) {\n  const encoder = device.createCommandEncoder();\n  encodeFrame(encoder, step + i);\n  device.queue.submit([encoder.finish()]);\n}\nstep += 100;\nawait device.queue.onSubmittedWorkDone();\n\n{\n  const encoder = device.createCommandEncoder();\n  encodeMetrics(encoder, step);\n  device.queue.submit([encoder.finish()]);\n  await device.queue.onSubmittedWorkDone();\n}\nconst metrics2 = await readMetrics();\n\n// Timing (quick)\nconst frameTimes: number[] = [];\nfor (let b = 0; b < Math.ceil(NUM_FRAMES/BATCH); b++) {\n  const n = Math.min(BATCH, NUM_FRAMES - b*BATCH);\n  const t0 = performance.now();\n  const encoder = device.createCommandEncoder();\n  for (let i = 0; i < n; i++) encodeFrame(encoder, step++);\n  device.queue.submit([encoder.finish()]);\n  await device.queue.onSubmittedWorkDone();\n  const pf = (performance.now() - t0) / n;\n  for (let i = 0; i < n; i++) frameTimes.push(pf);\n}\nframeTimes.sort((a,b) => a-b);\nconst avg = frameTimes.reduce((a,b) => a+b, 0) / frameTimes.length;\n\nconst result = computeScore(metrics1, metrics2);\n\nconsole.log(JSON.stringify({\n  num_boids: NUM_BOIDS,\n  avg_ms: +avg.toFixed(2),\n  p99_ms: +frameTimes[Math.floor(frameTimes.length * 0.99)].toFixed(2),\n  ...result,\n}));\n\ndevice.destroy();\nDeno.exit(0);\n\nfunction parseArgs(args: string[]): Record<string, number> {\n  const result: Record<string, number> = {};\n  for (let i = 0; i < args.length; i++) {\n    if (args[i].startsWith(\"--\") && i + 1 < args.length) {\n      result[args[i].slice(2)] = parseInt(args[i + 1]);\n      i++;\n    }\n  }\n  return result;\n}\n","numLines":354,"startLine":1,"totalLines":354}}}
