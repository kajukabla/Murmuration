{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017u12nfpo3kBZkcMS44JoVu","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→Locked evaluation script for the autoresearch optimization loop.\n     4→Binary-searches for the maximum boid count that maintains 60 FPS.\n     5→Uses the LIVE BROWSER (Chrome on macOS) for benchmarking with full rendering.\n     6→\n     7→The browser navigates to localhost:8080?boids=N, runs 120 measured frames,\n     8→and POSTs results to localhost:8080/api/bench_result.\n     9→\n    10→Outputs: max_boids: NNNNN\n    11→Appends each probe to run_metrics.csv.\n    12→\"\"\"\n    13→\n    14→import subprocess\n    15→import json\n    16→import sys\n    17→import os\n    18→import time\n    19→\n    20→SERVER_URL = \"http://localhost:8080\"\n    21→TARGET_MS = 16.6  # 60 FPS\n    22→RESULT_FILE = os.path.join(os.path.dirname(os.path.abspath(__file__)), \"bench_result.json\")\n    23→CSV_FILE = os.path.join(os.path.dirname(os.path.abspath(__file__)), \"run_metrics.csv\")\n    24→TIMEOUT = 30  # max seconds to wait for benchmark\n    25→\n    26→# Binary search bounds (in thousands)\n    27→LO = 1     # 1,000 boids\n    28→HI = 500   # 500,000 boids\n    29→\n    30→\n    31→def navigate_chrome(url: str):\n    32→    \"\"\"Navigate a Chrome tab to a URL WITHOUT stealing focus (macOS).\"\"\"\n    33→    script = f'''\n    34→    tell application \"Google Chrome\"\n    35→        if (count of windows) > 0 then\n    36→            set found to false\n    37→            repeat with w in windows\n    38→                repeat with t in tabs of w\n    39→                    if URL of t starts with \"http://localhost:8080\" then\n    40→                        set URL of t to \"{url}\"\n    41→                        set found to true\n    42→                        exit repeat\n    43→                    end if\n    44→                end repeat\n    45→                if found then exit repeat\n    46→            end repeat\n    47→            if not found then\n    48→                set URL of active tab of front window to \"{url}\"\n    49→            end if\n    50→        end if\n    51→    end tell\n    52→    '''\n    53→    subprocess.run([\"osascript\", \"-e\", script], capture_output=True, timeout=5)\n    54→\n    55→\n    56→def wait_for_result(timeout: int = TIMEOUT) -> dict | None:\n    57→    \"\"\"Poll bench_result.json until it appears or timeout.\"\"\"\n    58→    # Clear any stale result\n    59→    if os.path.exists(RESULT_FILE):\n    60→        os.remove(RESULT_FILE)\n    61→\n    62→    deadline = time.time() + timeout\n    63→    while time.time() < deadline:\n    64→        if os.path.exists(RESULT_FILE):\n    65→            try:\n    66→                with open(RESULT_FILE) as f:\n    67→                    data = json.load(f)\n    68→                os.remove(RESULT_FILE)  # consume it\n    69→                return data\n    70→            except (json.JSONDecodeError, IOError):\n    71→                pass\n    72→        time.sleep(0.5)\n    73→    return None\n    74→\n    75→\n    76→def append_csv(iteration: int, num_boids: int, avg_ms: float, p99_ms: float, passed: bool):\n    77→    from datetime import datetime\n    78→    write_header = not os.path.exists(CSV_FILE) or os.path.getsize(CSV_FILE) == 0\n    79→    with open(CSV_FILE, \"a\") as f:\n    80→        if write_header:\n    81→            f.write(\"Timestamp,Iteration,Particle_Count,Avg_Frame_Time,P99_Frame_Time,Result\\n\")\n    82→        result = \"Pass\" if passed else \"Fail\"\n    83→        f.write(f\"{datetime.now().isoformat()},{iteration},{num_boids},{avg_ms:.2f},{p99_ms:.2f},{result}\\n\")\n    84→\n    85→\n    86→def run_benchmark(num_boids: int) -> dict | None:\n    87→    \"\"\"Navigate Chrome to benchmark URL and wait for results.\"\"\"\n    88→    url = f\"{SERVER_URL}?boids={num_boids}\"\n    89→    navigate_chrome(url)\n    90→    # Wait for warmup (30 frames) + measurement (120 frames) + buffer\n    91→    # At 60fps that's ~2.5s, at 15fps ~10s. Give it generous time.\n    92→    return wait_for_result(TIMEOUT)\n    93→\n    94→\n    95→def main():\n    96→    # Read iteration number\n    97→    iteration = 0\n    98→    if os.path.exists(CSV_FILE):\n    99→        with open(CSV_FILE) as f:\n   100→            iteration = max(0, sum(1 for _ in f) - 1)\n   101→\n   102→    print(f\"Evaluating: binary search for max boids @ p99 < {TARGET_MS}ms (browser)\", file=sys.stderr)\n   103→\n   104→    lo, hi = LO, HI\n   105→    best = 0\n   106→    probe_num = 0\n   107→\n   108→    while lo <= hi:\n   109→        mid = (lo + hi) // 2\n   110→        num_boids = mid * 1000\n   111→        probe_num += 1\n   112→\n   113→        print(f\"  probe {probe_num}: {num_boids} boids ...\", end=\"\", file=sys.stderr, flush=True)\n   114→        result = run_benchmark(num_boids)\n   115→\n   116→        if result is None:\n   117→            print(f\" TIMEOUT\", file=sys.stderr)\n   118→            append_csv(iteration, num_boids, 0, 0, False)\n   119→            hi = mid - 1\n   120→            continue\n   121→\n   122→        p99 = result[\"p99_ms\"]\n   123→        avg = result[\"avg_ms\"]\n   124→        passed = p99 < TARGET_MS\n   125→\n   126→        print(f\" avg={avg:.1f}ms p99={p99:.1f}ms {'PASS' if passed else 'FAIL'}\", file=sys.stderr)\n   127→        append_csv(iteration, num_boids, avg, p99, passed)\n   128→\n   129→        if passed:\n   130→            best = max(best, num_boids)\n   131→            lo = mid + 1\n   132→        else:\n   133→            hi = mid - 1\n   134→\n   135→    # Navigate back to normal viewing mode with best count\n   136→    navigate_chrome(SERVER_URL)\n   137→    print(f\"max_boids: {best}\")\n   138→\n   139→\n   140→if __name__ == \"__main__\":\n   141→    main()\n   142→"}]},"parent_tool_use_id":null,"session_id":"7ffa1055-e97b-4b91-bfbd-0531ff2ae3b8","uuid":"2e7387d2-30c1-4c1f-a036-e7a6f1ace2ed","timestamp":"2026-03-22T22:45:52.345Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/aaronlemke/AI/Murmuration/evaluate.py","content":"#!/usr/bin/env python3\n\"\"\"\nLocked evaluation script for the autoresearch optimization loop.\nBinary-searches for the maximum boid count that maintains 60 FPS.\nUses the LIVE BROWSER (Chrome on macOS) for benchmarking with full rendering.\n\nThe browser navigates to localhost:8080?boids=N, runs 120 measured frames,\nand POSTs results to localhost:8080/api/bench_result.\n\nOutputs: max_boids: NNNNN\nAppends each probe to run_metrics.csv.\n\"\"\"\n\nimport subprocess\nimport json\nimport sys\nimport os\nimport time\n\nSERVER_URL = \"http://localhost:8080\"\nTARGET_MS = 16.6  # 60 FPS\nRESULT_FILE = os.path.join(os.path.dirname(os.path.abspath(__file__)), \"bench_result.json\")\nCSV_FILE = os.path.join(os.path.dirname(os.path.abspath(__file__)), \"run_metrics.csv\")\nTIMEOUT = 30  # max seconds to wait for benchmark\n\n# Binary search bounds (in thousands)\nLO = 1     # 1,000 boids\nHI = 500   # 500,000 boids\n\n\ndef navigate_chrome(url: str):\n    \"\"\"Navigate a Chrome tab to a URL WITHOUT stealing focus (macOS).\"\"\"\n    script = f'''\n    tell application \"Google Chrome\"\n        if (count of windows) > 0 then\n            set found to false\n            repeat with w in windows\n                repeat with t in tabs of w\n                    if URL of t starts with \"http://localhost:8080\" then\n                        set URL of t to \"{url}\"\n                        set found to true\n                        exit repeat\n                    end if\n                end repeat\n                if found then exit repeat\n            end repeat\n            if not found then\n                set URL of active tab of front window to \"{url}\"\n            end if\n        end if\n    end tell\n    '''\n    subprocess.run([\"osascript\", \"-e\", script], capture_output=True, timeout=5)\n\n\ndef wait_for_result(timeout: int = TIMEOUT) -> dict | None:\n    \"\"\"Poll bench_result.json until it appears or timeout.\"\"\"\n    # Clear any stale result\n    if os.path.exists(RESULT_FILE):\n        os.remove(RESULT_FILE)\n\n    deadline = time.time() + timeout\n    while time.time() < deadline:\n        if os.path.exists(RESULT_FILE):\n            try:\n                with open(RESULT_FILE) as f:\n                    data = json.load(f)\n                os.remove(RESULT_FILE)  # consume it\n                return data\n            except (json.JSONDecodeError, IOError):\n                pass\n        time.sleep(0.5)\n    return None\n\n\ndef append_csv(iteration: int, num_boids: int, avg_ms: float, p99_ms: float, passed: bool):\n    from datetime import datetime\n    write_header = not os.path.exists(CSV_FILE) or os.path.getsize(CSV_FILE) == 0\n    with open(CSV_FILE, \"a\") as f:\n        if write_header:\n            f.write(\"Timestamp,Iteration,Particle_Count,Avg_Frame_Time,P99_Frame_Time,Result\\n\")\n        result = \"Pass\" if passed else \"Fail\"\n        f.write(f\"{datetime.now().isoformat()},{iteration},{num_boids},{avg_ms:.2f},{p99_ms:.2f},{result}\\n\")\n\n\ndef run_benchmark(num_boids: int) -> dict | None:\n    \"\"\"Navigate Chrome to benchmark URL and wait for results.\"\"\"\n    url = f\"{SERVER_URL}?boids={num_boids}\"\n    navigate_chrome(url)\n    # Wait for warmup (30 frames) + measurement (120 frames) + buffer\n    # At 60fps that's ~2.5s, at 15fps ~10s. Give it generous time.\n    return wait_for_result(TIMEOUT)\n\n\ndef main():\n    # Read iteration number\n    iteration = 0\n    if os.path.exists(CSV_FILE):\n        with open(CSV_FILE) as f:\n            iteration = max(0, sum(1 for _ in f) - 1)\n\n    print(f\"Evaluating: binary search for max boids @ p99 < {TARGET_MS}ms (browser)\", file=sys.stderr)\n\n    lo, hi = LO, HI\n    best = 0\n    probe_num = 0\n\n    while lo <= hi:\n        mid = (lo + hi) // 2\n        num_boids = mid * 1000\n        probe_num += 1\n\n        print(f\"  probe {probe_num}: {num_boids} boids ...\", end=\"\", file=sys.stderr, flush=True)\n        result = run_benchmark(num_boids)\n\n        if result is None:\n            print(f\" TIMEOUT\", file=sys.stderr)\n            append_csv(iteration, num_boids, 0, 0, False)\n            hi = mid - 1\n            continue\n\n        p99 = result[\"p99_ms\"]\n        avg = result[\"avg_ms\"]\n        passed = p99 < TARGET_MS\n\n        print(f\" avg={avg:.1f}ms p99={p99:.1f}ms {'PASS' if passed else 'FAIL'}\", file=sys.stderr)\n        append_csv(iteration, num_boids, avg, p99, passed)\n\n        if passed:\n            best = max(best, num_boids)\n            lo = mid + 1\n        else:\n            hi = mid - 1\n\n    # Navigate back to normal viewing mode with best count\n    navigate_chrome(SERVER_URL)\n    print(f\"max_boids: {best}\")\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":142,"startLine":1,"totalLines":142}}}
