{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ee6ByJAwCF3cPstRQqpYgp","type":"tool_result","content":"     1→// === 3D Murmuration Compute Shader — Topological Neighbor Model ===\n     2→// Based on empirical starling research: birds track their nearest 7 neighbors,\n     3→// not all within a fixed radius. This produces realistic wave propagation,\n     4→// sharp flock edges, and coordinated turns.\n     5→\n     6→struct SimParams {\n     7→  num_boids: u32,\n     8→  grid_size: u32,\n     9→  grid_cells: u32,\n    10→  world_size: f32,\n    11→  cell_size: f32,\n    12→  visual_range: f32,\n    13→  visual_range_sq: f32,\n    14→  separation_dist: f32,\n    15→  separation_dist_sq: f32,\n    16→  align_factor: f32,\n    17→  cohesion_factor: f32,\n    18→  separation_factor: f32,\n    19→  max_speed: f32,\n    20→  min_speed: f32,\n    21→  dt: f32,\n    22→  turn_factor: f32,\n    23→  smoothing: f32,\n    24→  sim_speed: f32,\n    25→  size_randomness: f32,\n    26→  drag_factor: f32,\n    27→  gradient_id: u32,\n    28→  color_source: u32,\n    29→  sphere_radius: f32,\n    30→  frame_count: u32,\n    31→}\n    32→\n    33→struct Boid {\n    34→  pos: vec3f,\n    35→  size_factor: f32,\n    36→  vel: vec3f,\n    37→  speed: f32,\n    38→  heading: vec3f,\n    39→  neighbor_count: f32,\n    40→  dir_change: f32,\n    41→  flock_alignment: f32,\n    42→  sep_pressure: f32,\n    43→  density: f32,\n    44→}\n    45→\n    46→@group(0) @binding(0) var<uniform> params: SimParams;\n    47→@group(0) @binding(1) var<storage, read_write> boids_src: array<Boid>;\n    48→@group(0) @binding(2) var<storage, read_write> boids_dst: array<Boid>;\n    49→@group(0) @binding(3) var<storage, read_write> cell_counts: array<atomic<u32>>;\n    50→@group(0) @binding(4) var<storage, read_write> cell_offsets: array<u32>;\n    51→@group(0) @binding(5) var<storage, read_write> boid_cells: array<u32>;\n    52→@group(0) @binding(6) var<storage, read_write> sorted_indices: array<u32>;\n    53→@group(0) @binding(7) var<storage, read_write> scatter_counters: array<atomic<u32>>;\n    54→\n    55→fn get_cell(pos: vec3f) -> vec3u {\n    56→  let half = params.world_size * 0.5;\n    57→  return vec3u(clamp(\n    58→    vec3i(floor((pos + vec3f(half)) / params.cell_size)),\n    59→    vec3i(0),\n    60→    vec3i(i32(params.grid_size) - 1)\n    61→  ));\n    62→}\n    63→\n    64→fn cell_index(c: vec3u) -> u32 {\n    65→  return c.x + c.y * params.grid_size + c.z * params.grid_size * params.grid_size;\n    66→}\n    67→\n    68→@compute @workgroup_size(64)\n    69→fn clear_grid(@builtin(global_invocation_id) id: vec3u) {\n    70→  let i = id.x;\n    71→  if (i >= params.grid_cells) { return; }\n    72→  atomicStore(&cell_counts[i], 0u);\n    73→  atomicStore(&scatter_counters[i], 0u);\n    74→}\n    75→\n    76→@compute @workgroup_size(64)\n    77→fn assign_cells(@builtin(global_invocation_id) id: vec3u) {\n    78→  let i = id.x;\n    79→  if (i >= params.num_boids) { return; }\n    80→  let cell = cell_index(get_cell(boids_src[i].pos));\n    81→  boid_cells[i] = cell;\n    82→  atomicAdd(&cell_counts[cell], 1u);\n    83→}\n    84→\n    85→const SCAN_WG: u32 = 256u;\n    86→var<workgroup> scan_sums: array<u32, 256>;\n    87→\n    88→@compute @workgroup_size(256)\n    89→fn prefix_sum(@builtin(local_invocation_id) lid: vec3u) {\n    90→  let tid = lid.x;\n    91→  let chunk = (params.grid_cells + SCAN_WG - 1u) / SCAN_WG;\n    92→  let start = tid * chunk;\n    93→  let end = min(start + chunk, params.grid_cells);\n    94→  var local_total = 0u;\n    95→  for (var i = start; i < end; i++) {\n    96→    let count = atomicLoad(&cell_counts[i]);\n    97→    cell_offsets[i] = local_total;\n    98→    local_total += count;\n    99→  }\n   100→  scan_sums[tid] = local_total;\n   101→  workgroupBarrier();\n   102→  for (var stride = 1u; stride < SCAN_WG; stride *= 2u) {\n   103→    let val = select(0u, scan_sums[tid - stride], tid >= stride);\n   104→    workgroupBarrier();\n   105→    scan_sums[tid] += val;\n   106→    workgroupBarrier();\n   107→  }\n   108→  let prefix = select(0u, scan_sums[tid - 1u], tid > 0u);\n   109→  for (var i = start; i < end; i++) {\n   110→    cell_offsets[i] += prefix;\n   111→  }\n   112→}\n   113→\n   114→@compute @workgroup_size(64)\n   115→fn scatter(@builtin(global_invocation_id) id: vec3u) {\n   116→  let i = id.x;\n   117→  if (i >= params.num_boids) { return; }\n   118→  let cell = boid_cells[i];\n   119→  let local_offset = atomicAdd(&scatter_counters[cell], 1u);\n   120→  sorted_indices[cell_offsets[cell] + local_offset] = i;\n   121→}\n   122→\n   123→// === Topological Neighbor Flocking ===\n   124→// Find the K nearest neighbors (K=7 for alignment/cohesion, closest 1 for avoidance)\n   125→// Uses the spatial hash to find candidates, then keeps only the K closest.\n   126→\n   127→const K_NEIGHBORS: u32 = 7u;\n   128→\n   129→@compute @workgroup_size(64)\n   130→fn flock(@builtin(global_invocation_id) id: vec3u) {\n   131→  let i = id.x;\n   132→  if (i >= params.num_boids) { return; }\n   133→\n   134→  let boid = boids_src[i];\n   135→  let my_grid = get_cell(boid.pos);\n   136→  let gs = i32(params.grid_size);\n   137→  let mg = vec3i(my_grid);\n   138→\n   139→  // Track K nearest neighbors by distance (insertion sort into small array)\n   140→  // Store squared distances and indices\n   141→  var nearest_d2: array<f32, 7>;   // distances squared\n   142→  var nearest_idx: array<u32, 7>;  // boid indices\n   143→  var n_found = 0u;\n   144→\n   145→  // Initialize with large distances\n   146→  for (var k = 0u; k < K_NEIGHBORS; k++) {\n   147→    nearest_d2[k] = 1e10;\n   148→    nearest_idx[k] = 0u;\n   149→  }\n   150→\n   151→  // Search 3x3x3 neighborhood (27 cells)\n   152→  let lo = max(mg - vec3i(1), vec3i(0));\n   153→  let hi = min(mg + vec3i(1), vec3i(gs - 1));\n   154→\n   155→  var total_candidates = 0u;\n   156→\n   157→  for (var nz = lo.z; nz <= hi.z; nz++) {\n   158→    let zoff = u32(nz) * params.grid_size * params.grid_size;\n   159→    for (var ny = lo.y; ny <= hi.y; ny++) {\n   160→      let yzoff = u32(ny) * params.grid_size + zoff;\n   161→      for (var nx = lo.x; nx <= hi.x; nx++) {\n   162→        let nc = u32(nx) + yzoff;\n   163→        let start = cell_offsets[nc];\n   164→        let end_val = select(cell_offsets[nc + 1u], params.num_boids, nc + 1u >= params.grid_cells);\n   165→        if (start >= end_val) { continue; }\n   166→\n   167→        for (var j = start; j < end_val; j++) {\n   168→          let other_idx = sorted_indices[j];\n   169→          if (other_idx == i) { continue; }\n   170→\n   171→          let other_pos = boids_src[other_idx].pos;\n   172→          let diff = boid.pos - other_pos;\n   173→          let d2 = dot(diff, diff);\n   174→\n   175→          // Pre-filter by visual range before K-nearest sort\n   176→          if (d2 > params.visual_range_sq) { continue; }\n   177→\n   178→          total_candidates++;\n   179→\n   180→          // Insert into sorted K-nearest if closer than current worst\n   181→          if (d2 < nearest_d2[K_NEIGHBORS - 1u]) {\n   182→            // Find insertion position\n   183→            var pos = K_NEIGHBORS - 1u;\n   184→            for (var k = 0u; k < K_NEIGHBORS - 1u; k++) {\n   185→              if (d2 < nearest_d2[k]) {\n   186→                pos = k;\n   187→                break;\n   188→              }\n   189→            }\n   190→            // Shift larger entries down\n   191→            for (var k = K_NEIGHBORS - 1u; k > pos; k--) {\n   192→              nearest_d2[k] = nearest_d2[k - 1u];\n   193→              nearest_idx[k] = nearest_idx[k - 1u];\n   194→            }\n   195→            nearest_d2[pos] = d2;\n   196→            nearest_idx[pos] = other_idx;\n   197→            n_found = min(n_found + 1u, K_NEIGHBORS);\n   198→          }\n   199→        }\n   200→      }\n   201→    }\n   202→  }\n   203→\n   204→  // === Apply flocking rules using topological neighbors ===\n   205→  var new_vel = boid.vel;\n   206→\n   207→  // Avoidance: only the 1 nearest neighbor\n   208→  var sep_force = vec3f(0.0);\n   209→  if (n_found > 0u && nearest_d2[0] < params.separation_dist_sq) {\n   210→    let other_pos = boids_src[nearest_idx[0]].pos;\n   211→    let diff = boid.pos - other_pos;\n   212→    let d2 = nearest_d2[0];\n   213→    sep_force = diff * (1.0 - d2 / params.separation_dist_sq);\n   214→    new_vel += sep_force * params.separation_factor * 2.0; // stronger since only 1 neighbor\n   215→  }\n   216→\n   217→  // Alignment + Cohesion: all K neighbors\n   218→  var ali = vec3f(0.0);\n   219→  var coh = vec3f(0.0);\n   220→  var avg_vel = vec3f(0.0);\n   221→  if (n_found > 0u) {\n   222→    for (var k = 0u; k < min(n_found, K_NEIGHBORS); k++) {\n   223→      let other = boids_src[nearest_idx[k]];\n   224→      ali += other.vel;\n   225→      coh += other.pos;\n   226→    }\n   227→    let nf = f32(min(n_found, K_NEIGHBORS));\n   228→    avg_vel = ali / nf;\n   229→    let avg_pos = coh / nf;\n   230→    new_vel += (avg_vel - boid.vel) * params.align_factor;\n   231→    new_vel += (avg_pos - boid.pos) * params.cohesion_factor;\n   232→  }\n   233→\n   234→  // === Murmuration-specific forces ===\n   235→\n   236→  // Gravity: slight downward pull (creates the flat pancake shape)\n   237→  new_vel.y -= 0.06;\n   238→\n   239→  // Center-seeking: gentle drift toward local flock center\n   240→  if (n_found >= 2u) {\n   241→    let local_center = coh / f32(min(n_found, K_NEIGHBORS));\n   242→    let to_center = local_center - boid.pos;\n   243→    let center_dist = length(to_center);\n   244→    if (center_dist > 0.5) {\n   245→      new_vel += normalize(to_center) * 0.08;\n   246→    }\n   247→  }\n   248→\n   249→  // Roost attractor: orbiting point that guides flock into sweeping arcs\n   250→  let time = f32(params.frame_count) * 0.002;\n   251→  let roost = vec3f(\n   252→    sin(time) * params.sphere_radius * 0.4,\n   253→    cos(time * 0.7) * params.sphere_radius * 0.05,\n   254→    cos(time) * params.sphere_radius * 0.4\n   255→  );\n   256→  let to_roost = roost - boid.pos;\n   257→  let roost_dist = length(to_roost);\n   258→  if (roost_dist > 1.0) {\n   259→    new_vel += normalize(to_roost) * 0.3;\n   260→  }\n   261→\n   262→  // Random perturbation: breaks symmetry, triggers wave cascades\n   263→  let noise_seed = f32(i * 1973u + params.frame_count * 9277u);\n   264→  let noise = vec3f(\n   265→    fract(sin(noise_seed) * 43758.5) - 0.5,\n   266→    fract(sin(noise_seed * 1.3) * 22578.1) - 0.5,\n   267→    fract(sin(noise_seed * 0.7) * 31415.9) - 0.5\n   268→  ) * 0.15;\n   269→  new_vel += noise;\n   270→\n   271→  // Spherical boundary steering\n   272→  let dist_from_center = length(boid.pos);\n   273→  let r = params.sphere_radius;\n   274→  let soft_zone = r * 0.15;\n   275→  if (dist_from_center > r - soft_zone && dist_from_center > 0.001) {\n   276→    let penetration = (dist_from_center - (r - soft_zone)) / soft_zone;\n   277→    let push = -normalize(boid.pos) * params.turn_factor * clamp(penetration, 0.0, 3.0);\n   278→    new_vel += push;\n   279→  }\n   280→\n   281→  // Turn rate limiter (smooth heading changes — creates wave-like motion)\n   282→  let old_speed = length(boid.vel);\n   283→  var old_dir = boid.vel;\n   284→  if (old_speed > 0.001) { old_dir = old_dir / old_speed; }\n   285→  else { old_dir = vec3f(1.0, 0.0, 0.0); }\n   286→  let desired_speed = length(new_vel);\n   287→  var desired_dir = new_vel;\n   288→  if (desired_speed > 0.001) { desired_dir = desired_dir / desired_speed; }\n   289→  else { desired_dir = old_dir; }\n   290→  let final_dir = normalize(mix(old_dir, desired_dir, params.smoothing));\n   291→\n   292→  // Speed with drag\n   293→  let drag_scale = 1.0 / mix(1.0, boid.size_factor, params.drag_factor);\n   294→  var final_speed = mix(old_speed, desired_speed, 0.15);\n   295→  final_speed = clamp(final_speed, params.min_speed * drag_scale, params.max_speed * drag_scale);\n   296→  new_vel = final_dir * final_speed;\n   297→\n   298→  // Direction change metric\n   299→  let dir_change_val = 1.0 - clamp(dot(old_dir, final_dir), -1.0, 1.0);\n   300→  let effective_dt = params.dt;\n   301→\n   302→  // Write outputs\n   303→  boids_dst[i].pos = boid.pos + new_vel * effective_dt;\n   304→  boids_dst[i].vel = new_vel;\n   305→  boids_dst[i].size_factor = boid.size_factor;\n   306→  boids_dst[i].heading = final_dir;\n   307→  boids_dst[i].speed = final_speed;\n   308→  boids_dst[i].neighbor_count = f32(n_found);\n   309→  boids_dst[i].dir_change = dir_change_val;\n   310→  let vel_d2 = dot(boid.vel, boid.vel);\n   311→  let avg_d2 = dot(avg_vel, avg_vel);\n   312→  boids_dst[i].flock_alignment = select(dot(boid.vel, avg_vel) * inverseSqrt(vel_d2 * avg_d2), 0.0, vel_d2 < 0.001 || avg_d2 < 0.001);\n   313→  boids_dst[i].sep_pressure = length(sep_force);\n   314→  boids_dst[i].density = f32(n_found) / f32(K_NEIGHBORS);\n   315→}\n   316→\n   317→// === Auto-range stats ===\n   318→@group(1) @binding(0) var<storage, read_write> stats: array<atomic<u32>, 2>;\n   319→\n   320→fn get_metric(boid: Boid, source: u32) -> f32 {\n   321→  switch (source) {\n   322→    case 0u: { return dot(normalize(boid.heading + vec3f(0.0001, 0.0, 0.0)), vec3f(0.3, 0.4, 0.3)) + 0.5; }\n   323→    case 1u: { return boid.speed; }\n   324→    case 2u: { return boid.dir_change; }\n   325→    case 3u: { return boid.neighbor_count; }\n   326→    case 4u: { return (boid.pos.y + 50.0) / 100.0; }\n   327→    case 5u: { return length(boid.pos) / 50.0; }\n   328→    case 6u: { return boid.flock_alignment * 0.5 + 0.5; }\n   329→    case 7u: { return boid.sep_pressure; }\n   330→    case 8u: { return boid.density; }\n   331→    case 9u: { return 0.5; }\n   332→    default: { return 0.5; }\n   333→  }\n   334→}\n   335→\n   336→@compute @workgroup_size(64)\n   337→fn clear_stats(@builtin(global_invocation_id) id: vec3u) {\n   338→  if (id.x == 0u) {\n   339→    atomicStore(&stats[0], bitcast<u32>(1e10));\n   340→    atomicStore(&stats[1], 0u);\n   341→  }\n   342→}\n   343→\n   344→@compute @workgroup_size(64)\n   345→fn compute_stats(@builtin(global_invocation_id) id: vec3u) {\n   346→  let i = id.x;\n   347→  if (i >= params.num_boids) { return; }\n   348→  let val = get_metric(boids_src[i], params.color_source);\n   349→  let val_bits = bitcast<u32>(val);\n   350→  atomicMin(&stats[0], val_bits);\n   351→  atomicMax(&stats[1], val_bits);\n   352→}\n   353→\n   354→// === Murmuration Quality Metrics ===\n   355→// Computes behavioral metrics for evaluating murmuration quality.\n   356→// Uses @group(1) @binding(1) for a metrics buffer (separate from auto-range stats).\n   357→// 16 atomic u32 slots, interpreted as f32 via bitcast accumulation.\n   358→\n   359→@group(1) @binding(1) var<storage, read_write> metrics: array<atomic<u32>, 16>;\n   360→\n   361→// Slots:\n   362→// 0: count of boids with >= 5 neighbors (cohesion)\n   363→// 1: sum of neighbor_count (for avg)\n   364→// 2: sum of velocity_correlation (dot products)\n   365→// 3: sum of pos.x\n   366→// 4: sum of pos.y\n   367→// 5: sum of pos.z\n   368→// 6: sum of pos.x^2\n   369→// 7: sum of pos.y^2\n   370→// 8: sum of pos.z^2\n   371→// 9: sum of neighbor_count^2 (for variance)\n   372→// 10: count of boids processed\n   373→\n   374→@compute @workgroup_size(64)\n   375→fn clear_metrics(@builtin(global_invocation_id) id: vec3u) {\n   376→  if (id.x == 0u) {\n   377→    for (var k = 0u; k < 16u; k++) {\n   378→      atomicStore(&metrics[k], 0u);\n   379→    }\n   380→  }\n   381→}\n   382→\n   383→// Atomic float add via CAS loop\n   384→fn atomic_add_f32(slot: u32, val: f32) {\n   385→  var old = atomicLoad(&metrics[slot]);\n   386→  loop {\n   387→    let new_val = bitcast<f32>(old) + val;\n   388→    let result = atomicCompareExchangeWeak(&metrics[slot], old, bitcast<u32>(new_val));\n   389→    if (result.exchanged) { break; }\n   390→    old = result.old_value;\n   391→  }\n   392→}\n   393→\n   394→@compute @workgroup_size(64)\n   395→fn compute_metrics(@builtin(global_invocation_id) id: vec3u) {\n   396→  let i = id.x;\n   397→  if (i >= params.num_boids) { return; }\n   398→\n   399→  let boid = boids_src[i];\n   400→\n   401→  // Cohesion: count boids with >= 5 neighbors\n   402→  if (boid.neighbor_count >= 5.0) {\n   403→    atomicAdd(&metrics[0], 1u);\n   404→  }\n   405→\n   406→  // Neighbor count sum\n   407→  atomic_add_f32(1u, boid.neighbor_count);\n   408→\n   409→  // Velocity correlation (flock_alignment is already dot(my_vel, avg_neighbor_vel))\n   410→  atomic_add_f32(2u, boid.flock_alignment);\n   411→\n   412→  // Position sums for covariance\n   413→  atomic_add_f32(3u, boid.pos.x);\n   414→  atomic_add_f32(4u, boid.pos.y);\n   415→  atomic_add_f32(5u, boid.pos.z);\n   416→  atomic_add_f32(6u, boid.pos.x * boid.pos.x);\n   417→  atomic_add_f32(7u, boid.pos.y * boid.pos.y);\n   418→  atomic_add_f32(8u, boid.pos.z * boid.pos.z);\n   419→\n   420→  // Neighbor count squared for variance\n   421→  atomic_add_f32(9u, boid.neighbor_count * boid.neighbor_count);\n   422→\n   423→  // Total count\n   424→  atomicAdd(&metrics[10], 1u);\n   425→}\n   426→"}]},"parent_tool_use_id":null,"session_id":"6b0e04ab-0a04-4fdc-bf69-142a37b30a0b","uuid":"d45bbeaa-f659-4c69-8104-7f0cd2d339df","timestamp":"2026-03-23T05:29:27.286Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/aaronlemke/AI/Murmuration/shader.wgsl","content":"// === 3D Murmuration Compute Shader — Topological Neighbor Model ===\n// Based on empirical starling research: birds track their nearest 7 neighbors,\n// not all within a fixed radius. This produces realistic wave propagation,\n// sharp flock edges, and coordinated turns.\n\nstruct SimParams {\n  num_boids: u32,\n  grid_size: u32,\n  grid_cells: u32,\n  world_size: f32,\n  cell_size: f32,\n  visual_range: f32,\n  visual_range_sq: f32,\n  separation_dist: f32,\n  separation_dist_sq: f32,\n  align_factor: f32,\n  cohesion_factor: f32,\n  separation_factor: f32,\n  max_speed: f32,\n  min_speed: f32,\n  dt: f32,\n  turn_factor: f32,\n  smoothing: f32,\n  sim_speed: f32,\n  size_randomness: f32,\n  drag_factor: f32,\n  gradient_id: u32,\n  color_source: u32,\n  sphere_radius: f32,\n  frame_count: u32,\n}\n\nstruct Boid {\n  pos: vec3f,\n  size_factor: f32,\n  vel: vec3f,\n  speed: f32,\n  heading: vec3f,\n  neighbor_count: f32,\n  dir_change: f32,\n  flock_alignment: f32,\n  sep_pressure: f32,\n  density: f32,\n}\n\n@group(0) @binding(0) var<uniform> params: SimParams;\n@group(0) @binding(1) var<storage, read_write> boids_src: array<Boid>;\n@group(0) @binding(2) var<storage, read_write> boids_dst: array<Boid>;\n@group(0) @binding(3) var<storage, read_write> cell_counts: array<atomic<u32>>;\n@group(0) @binding(4) var<storage, read_write> cell_offsets: array<u32>;\n@group(0) @binding(5) var<storage, read_write> boid_cells: array<u32>;\n@group(0) @binding(6) var<storage, read_write> sorted_indices: array<u32>;\n@group(0) @binding(7) var<storage, read_write> scatter_counters: array<atomic<u32>>;\n\nfn get_cell(pos: vec3f) -> vec3u {\n  let half = params.world_size * 0.5;\n  return vec3u(clamp(\n    vec3i(floor((pos + vec3f(half)) / params.cell_size)),\n    vec3i(0),\n    vec3i(i32(params.grid_size) - 1)\n  ));\n}\n\nfn cell_index(c: vec3u) -> u32 {\n  return c.x + c.y * params.grid_size + c.z * params.grid_size * params.grid_size;\n}\n\n@compute @workgroup_size(64)\nfn clear_grid(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.grid_cells) { return; }\n  atomicStore(&cell_counts[i], 0u);\n  atomicStore(&scatter_counters[i], 0u);\n}\n\n@compute @workgroup_size(64)\nfn assign_cells(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.num_boids) { return; }\n  let cell = cell_index(get_cell(boids_src[i].pos));\n  boid_cells[i] = cell;\n  atomicAdd(&cell_counts[cell], 1u);\n}\n\nconst SCAN_WG: u32 = 256u;\nvar<workgroup> scan_sums: array<u32, 256>;\n\n@compute @workgroup_size(256)\nfn prefix_sum(@builtin(local_invocation_id) lid: vec3u) {\n  let tid = lid.x;\n  let chunk = (params.grid_cells + SCAN_WG - 1u) / SCAN_WG;\n  let start = tid * chunk;\n  let end = min(start + chunk, params.grid_cells);\n  var local_total = 0u;\n  for (var i = start; i < end; i++) {\n    let count = atomicLoad(&cell_counts[i]);\n    cell_offsets[i] = local_total;\n    local_total += count;\n  }\n  scan_sums[tid] = local_total;\n  workgroupBarrier();\n  for (var stride = 1u; stride < SCAN_WG; stride *= 2u) {\n    let val = select(0u, scan_sums[tid - stride], tid >= stride);\n    workgroupBarrier();\n    scan_sums[tid] += val;\n    workgroupBarrier();\n  }\n  let prefix = select(0u, scan_sums[tid - 1u], tid > 0u);\n  for (var i = start; i < end; i++) {\n    cell_offsets[i] += prefix;\n  }\n}\n\n@compute @workgroup_size(64)\nfn scatter(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.num_boids) { return; }\n  let cell = boid_cells[i];\n  let local_offset = atomicAdd(&scatter_counters[cell], 1u);\n  sorted_indices[cell_offsets[cell] + local_offset] = i;\n}\n\n// === Topological Neighbor Flocking ===\n// Find the K nearest neighbors (K=7 for alignment/cohesion, closest 1 for avoidance)\n// Uses the spatial hash to find candidates, then keeps only the K closest.\n\nconst K_NEIGHBORS: u32 = 7u;\n\n@compute @workgroup_size(64)\nfn flock(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.num_boids) { return; }\n\n  let boid = boids_src[i];\n  let my_grid = get_cell(boid.pos);\n  let gs = i32(params.grid_size);\n  let mg = vec3i(my_grid);\n\n  // Track K nearest neighbors by distance (insertion sort into small array)\n  // Store squared distances and indices\n  var nearest_d2: array<f32, 7>;   // distances squared\n  var nearest_idx: array<u32, 7>;  // boid indices\n  var n_found = 0u;\n\n  // Initialize with large distances\n  for (var k = 0u; k < K_NEIGHBORS; k++) {\n    nearest_d2[k] = 1e10;\n    nearest_idx[k] = 0u;\n  }\n\n  // Search 3x3x3 neighborhood (27 cells)\n  let lo = max(mg - vec3i(1), vec3i(0));\n  let hi = min(mg + vec3i(1), vec3i(gs - 1));\n\n  var total_candidates = 0u;\n\n  for (var nz = lo.z; nz <= hi.z; nz++) {\n    let zoff = u32(nz) * params.grid_size * params.grid_size;\n    for (var ny = lo.y; ny <= hi.y; ny++) {\n      let yzoff = u32(ny) * params.grid_size + zoff;\n      for (var nx = lo.x; nx <= hi.x; nx++) {\n        let nc = u32(nx) + yzoff;\n        let start = cell_offsets[nc];\n        let end_val = select(cell_offsets[nc + 1u], params.num_boids, nc + 1u >= params.grid_cells);\n        if (start >= end_val) { continue; }\n\n        for (var j = start; j < end_val; j++) {\n          let other_idx = sorted_indices[j];\n          if (other_idx == i) { continue; }\n\n          let other_pos = boids_src[other_idx].pos;\n          let diff = boid.pos - other_pos;\n          let d2 = dot(diff, diff);\n\n          // Pre-filter by visual range before K-nearest sort\n          if (d2 > params.visual_range_sq) { continue; }\n\n          total_candidates++;\n\n          // Insert into sorted K-nearest if closer than current worst\n          if (d2 < nearest_d2[K_NEIGHBORS - 1u]) {\n            // Find insertion position\n            var pos = K_NEIGHBORS - 1u;\n            for (var k = 0u; k < K_NEIGHBORS - 1u; k++) {\n              if (d2 < nearest_d2[k]) {\n                pos = k;\n                break;\n              }\n            }\n            // Shift larger entries down\n            for (var k = K_NEIGHBORS - 1u; k > pos; k--) {\n              nearest_d2[k] = nearest_d2[k - 1u];\n              nearest_idx[k] = nearest_idx[k - 1u];\n            }\n            nearest_d2[pos] = d2;\n            nearest_idx[pos] = other_idx;\n            n_found = min(n_found + 1u, K_NEIGHBORS);\n          }\n        }\n      }\n    }\n  }\n\n  // === Apply flocking rules using topological neighbors ===\n  var new_vel = boid.vel;\n\n  // Avoidance: only the 1 nearest neighbor\n  var sep_force = vec3f(0.0);\n  if (n_found > 0u && nearest_d2[0] < params.separation_dist_sq) {\n    let other_pos = boids_src[nearest_idx[0]].pos;\n    let diff = boid.pos - other_pos;\n    let d2 = nearest_d2[0];\n    sep_force = diff * (1.0 - d2 / params.separation_dist_sq);\n    new_vel += sep_force * params.separation_factor * 2.0; // stronger since only 1 neighbor\n  }\n\n  // Alignment + Cohesion: all K neighbors\n  var ali = vec3f(0.0);\n  var coh = vec3f(0.0);\n  var avg_vel = vec3f(0.0);\n  if (n_found > 0u) {\n    for (var k = 0u; k < min(n_found, K_NEIGHBORS); k++) {\n      let other = boids_src[nearest_idx[k]];\n      ali += other.vel;\n      coh += other.pos;\n    }\n    let nf = f32(min(n_found, K_NEIGHBORS));\n    avg_vel = ali / nf;\n    let avg_pos = coh / nf;\n    new_vel += (avg_vel - boid.vel) * params.align_factor;\n    new_vel += (avg_pos - boid.pos) * params.cohesion_factor;\n  }\n\n  // === Murmuration-specific forces ===\n\n  // Gravity: slight downward pull (creates the flat pancake shape)\n  new_vel.y -= 0.06;\n\n  // Center-seeking: gentle drift toward local flock center\n  if (n_found >= 2u) {\n    let local_center = coh / f32(min(n_found, K_NEIGHBORS));\n    let to_center = local_center - boid.pos;\n    let center_dist = length(to_center);\n    if (center_dist > 0.5) {\n      new_vel += normalize(to_center) * 0.08;\n    }\n  }\n\n  // Roost attractor: orbiting point that guides flock into sweeping arcs\n  let time = f32(params.frame_count) * 0.002;\n  let roost = vec3f(\n    sin(time) * params.sphere_radius * 0.4,\n    cos(time * 0.7) * params.sphere_radius * 0.05,\n    cos(time) * params.sphere_radius * 0.4\n  );\n  let to_roost = roost - boid.pos;\n  let roost_dist = length(to_roost);\n  if (roost_dist > 1.0) {\n    new_vel += normalize(to_roost) * 0.3;\n  }\n\n  // Random perturbation: breaks symmetry, triggers wave cascades\n  let noise_seed = f32(i * 1973u + params.frame_count * 9277u);\n  let noise = vec3f(\n    fract(sin(noise_seed) * 43758.5) - 0.5,\n    fract(sin(noise_seed * 1.3) * 22578.1) - 0.5,\n    fract(sin(noise_seed * 0.7) * 31415.9) - 0.5\n  ) * 0.15;\n  new_vel += noise;\n\n  // Spherical boundary steering\n  let dist_from_center = length(boid.pos);\n  let r = params.sphere_radius;\n  let soft_zone = r * 0.15;\n  if (dist_from_center > r - soft_zone && dist_from_center > 0.001) {\n    let penetration = (dist_from_center - (r - soft_zone)) / soft_zone;\n    let push = -normalize(boid.pos) * params.turn_factor * clamp(penetration, 0.0, 3.0);\n    new_vel += push;\n  }\n\n  // Turn rate limiter (smooth heading changes — creates wave-like motion)\n  let old_speed = length(boid.vel);\n  var old_dir = boid.vel;\n  if (old_speed > 0.001) { old_dir = old_dir / old_speed; }\n  else { old_dir = vec3f(1.0, 0.0, 0.0); }\n  let desired_speed = length(new_vel);\n  var desired_dir = new_vel;\n  if (desired_speed > 0.001) { desired_dir = desired_dir / desired_speed; }\n  else { desired_dir = old_dir; }\n  let final_dir = normalize(mix(old_dir, desired_dir, params.smoothing));\n\n  // Speed with drag\n  let drag_scale = 1.0 / mix(1.0, boid.size_factor, params.drag_factor);\n  var final_speed = mix(old_speed, desired_speed, 0.15);\n  final_speed = clamp(final_speed, params.min_speed * drag_scale, params.max_speed * drag_scale);\n  new_vel = final_dir * final_speed;\n\n  // Direction change metric\n  let dir_change_val = 1.0 - clamp(dot(old_dir, final_dir), -1.0, 1.0);\n  let effective_dt = params.dt;\n\n  // Write outputs\n  boids_dst[i].pos = boid.pos + new_vel * effective_dt;\n  boids_dst[i].vel = new_vel;\n  boids_dst[i].size_factor = boid.size_factor;\n  boids_dst[i].heading = final_dir;\n  boids_dst[i].speed = final_speed;\n  boids_dst[i].neighbor_count = f32(n_found);\n  boids_dst[i].dir_change = dir_change_val;\n  let vel_d2 = dot(boid.vel, boid.vel);\n  let avg_d2 = dot(avg_vel, avg_vel);\n  boids_dst[i].flock_alignment = select(dot(boid.vel, avg_vel) * inverseSqrt(vel_d2 * avg_d2), 0.0, vel_d2 < 0.001 || avg_d2 < 0.001);\n  boids_dst[i].sep_pressure = length(sep_force);\n  boids_dst[i].density = f32(n_found) / f32(K_NEIGHBORS);\n}\n\n// === Auto-range stats ===\n@group(1) @binding(0) var<storage, read_write> stats: array<atomic<u32>, 2>;\n\nfn get_metric(boid: Boid, source: u32) -> f32 {\n  switch (source) {\n    case 0u: { return dot(normalize(boid.heading + vec3f(0.0001, 0.0, 0.0)), vec3f(0.3, 0.4, 0.3)) + 0.5; }\n    case 1u: { return boid.speed; }\n    case 2u: { return boid.dir_change; }\n    case 3u: { return boid.neighbor_count; }\n    case 4u: { return (boid.pos.y + 50.0) / 100.0; }\n    case 5u: { return length(boid.pos) / 50.0; }\n    case 6u: { return boid.flock_alignment * 0.5 + 0.5; }\n    case 7u: { return boid.sep_pressure; }\n    case 8u: { return boid.density; }\n    case 9u: { return 0.5; }\n    default: { return 0.5; }\n  }\n}\n\n@compute @workgroup_size(64)\nfn clear_stats(@builtin(global_invocation_id) id: vec3u) {\n  if (id.x == 0u) {\n    atomicStore(&stats[0], bitcast<u32>(1e10));\n    atomicStore(&stats[1], 0u);\n  }\n}\n\n@compute @workgroup_size(64)\nfn compute_stats(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.num_boids) { return; }\n  let val = get_metric(boids_src[i], params.color_source);\n  let val_bits = bitcast<u32>(val);\n  atomicMin(&stats[0], val_bits);\n  atomicMax(&stats[1], val_bits);\n}\n\n// === Murmuration Quality Metrics ===\n// Computes behavioral metrics for evaluating murmuration quality.\n// Uses @group(1) @binding(1) for a metrics buffer (separate from auto-range stats).\n// 16 atomic u32 slots, interpreted as f32 via bitcast accumulation.\n\n@group(1) @binding(1) var<storage, read_write> metrics: array<atomic<u32>, 16>;\n\n// Slots:\n// 0: count of boids with >= 5 neighbors (cohesion)\n// 1: sum of neighbor_count (for avg)\n// 2: sum of velocity_correlation (dot products)\n// 3: sum of pos.x\n// 4: sum of pos.y\n// 5: sum of pos.z\n// 6: sum of pos.x^2\n// 7: sum of pos.y^2\n// 8: sum of pos.z^2\n// 9: sum of neighbor_count^2 (for variance)\n// 10: count of boids processed\n\n@compute @workgroup_size(64)\nfn clear_metrics(@builtin(global_invocation_id) id: vec3u) {\n  if (id.x == 0u) {\n    for (var k = 0u; k < 16u; k++) {\n      atomicStore(&metrics[k], 0u);\n    }\n  }\n}\n\n// Atomic float add via CAS loop\nfn atomic_add_f32(slot: u32, val: f32) {\n  var old = atomicLoad(&metrics[slot]);\n  loop {\n    let new_val = bitcast<f32>(old) + val;\n    let result = atomicCompareExchangeWeak(&metrics[slot], old, bitcast<u32>(new_val));\n    if (result.exchanged) { break; }\n    old = result.old_value;\n  }\n}\n\n@compute @workgroup_size(64)\nfn compute_metrics(@builtin(global_invocation_id) id: vec3u) {\n  let i = id.x;\n  if (i >= params.num_boids) { return; }\n\n  let boid = boids_src[i];\n\n  // Cohesion: count boids with >= 5 neighbors\n  if (boid.neighbor_count >= 5.0) {\n    atomicAdd(&metrics[0], 1u);\n  }\n\n  // Neighbor count sum\n  atomic_add_f32(1u, boid.neighbor_count);\n\n  // Velocity correlation (flock_alignment is already dot(my_vel, avg_neighbor_vel))\n  atomic_add_f32(2u, boid.flock_alignment);\n\n  // Position sums for covariance\n  atomic_add_f32(3u, boid.pos.x);\n  atomic_add_f32(4u, boid.pos.y);\n  atomic_add_f32(5u, boid.pos.z);\n  atomic_add_f32(6u, boid.pos.x * boid.pos.x);\n  atomic_add_f32(7u, boid.pos.y * boid.pos.y);\n  atomic_add_f32(8u, boid.pos.z * boid.pos.z);\n\n  // Neighbor count squared for variance\n  atomic_add_f32(9u, boid.neighbor_count * boid.neighbor_count);\n\n  // Total count\n  atomicAdd(&metrics[10], 1u);\n}\n","numLines":426,"startLine":1,"totalLines":426}}}
